    "bfb2124e-0fa8-401d-84d8-2ee2d104a660": {
      "type": "home-8",
      "settings": {
        "hd": "\"Do you own a rare car?\"",
        "des": "<p>Can't find floor mats for YOUR unique car?<br/><br/>We have contacts throughout Poland and abroad with various car dealerships where we take measurements when you are unable to come to us. We approach each measurement with the kind of perfection that a watchmaker puts together a watch.<br/><br/>Fill out this form and we will realize customized floor mats for your car.</p>",
        "btn_text": "Custom order",
        "btn_url": "shopify://products/customized-order-for-your-vehicle-advance-payment-100",
        "img": "shopify://shop_images/Frame_34-removebg-preview_1_1.webp"
      }
    },
    "71ff6538-4b35-41d3-a6c7-6412594d6409": {
      "type": "home-faq",
      "blocks": {
        "374876f6-aa24-46f3-9b69-3aa07e7dd528": {
          "type": "text",
          "settings": {
            "hd": "Floor Coverage and Fit",
            "des": "<p><strong>-Will the mats fit for sure?</strong><br/>Yes, our EVA mats are specifically designed for each car brand, model, and version, covering the entire floor surface and protecting areas not covered by rubber and velour mats.</p><p><strong>-What is a tunnel mat?</strong><br/>EVA mats cover up to 98% of the floor, including the central tunnel, ensuring maximum protection.</p><p><strong>-Is the heel pad installed on the driver’s mat?</strong><br/>No, the heel pad is provided separately so that it can be adjusted to your individual preferences.</p>"
          }
        },
        "text_f4MJE7": {
          "type": "text",
          "settings": {
            "hd": "Material Features and Durability",
            "des": "<p><strong>    -What is EVA material?</strong><br/>It is a 10 mm thick foam that traps dirt and water on the surface of the mat, preventing them from seeping underneath.</p><p><strong>   -What is the difference between a 3D set and a 3D set with edges?</strong><br/>A 3D set with edges provides additional protection for the side floor upholstery, ensuring a better fit.  </p><p><strong> -How long do the mats last?</strong><br/> Thanks to the durable EVA material, the mats last from 5 to 7 years without signs of wear.</p>"
          }
        },
        "text_dkbcKW": {
          "type": "text",
          "settings": {
            "hd": "Usage and Maintenance",
            "des": "<p><strong>-How to clean EVA mats?</strong><br/>Dirt does not stick to the surface of the mat. Simply shake them out or, in case of heavy dirt, wash them with a pressure washer.</p><p><br/><strong>-Are EVA mats suitable for summer and winter?</strong><br/>Yes, they are waterproof, odorless, temperature-resistant, and perfect for year-round use.</p>"
          }
        },
        "text_ie3jjY": {
          "type": "text",
          "settings": {
            "hd": "Order and Delivery",
            "des": "<p><strong>-What is the delivery time?</strong><br/>We usually fulfill orders within 2 weeks. For special vehicles, such as motorboats or tractors, the time may extend to 4–6 weeks.<br/></p><p><strong>-What is the delivery method?</strong><br/>We ship the mats via courier directly to the customer's specified address. We do not send mats to parcel lockers due to the product's size. We ensure that the mats are delivered in the same form in which they were made, without folding or bending, as this could affect their fit.</p>"
          }
        }
      },
