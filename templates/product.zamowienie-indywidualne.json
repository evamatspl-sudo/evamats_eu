    "e857fdc5-7358-4bf5-80d4-611e2484d845": {
      "type": "home-8",
      "disabled": true,
      "settings": {
        "hd": "<h1>Do jakiego <span>transportu? <\/span>\n<\/h1>",
        "des": "<p>Vyrábíme stylové EVA koberce pro všechny druhy dopravy: auta, lodě, letadla atd. Nabízíme řešení přizpůsobená přesným rozměrům vašeho vozidla. Různé vzory a nejvyšší kvalita za dostupnou cenu.<\/p>",
        "btn_text": "OBJEDNAT KOBEREC",
        "btn_url": "shopify:\/\/pages\/zamowienie-indywidualne"
      }
    },
    "c605d8f3-dc8c-4614-8c41-de8a728399a1": {
      "type": "collapsible-content",
      "blocks": {
        "template--18288166109490__c605d8f3-dc8c-4614-8c41-de8a728399a1-1679587212fe76a58e-0": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Co je materiál EVA?",
            "icon": "none",
            "row_content": "<p>EVA je ethylen-vinylacetát, lehký a elastický materiál s voděodolnými vlastnostmi.<br\/>Díky hypoalergennímu složení koberce nezapáchají ani při vysokých teplotách.<\/p>",
            "page": ""
          }
        },
        "template--18288166109490__c605d8f3-dc8c-4614-8c41-de8a728399a1-1679587212fe76a58e-2": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Jak správně namontovat koberce z materiálu EVA?",
            "icon": "none",
            "row_content": "<p>Každá sada má určený typ upevnění, máme více než 30 typů. Upevnění montujeme na správných místech a navíc přišíváme suché zipy po stranách, aby se koberce neposouvaly a držely na místě.<\/p>",
            "page": ""
          }
        },
        "template--18288166109490__c605d8f3-dc8c-4614-8c41-de8a728399a1-1679587212fe76a58e-3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Potřebuji výjimečný koberec?",
            "icon": "none",
            "row_content": "<p>Je možné vyrobit samostatný koberec na plynovou lahev, pokud trčí v kufru, nebo zakrýt větší plochu podlahy na určených místech podle požadavků zákazníka.<\/p>",
            "page": ""
          }
        },
        "template--18288166109490__c605d8f3-dc8c-4614-8c41-de8a728399a1-1679587212fe76a58e-1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Lze prát koberce z materiálu EVA?",
            "icon": "none",
            "row_content": "<p>Ano, koberce lze čistit měkkou houbičkou a detergentem. Nedoporučuje se však používat agresivní chemické čisticí prostředky.<\/p>",
            "page": ""
          }
        },
        "4585ff0f-b735-4703-9e3f-52b91d99c12d": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Mají koberce záruku?",
            "icon": "none",
            "row_content": "<p>Poskytujeme záruku jeden rok od převzetí koberců, co umožňuje výměnu sady do jednoho roku v případě deformace nebo otěrů. Díky kvalitnímu materiálu však koberce vydrží 5–7 let.<\/p>",
            "page": ""
          }
        }
      },
