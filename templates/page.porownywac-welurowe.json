          "type": "block",
          "settings": {
            "header": "<h2>Disadvantages of velour mats </h2>",
            "unordered_list": "<ul><li>They absorb water and contaminants deep within the fabric structure</li><li>Difficult to clean</li><li>Quickly lose their original appearance</li><li>The area under the right foot wears out very quickly</li><li>Cover only 60-70% of the available floor surface</li><li>Not resistant to chemicals</li><li>Offer basic customization</li></ul>",
            "image": "shopify://shop_images/IMG_8796_1_1.png"
          }
        },
        "block_YfT8nF": {
