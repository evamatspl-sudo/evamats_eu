          "settings": {
            "header": "<p><strong>Advantages </strong>of EVA mats</p>",
            "unordered_list": "<ul><li>Perfectly fitted</li><li>Ultra lightweight and easy to clean</li><li>Odorless ECO material, non-toxic</li><li>Waterproof</li><li>195 color combinations</li><li>Technological cells trap various types of contaminants</li></ul>",
