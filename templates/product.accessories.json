    },
    "1f13addc-5ac5-4bf9-a9f1-de28ec681035": {
      "type": "advantages-home-2",
      "disabled": true,
      "settings": {
        "img1": "shopify:\/\/shop_images\/1.png",
        "des1": "<p>Trwałe, nie tracą swojego wyglądu z upływem czasu<\/p>",
        "img2": "shopify:\/\/shop_images\/High_Temperature_Meteorology_Symbol.I16_1.png",
        "des2": "<p>Wytrzymuje temperaturyod -50 °C do +50 °C<\/p>",
        "img3": "shopify:\/\/shop_images\/1_3853e075-6a50-4722-aa6e-3fdfd4d9847a.png",
        "des3": "<p>Odporność na działanie detergentów<\/p>"
