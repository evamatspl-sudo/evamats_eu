    "0801e0f0-d696-4558-b05e-3648c986e943": {
      "type": "home-10",
      "disabled": true,
      "custom_css": [],
      "settings": {
        "hd": "Maty do łodzi!",
        "des": "<p>Produkujemy maty na indywidualne zamówienia. Na przykład na łodzie, samoloty i inne rodzaje transportu według spersonalizowanych wymiarów. Napisz do nas, a spełnimy wszystkie Twoje życzenia!<\/p>",
