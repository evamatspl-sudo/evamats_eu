        },
        "template--18288166109490__c605d8f3-dc8c-4614-8c41-de8a728399a1-1679587212fe76a58e-2": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Jak správně namontovat koberce z materiálu EVA?",
            "icon": "none",
            "row_content": "<p>Každá sada má určený typ upevnění, máme více než 30 typů. Upevnění montujeme na správných místech a navíc přišíváme suché zipy po stranách, aby se koberce neposouvaly a držely na místě.</p>",
            "page": ""
          }
        },
        "template--18288166109490__c605d8f3-dc8c-4614-8c41-de8a728399a1-1679587212fe76a58e-3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Potřebuji výjimečný koberec?",
            "icon": "none",
            "row_content": "<p>Je možné vyrobit samostatný koberec na plynovou lahev, pokud trčí v kufru, nebo zakrýt větší plochu podlahy na určených místech podle požadavků zákazníka.</p>",
            "page": ""
          }
        },
        "template--18288166109490__c605d8f3-dc8c-4614-8c41-de8a728399a1-1679587212fe76a58e-1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Lze prát koberce z materiálu EVA?",
            "icon": "none",
            "row_content": "<p>Ano, koberce lze čistit měkkou houbičkou a detergentem. Nedoporučuje se však používat agresivní chemické čisticí prostředky.</p>",
            "page": ""
          }
        },
        "4585ff0f-b735-4703-9e3f-52b91d99c12d": {
          "type": "collapsible_row",
