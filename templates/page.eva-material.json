    "0ca031b3-1d4a-4a14-9172-d6c1118bf269": {
      "type": "text-with-image-right",
      "disabled": true,
      "settings": {
        "des": "<p>EVA material is <strong>a popular choice for car mats.<\/strong> It stands for ethylene vinylacetylene, which means it is a thermoplastic polymer. This material offers many advantages that make it ideal for use in cars.<\/p><p>One of the most important advantages of EVA is its <strong>durability<\/strong>. It is a material <strong>with high resistance to abrasion and deformation<\/strong>, which makes it ideal for use in car mats. In addition, the material is also resistant to weathering, such as sun or rain, making it ideal for use in cars that are often exposed to the weather.<\/p>",
        "img": "shopify:\/\/shop_images\/Group_184_eed00412-fc64-4df2-8337-6457204238c3.png"
      }
    },
