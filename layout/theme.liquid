  </head>

  <body class="gradient template_{{ template.name }} {% if page %} template_{{ page.template_suffix }}{% endif %} {% if product.template_suffix %}suffix_{{ product.template_suffix }}{% endif %}{% if evamats_is_v2_page %} evamats-v2{% endif %}">

    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ "accessibility.skip_to_text" | t }}
    </a>

    {%- if settings.cart_type == 'drawer' -%}
      {%- render 'cart-drawer' -%}
    {%- endif -%}

    {% sections 'header-group' %}

    <main
      id="MainContent"
      class="content-for-layout focus-none"
      role="main"
      tabindex="-1">
      <div class="globoRecommendationsTop"></div>
      {{ content_for_layout }}<div class="globoRecommendationsBottom"></div>
    </main>

    {% sections 'footer-group' %}
    {% comment %} {% section 'cookie-banner' %} {% endcomment %}
    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    <div id="popupOverlayLipComment" class="popup_overlay popup-overlay--lip_comment">
      <div class="popup-overlay--lip_comment__inner">
        <div class="popup">
          <div class="popup-content rte">
            {{ settings.popup_info_text }}
          </div>
        </div>
        <button type="button" class="popup_close_btn" aria-label="{{ 'accessibility.close' | t }}">
          {% render 'icon-close' %}
        </button>
      </div>
    </div>
    <div id="popupOverlayUpsellVideo" class="popup_overlay popup-overlay--upsell_video">
      <div class="popup">
          <div class="popup-content rte">
            {% assign upsell_popup_page = pages['product-upsell-popup-content'] %}
            {% if upsell_popup_page != empty %}
              {{ upsell_popup_page.content }}
            {% else %}
              {{ settings.product_upsell_text }}
            {% endif %}
          </div>
      </div>
      <span class="popup_close_btn" >{% render 'icon-close' %}</span>
    </div>
    {% if request.locale.iso_code == 'en'  %}
      <div id="popupOverlayRightHand" class="popup_overlay popup-overlay--right_hand">
        <div class="popup">
            <div class="popup-content">
                {{ 'general.config.right_hand_message_long' | t }}
            </div>
        </div>
        <span class="popup_close_btn" >{% render 'icon-close' %}</span>
      </div>      
    {% endif %}
    {% comment %} {% unless cart.empty? or template contains 'cart' %} 
      
      <div class="cart__toast">
        <img src="{{cart.items[0].image | img_url: '100x' }}" alt="" class="cart__toast_image" loading="lazy">

        <div class="cart__toast_info">
          <div class="cart__toast_text">{{ 'general.cart.opportunity' | t }}</div>
