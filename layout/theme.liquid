      <script>
        (function() {
          'use strict';

          var lastSalePrice = '';
          var lastOriginalPrice = '';
          var isUpdating = false;

          function getSalePrice() {
            var sourceDmixer = document.querySelector('dmixer-discounted-price');
            if (!sourceDmixer || !sourceDmixer.shadowRoot) return '';
            var el = sourceDmixer.shadowRoot.querySelector('.dmixer-dp-price');
            return el ? el.textContent.trim() : '';
          }

          function getOriginalPrice() {
            var el = document.querySelector('.price-item--regular.dmixer-original-price');
            return el ? el.textContent.trim() : '';
          }

          function applyToZestaw() {
            if (isUpdating) return false;

            var salePrice = getSalePrice();
            if (!salePrice) return false;

            var originalPrice = getOriginalPrice();

            var targetCompare = document.querySelector('.option__price_compare');
            var targetRegular = document.querySelector('.option__price_regular');
            if (!targetCompare || !targetRegular) return false;

            if (targetRegular.textContent.trim() === salePrice &&
                targetCompare.textContent.trim() === originalPrice) {
              return true;
            }

            isUpdating = true;

            if (originalPrice) {
              targetCompare.textContent = originalPrice;
              targetCompare.classList.remove('hidden');
            }
            targetRegular.textContent = salePrice;

            lastSalePrice = salePrice;
            lastOriginalPrice = originalPrice;

            setTimeout(function() { isUpdating = false; }, 50);
            return true;
          }

          var attempts = 0;
          var maxAttempts = 50;
          var initialInterval = setInterval(function() {
            attempts++;
            if (applyToZestaw() || attempts >= maxAttempts) {
              clearInterval(initialInterval);
              startObservers();
            }
          }, 200);

          function startObservers() {
            var sourceDmixer = document.querySelector('dmixer-discounted-price');
            if (sourceDmixer && sourceDmixer.shadowRoot) {
              new MutationObserver(applyToZestaw).observe(sourceDmixer.shadowRoot, {
                childList: true, subtree: true, characterData: true
              });
            }

            var targetWrapper = document.querySelector('.option__price_wr');
            if (targetWrapper) {
              new MutationObserver(function() {
                if (isUpdating) return;
                applyToZestaw();
              }).observe(targetWrapper, {
                childList: true, subtree: true, characterData: true, attributes: true
              });
            }

            var originalEl = document.querySelector('.price-item--regular.dmixer-original-price');
            if (originalEl) {
              new MutationObserver(applyToZestaw).observe(originalEl, {
                childList: true, subtree: true, characterData: true
              });
            }

            setInterval(applyToZestaw, 500);
          }
        })();
      </script>

