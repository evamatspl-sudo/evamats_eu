    {% if template.name contains 'index' %}
      <script defer>
        const time = +document.querySelector('.hero-slider').dataset.time;

        function heroSlider() {
            const swiperHero = new Swiper('.hero-slider', {
                spaceBetween: 30,
                virtualTranslate: true,
                effect: "fade",
                centeredSlides: true,
                fadeEffect: { crossFade: true },
                slidesPerView: 1,
                pagination: {
                    el: ".hero-slider .swiper-pagination",
                    clickable: true,
                },
                autoplay: {
                    delay: time,
                    disableOnInteraction: false,
                },
                on: {
                    slideChange: function () {
                        toggleAutoplay(this);
                    }
                }
            });

            function toggleAutoplay(swiper) {
                const activeSlide = swiper.slides[swiper.activeIndex];
                const desktopVideo = activeSlide.querySelector('.hero-slider__video_desktop');
                const mobileVideo = activeSlide.querySelector('.hero-slider__video_mobile');
    
                // Определяем текущее видео (проверяем, какое из них отображается)
                const video = window.innerWidth <= 768 ? mobileVideo : desktopVideo;
                if (video) {
                    swiper.autoplay.stop();
                    video.play();

                    video.addEventListener('ended', () => {
                        swiper.autoplay.start();
                    }, { once: true });
                } else {
                    swiper.autoplay.start();
                }
            }

            toggleAutoplay(swiperHero);
        }

        if (Shopify.designMode) {
            heroSlider();
            document.addEventListener('shopify:section:load', function () {
                heroSlider();
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            heroSlider();
        });

        {% comment %} document.addEventListener('DOMContentLoaded', () => {
          document.querySelectorAll('.hero-slider__video_full').forEach(button => {
              button.addEventListener('click', function () {
                  const slide = this.closest('.swiper-slide');
                  const desktopVideo = slide.querySelector('.hero-slider__video_desktop');
                  const mobileVideo = slide.querySelector('.hero-slider__video_mobile');
      
                  // Определяем текущее видео (проверяем, какое из них отображается)
                  const video = window.innerWidth <= 768 ? mobileVideo : desktopVideo;
      
                  if (video) {
                      video.muted = false;
                      video.currentTime = 0.1;
                      video.load();
      
                      // Отключаем playsinline перед полноэкранным режимом (для iOS)
                      video.removeAttribute('playsinline');
      
                      if (video.requestFullscreen) {
                          video.requestFullscreen();
                      } else if (video.webkitRequestFullscreen) {
                          video.webkitRequestFullscreen();
                      } else if (video.msRequestFullscreen) {
                          video.msRequestFullscreen();
                      } else if (video.webkitEnterFullscreen) { // Для iOS Safari
                          video.webkitEnterFullscreen();
                      }
      
                      // Следим за выходом из fullscreen и возвращаем playsinline + mute
                      const resetMuted = () => {
                          if (!document.fullscreenElement && !document.webkitFullscreenElement && !document.msFullscreenElement) {
                              video.muted = true;
                              video.setAttribute('playsinline', 'true'); // Возвращаем playsinline
                              document.removeEventListener('fullscreenchange', resetMuted);
                              document.removeEventListener('webkitfullscreenchange', resetMuted);
                              document.removeEventListener('msfullscreenchange', resetMuted);
                          }
                      };
      
                      document.addEventListener('fullscreenchange', resetMuted);
                      document.addEventListener('webkitfullscreenchange', resetMuted);
                      document.addEventListener('msfullscreenchange', resetMuted);
                  }
              });
          });
      }); {% endcomment %}
      

      </script>
