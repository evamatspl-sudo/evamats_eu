{{ 'evamats-breadcrumbs.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign desktop_image = section.settings.image_desktop
  assign mobile_image = section.settings.image_mobile
  assign desktop_ratio = desktop_image.aspect_ratio | default: 2.1333
  assign mobile_ratio = mobile_image.aspect_ratio | default: desktop_ratio

  assign breadcrumb_parent_label = section.settings.parent_label | strip
  if breadcrumb_parent_label == blank
    assign breadcrumb_parent_label = shop.name
  endif

  assign breadcrumb_parent_url = section.settings.parent_url | strip
  if breadcrumb_parent_url == blank
    assign breadcrumb_parent_url = routes.root_url
  endif

  assign breadcrumb_current_label = section.settings.current_label | strip
  if breadcrumb_current_label == blank and page != blank
    assign breadcrumb_current_label = page.title
  endif

  assign show_breadcrumbs = false
  if section.settings.show_breadcrumbs and breadcrumb_current_label != blank
    assign show_breadcrumbs = true
  endif
-%}

<div
  id="MediaBannerV2-{{ section.id }}"
  class="media-banner-v2 media-banner-v2--height-{{ section.settings.height_mode }}"
  style="
    --media-banner-height-desktop: {{ section.settings.height_desktop }}px;
    --media-banner-height-mobile: {{ section.settings.height_mobile }}px;
    --media-banner-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --media-banner-content-bottom-offset: {{ section.settings.content_bottom_offset }}px;
    --media-banner-ratio-desktop: {{ desktop_ratio }};
    --media-banner-ratio-mobile: {{ mobile_ratio }};
  "
>
  <div class="media-banner-v2__media">
    {%- if desktop_image != blank -%}
      <picture>
        {%- if mobile_image != blank -%}
          <source media="(max-width: 749px)" srcset="{{ mobile_image | image_url: width: 1200 }}">
        {%- endif -%}
        {{
          desktop_image
          | image_url: width: 3840
          | image_tag:
            loading: 'lazy',
            class: 'media-banner-v2__image',
            widths: '750, 1100, 1500, 1780, 2000, 3000, 3840'
        }}
      </picture>
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'media-banner-v2__placeholder placeholder-svg' }}
    {%- endif -%}
    <div class="media-banner-v2__overlay"></div>
  </div>

  {%- if show_breadcrumbs or section.settings.heading != blank or section.settings.text != blank -%}
    <div class="media-banner-v2__ui page-width">
      {%- if show_breadcrumbs -%}
        {% render 'evamats-breadcrumbs',
          parent_label: breadcrumb_parent_label,
          parent_url: breadcrumb_parent_url,
          current_label: breadcrumb_current_label,
          class: 'media-banner-v2__breadcrumbs'
        %}
      {%- endif -%}

      {%- if section.settings.heading != blank or section.settings.text != blank -%}
        <div class="media-banner-v2__content">
          {%- if section.settings.heading != blank -%}
            <h2 class="media-banner-v2__heading section_title">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}
          {%- if section.settings.text != blank -%}
            <div class="media-banner-v2__text body-m">{{ section.settings.text }}</div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% comment %} styles moved to assets/base.css (style) {% endcomment %}

{% schema %}
{
  "name": "Media Banner v2",
  "class": "section_v2",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Desktop height",
      "min": 400,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 900
    },
    {
      "type": "select",
      "id": "height_mode",
      "label": "Banner height mode",
      "options": [
        {
          "value": "auto",
          "label": "Auto (image ratio)"
        },
        {
          "value": "custom",
          "label": "Custom height"
        }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Mobile height",
      "min": 220,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 650
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "range",
      "id": "content_bottom_offset",
      "label": "Content bottom offset",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Breadcrumbs"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs on banner",
      "default": false
    },
    {
      "type": "text",
      "id": "parent_label",
      "label": "Breadcrumb — parent",
      "default": "Carvion",
      "info": "Leave empty to use shop name."
    },
    {
      "type": "url",
      "id": "parent_url",
      "label": "Breadcrumb — parent link",
      "info": "Leave empty for homepage."
    },
    {
      "type": "text",
      "id": "current_label",
      "label": "Breadcrumb — current page",
      "info": "Leave empty to use page title."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nowa wersja mat EVA"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Lekki i nowoczesny baner dla strony ADV.</p>"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Media Banner v2",
      "category": "V2"
    }
  ]
}
{% endschema %}
