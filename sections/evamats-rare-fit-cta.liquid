{{ 'section-evamats-rare-fit-cta.css' | asset_url | stylesheet_tag }}
{% render 'evamats-section-padding-style', section: section, target: '.evamats-rare-fit-cta' %}

{%- liquid
  assign image_desktop = section.settings.image_desktop
  assign image_mobile = section.settings.image_mobile
  if image_mobile == blank
    assign image_mobile = image_desktop
  endif
-%}

<section id="EvamatsRareFitCta-{{ section.id }}" class="evamats-rare-fit-cta">
  <div class="evamats-rare-fit-cta__inner page-width">
    <div class="evamats-rare-fit-cta__banner">
      {%- if image_desktop != blank -%}
        <div class="evamats-rare-fit-cta__media" aria-hidden="true">
          <picture>
            {%- if section.settings.image_mobile != blank -%}
              <source media="(max-width: 749px)" srcset="{{ image_mobile | image_url: width: 800 }}">
            {%- elsif image_desktop != blank -%}
              <source media="(max-width: 749px)" srcset="{{ image_desktop | image_url: width: 800 }}">
            {%- endif -%}
            {{
              image_desktop
              | image_url: width: 3040
              | image_tag:
                class: 'evamats-rare-fit-cta__media-img',
                loading: 'lazy',
                widths: '375, 750, 1100, 1500, 1520, 2000, 3040',
                sizes: '(min-width: 750px) 1520px, 100vw',
                alt: ''
            }}
          </picture>
          <div class="evamats-rare-fit-cta__fade evamats-rare-fit-cta__fade--left"></div>
          <div class="evamats-rare-fit-cta__fade evamats-rare-fit-cta__fade--right"></div>
        </div>
      {%- endif -%}

      <div class="evamats-rare-fit-cta__panel">
        {%- if settings.logo != blank -%}
          <div class="evamats-rare-fit-cta__logo">
            {{
              settings.logo
              | image_url: width: 284
              | image_tag:
                loading: 'lazy',
                class: 'evamats-rare-fit-cta__logo-img',
                widths: '109, 142, 284',
                sizes: '(min-width: 750px) 142px, 109px',
                alt: settings.logo.alt | default: shop.name
            }}
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="evamats-rare-fit-cta__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="evamats-rare-fit-cta__text">{{ section.settings.text | escape }}</p>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a
            class="evamats-rare-fit-cta__cta"
            href="{% if section.settings.button_link != blank %}{{ section.settings.button_link }}{% else %}#{% endif %}"
          >
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rare fit CTA",
  "tag": "section",
  "class": "section-evamats-rare-fit-cta",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background image (mobile)",
      "info": "Optional. Uses desktop image when empty."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "paragraph",
      "content": "Logo is taken from Theme settings → Logo."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dopasowanie tam, gdzie inni nie mają rozwiązania"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Tworzymy dywaniki na zamówienie — nawet dla rzadkich modeli aut"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Sprawdź możliwość wykonania"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Section spacing (desktop)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "header",
      "content": "Section spacing (mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Rare fit CTA"
    }
  ]
}
{% endschema %}
