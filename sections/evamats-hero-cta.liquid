{%- liquid
  assign hero_image = section.settings.image
  assign hero_image_mobile = section.settings.image_mobile
  if hero_image_mobile == blank
    assign hero_image_mobile = hero_image
  endif
-%}

{% render 'evamats-section-padding-style', section: section, target: '.evamats-hero-cta__intro' %}
<div
  id="EvamatsHeroCta-{{ section.id }}"
  class="evamats-hero-cta"
>
  <div class="evamats-hero-cta__intro">
    <div class="evamats-hero-cta__inner page-width">
      {%- if section.settings.eyebrow != blank -%}
        <p class="evamats-hero-cta__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="evamats-hero-cta__heading section_title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="evamats-hero-cta__description rte">{{ section.settings.description }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="button-row-v2 evamats-hero-cta__actions">
          {%- if section.settings.button_link != blank -%}
            <a class="button button_3" href="{{ section.settings.button_link }}">
              {{- section.settings.button_label | escape -}}
            </a>
          {%- elsif section.settings.button_scroll_to_list -%}
            <a
              class="button button_3"
              href="#vacancies-list"
              data-evamats-hero-cta-scroll="{{ section.settings.button_scroll_selector | escape }}"
            >
              {{- section.settings.button_label | escape -}}
            </a>
          {%- else -%}
            <span class="button button_3 disabled" aria-disabled="true">
              {{- section.settings.button_label | escape -}}
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="evamats-hero-cta__media">
    {%- if hero_image != blank -%}
      <picture>
        {%- if section.settings.image_mobile != blank -%}
          <source media="(max-width: 749px)" srcset="{{ hero_image_mobile | image_url: width: 1200 }}">
        {%- endif -%}
        {{
          hero_image
          | image_url: width: 2400
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            class: 'evamats-hero-cta__image',
            widths: '375, 550, 750, 1100, 1500, 1780, 2000, 2400',
            sizes: '100vw'
        }}
      </picture>
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'evamats-hero-cta__image evamats-hero-cta__image--placeholder' }}
    {%- endif -%}
  </div>
</div>

{%- if section.settings.button_label != blank and section.settings.button_link == blank and section.settings.button_scroll_to_list -%}
  <script>
    (function () {
      var btn = document.querySelector('#EvamatsHeroCta-{{ section.id }} [data-evamats-hero-cta-scroll]');
      if (!btn) return;
      btn.addEventListener('click', function (e) {
        var target = document.querySelector(btn.getAttribute('data-evamats-hero-cta-scroll') || '.main-blog');
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    })();
  </script>
{%- endif -%}

{% comment %} styles moved to assets/base.css (stylesheet) {% endcomment %}

{% schema %}
{
  "name": "Carvion — Hero CTA",
  "tag": "section",
  "class": "section-evamats-hero-cta",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Pracovní nabídky"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Připojte se k týmu Carvion"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Vytváříme místo, kde záleží na lidech, spolupráci a skutečném vlivu na rozvoj firmy.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Zobrazit nabídky"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_scroll_to_list",
      "label": "Scroll to content below when link is empty",
      "default": true
    },
    {
      "type": "text",
      "id": "button_scroll_selector",
      "label": "Scroll target selector",
      "default": ".main-blog",
      "info": "CSS selector for in-page scroll when button link is empty."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image (mobile)",
      "info": "Optional. Uses desktop image when empty."
    },
    {
      "type": "header",
      "content": "Section spacing (desktop)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding (intro)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Section spacing (mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top (intro)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (intro)",
      "default": 44
    }
  ],
  "presets": [
    {
      "name": "Carvion — Hero CTA",
      "category": "V2"
    }
  ]
}
{% endschema %}
