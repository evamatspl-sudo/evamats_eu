{%- liquid
  assign slide_count = 0
  assign point_count = 0
  for block in section.blocks
    if block.type == 'slide'
      assign slide_count = slide_count | plus: 1
    endif
    if block.type == 'point'
      assign point_count = point_count | plus: 1
    endif
  endfor

  assign media_is_video = false
  if section.settings.media_type == 'video' and section.settings.video_desktop != blank
    assign media_is_video = true
  endif

  assign video_desktop_src = ''
  assign video_mobile_src = ''
  if media_is_video
    assign video_desktop_src = section.settings.video_desktop.sources[1].url
    if section.settings.video_mobile != blank
      assign video_mobile_src = section.settings.video_mobile.sources[1].url
    else
      assign video_mobile_src = video_desktop_src
    endif
  endif
-%}

<div
  id="ProductSpotlight-{{ section.id }}"
  class="product-spotlight-v2"
  data-slide-count="{{ slide_count }}"
  data-ps-media-mode="{% if media_is_video %}video{% else %}carousel{% endif %}"
>
  <div class="product-spotlight-v2__inner page-width">
    <div class="product-spotlight-v2__grid">
      <div class="product-spotlight-v2__content">
        {%- if section.settings.overline != blank -%}
          <p class="product-spotlight-v2__overline">{{ section.settings.overline | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="product-spotlight-v2__heading section_title">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if point_count > 0 -%}
          <ul class="product-spotlight-v2__points">
            {%- for block in section.blocks -%}
              {%- if block.type == 'point' -%}
              <li class="product-spotlight-v2__point" {{ block.shopify_attributes }}>
                <span class="product-spotlight-v2__point-icon" aria-hidden="true">
                  {%- if block.settings.icon != blank -%}
                    {{
                      block.settings.icon
                      | image_url: width: 120
                      | image_tag:
                        loading: 'lazy',
                        class: 'product-spotlight-v2__point-icon-img',
                        widths: '40, 60, 80, 120',
                        sizes: '60px'
                    }}
                  {%- else -%}
                    <svg class="product-spotlight-v2__point-icon-default" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="20" cy="20" r="19" fill="none" stroke="var(--color-accent-red)" stroke-width="2" />
                      <g transform="translate(12, 14)">
                        <path d="M1.41406 5.78681L5.82919 10.4141L14.4141 1.41406" stroke="currentColor" stroke-width="2" stroke-miterlimit="10" stroke-linecap="square" />
                      </g>
                    </svg>
                  {%- endif -%}
                </span>
                <span class="product-spotlight-v2__point-text">{{ block.settings.text | escape }}</span>
              </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
          <a class="button button_3 product-spotlight-v2__cta" href="{{ section.settings.cta_url }}">{{ section.settings.cta_label | escape }}</a>
        {%- elsif section.settings.cta_label != blank -%}
          <span class="button button_3 product-spotlight-v2__cta disabled" aria-disabled="true">{{ section.settings.cta_label | escape }}</span>
        {%- endif -%}
      </div>

      <div class="product-spotlight-v2__media">
        <div class="product-spotlight-v2__slider-row{% if media_is_video %} product-spotlight-v2__slider-row--video{% endif %}">
          {%- unless media_is_video -%}
          {% render 'eva-slider-nav-button',
            direction: 'prev',
            size: 'medium',
            color: 'white',
            class: 'product-spotlight-v2__nav product-spotlight-v2__nav--prev',
            label: 'Poprzedni slajd'
          %}
          {%- endunless -%}

          {%- if media_is_video -%}
            <div class="product-spotlight-v2__video-wrap" data-ps-video-root>
              <video
                class="product-spotlight-v2__video product-spotlight-v2__video--desktop"
                data-ps-video="desktop"
                data-src="{{ video_desktop_src }}"
                muted
                playsinline
                loop
                controls
                autoplay
                preload="none"
                {% if section.settings.video_desktop.preview_image != blank %}
                  poster="{{ section.settings.video_desktop.preview_image | image_url: width: 1200 }}"
                {% endif %}
                aria-hidden="true"
              ></video>
              <video
                class="product-spotlight-v2__video product-spotlight-v2__video--mobile"
                data-ps-video="mobile"
                data-src="{{ video_mobile_src }}"
                muted
                playsinline
                loop
                controls
                autoplay
                preload="none"
                {%- assign video_mobile_poster = section.settings.video_mobile.preview_image | default: section.settings.video_desktop.preview_image -%}
                {%- if video_mobile_poster != blank -%}
                  poster="{{ video_mobile_poster | image_url: width: 800 }}"
                {%- endif -%}
                aria-hidden="true"
              ></video>
            </div>
          {%- else -%}
          <div class="swiper product-spotlight-v2__swiper" data-ps-swiper>
            <div class="swiper-wrapper">
              {%- if slide_count > 0 -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'slide' -%}
                    <div class="swiper-slide product-spotlight-v2__slide" {{ block.shopify_attributes }}>
                      {%- if block.settings.image != blank -%}
                        {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'product-spotlight-v2__slide-img', sizes: '(min-width: 990px) 50vw, 90vw', widths: '400, 600, 800, 1000, 1200' }}
                      {%- else -%}
                        {{ 'lifestyle-1' | placeholder_svg_tag: 'product-spotlight-v2__slide-img product-spotlight-v2__placeholder' }}
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              {%- else -%}
                <div class="swiper-slide product-spotlight-v2__slide">
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'product-spotlight-v2__slide-img product-spotlight-v2__placeholder' }}
                </div>
              {%- endif -%}
            </div>
          </div>
          {%- endif -%}

          {%- unless media_is_video -%}
          {% render 'eva-slider-nav-button',
            direction: 'next',
            size: 'medium',
            color: 'white',
            class: 'product-spotlight-v2__nav product-spotlight-v2__nav--next',
            label: 'Další snímek'
          %}
          {%- endunless -%}
        </div>

        {%- if slide_count > 1 and media_is_video == false -%}
          <div class="product-spotlight-v2__pagination swiper-pagination" data-ps-pagination></div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% comment %} styles moved to assets/base_v2.css (style) {% endcomment %}

{% javascript %}
  (function () {
    function destroySpotlight(root) {
      if (!root) return;
      if (root._psSwiper) {
        try {
          root._psSwiper.destroy(true, true);
        } catch (e) {}
        root._psSwiper = null;
      }
      if (root._psVideoIO) {
        try {
          root._psVideoIO.disconnect();
        } catch (e) {}
        root._psVideoIO = null;
      }
      if (root._psVideoMq) {
        var mqDestroy = root._psVideoMq;
        if (mqDestroy.removeEventListener) {
          mqDestroy.removeEventListener('change', root._psVideoMqHandler);
        } else if (mqDestroy.removeListener) {
          mqDestroy.removeListener(root._psVideoMqHandler);
        }
        root._psVideoMq = null;
        root._psVideoMqHandler = null;
      }
      root.querySelectorAll('[data-ps-video]').forEach(function (video) {
        video.pause();
        video.removeAttribute('src');
        try {
          video.load();
        } catch (e) {}
      });
      delete root.dataset.psVideoInit;
      delete root.dataset.psSwiperInit;
    }

    function initSpotlightVideo(root) {
      if (!root || root.dataset.psVideoInit === '1') return;
      var videoRoot = root.querySelector('[data-ps-video-root]');
      if (!videoRoot) return;
      var desktopEl = videoRoot.querySelector('[data-ps-video="desktop"]');
      var mobileEl = videoRoot.querySelector('[data-ps-video="mobile"]');
      if (!desktopEl && !mobileEl) return;

      root.dataset.psVideoInit = '1';
      var isInView = false;

      if (typeof window.evamatsBindVideoFullscreen === 'function') {
        window.evamatsBindVideoFullscreen(root);
      }

      function activeVideo() {
        var isDesktop = window.matchMedia('(min-width: 990px)').matches;
        if (isDesktop) return desktopEl || mobileEl;
        return mobileEl || desktopEl;
      }

      function pauseAll() {
        [desktopEl, mobileEl].forEach(function (video) {
          if (video && !video.paused) video.pause();
        });
      }

      function playVideo(video) {
        if (!video) return;
        var tryPlay = function () {
          if (!isInView && !(typeof Shopify !== 'undefined' && Shopify.designMode)) return;
          var playPromise = video.play();
          if (playPromise && playPromise.catch) {
            playPromise.catch(function () {});
          }
        };
        if (!video.src) {
          var src = video.getAttribute('data-src');
          if (!src) return;
          video.src = src;
          if (video.readyState >= 2) {
            tryPlay();
          } else {
            video.addEventListener('loadeddata', tryPlay, { once: true });
            video.addEventListener('canplay', tryPlay, { once: true });
          }
          return;
        }
        if (video.paused) tryPlay();
      }

      function playActive() {
        var active = activeVideo();
        if (!active) return;
        pauseAll();
        playVideo(active);
      }

      if (typeof Shopify !== 'undefined' && Shopify.designMode) {
        isInView = true;
        playActive();
        return;
      }

      root._psVideoIO = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            isInView = entry.isIntersecting;
            if (isInView) {
              playActive();
            } else {
              pauseAll();
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px 80px 0px' }
      );
      root._psVideoIO.observe(root);

      var mq = window.matchMedia('(min-width: 990px)');
      root._psVideoMq = mq;
      root._psVideoMqHandler = function () {
        if (!isInView) return;
        playActive();
      };
      if (mq.addEventListener) {
        mq.addEventListener('change', root._psVideoMqHandler);
      } else if (mq.addListener) {
        mq.addListener(root._psVideoMqHandler);
      }
    }

    function initProductSpotlight(root) {
      if (!root) return;

      var mediaMode = root.dataset.psMediaMode || 'carousel';
      if (mediaMode === 'video') {
        if (root.dataset.psVideoInit === '1') return;
        initSpotlightVideo(root);
        return;
      }

      if (root.dataset.psSwiperInit === '1') return;

      var swiperEl = root.querySelector('[data-ps-swiper]');
      if (!swiperEl) return;

      var slides = swiperEl.querySelectorAll('.swiper-slide');
      var count = slides.length;
      if (!count) return;

      var prevEl = root.querySelector('.product-spotlight-v2__nav--prev');
      var nextEl = root.querySelector('.product-spotlight-v2__nav--next');
      var paginationEl = root.querySelector('[data-ps-pagination]');

      function run() {
        if (typeof window.Swiper === 'undefined') return;
        if (root.dataset.psSwiperInit === '1') return;
        root.dataset.psSwiperInit = '1';

        var opts = {
          slidesPerView: 1,
          speed: 400,
          watchOverflow: true,
          navigation: {
            prevEl: prevEl,
            nextEl: nextEl,
          },
        };

        if (paginationEl && count > 1) {
          opts.pagination = {
            el: paginationEl,
            clickable: true,
          };
        }

        root._psSwiper = new window.Swiper(swiperEl, opts);
      }

      function whenSwiperReady(cb) {
        if (typeof window.Swiper !== 'undefined') {
          cb();
          return;
        }
        if (typeof window.ensureSwiperLoaded === 'function') {
          window.ensureSwiperLoaded(cb);
          return;
        }
        var done = false;
        var poll = null;
        function finish() {
          if (done) return;
          if (typeof window.Swiper === 'undefined') return;
          done = true;
          document.removeEventListener('swiper-loaded', onLoaded);
          if (poll) clearInterval(poll);
          cb();
        }
        function onLoaded() {
          finish();
        }
        document.addEventListener('swiper-loaded', onLoaded);
        poll = setInterval(finish, 50);
        setTimeout(function () {
          if (poll) clearInterval(poll);
          document.removeEventListener('swiper-loaded', onLoaded);
        }, 8000);
      }

      whenSwiperReady(run);
    }

    function initAll() {
      document.querySelectorAll('.product-spotlight-v2').forEach(initProductSpotlight);
    }

    function scheduleInit() {
      function go() {
        initAll();
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function onDom() {
          document.removeEventListener('DOMContentLoaded', onDom);
          setTimeout(go, 0);
        });
      } else {
        setTimeout(go, 0);
      }
    }

    scheduleInit();
    document.addEventListener('swiper-loaded', initAll);

    document.addEventListener('shopify:section:load', function (ev) {
      var target = ev.target;
      if (!target || !target.querySelector) return;
      var el = target.classList.contains('product-spotlight-v2') ? target : target.querySelector('.product-spotlight-v2');
      if (el) {
        destroySpotlight(el);
        setTimeout(function () {
          initProductSpotlight(el);
        }, 0);
      }
    });

    document.addEventListener('shopify:section:unload', function (ev) {
      var target = ev.target;
      if (!target || !target.querySelector) return;
      var el = target.classList.contains('product-spotlight-v2') ? target : target.querySelector('.product-spotlight-v2');
      if (el) destroySpotlight(el);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Product spotlight v2",
  "tag": "section",
  "class": "section_v2",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "To nie detal. To element systemu."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stále více řidičů přestává brát koberce jako doplněk."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Zobacz produkt"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media",
      "options": [
        {
          "value": "carousel",
          "label": "Image carousel"
        },
        {
          "value": "video",
          "label": "Video (MP4)"
        }
      ],
      "default": "carousel"
    },
    {
      "type": "video",
      "id": "video_desktop",
      "label": "Video — desktop",
      "info": "Replaces the image carousel. Loads when scrolled into view."
    },
    {
      "type": "video",
      "id": "video_mobile",
      "label": "Video — mobile",
      "info": "Optional. If empty, desktop video is used on mobile."
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Carousel mode only. Ignored when Media is Video."
        }
      ]
    },
    {
      "type": "point",
      "name": "Point",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (optional)",
          "info": "Square PNG or SVG, ~60×60 px. If empty, the default checkmark is shown."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Stejně jako chráníte lak, můžete chránit podlahu."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product spotlight v2",
      "category": "V2",
      "blocks": [
        {
          "type": "slide",
          "settings": {}
        },
        {
          "type": "point",
          "settings": {
            "text": "Stejně jako chráníte lak, můžete chránit podlahu."
          }
        },
        {
          "type": "point",
          "settings": {
            "text": "Protože čistý interiér není náhoda. Je to rozhodnutí."
          }
        }
      ]
    }
  ]
}
{% endschema %}
