{{ 'evamats-benefits.css' | asset_url | stylesheet_tag }}
<script src="{{ 'evamats-benefits.js' | asset_url }}" defer></script>

{% liquid
    assign background = section.settings.background
    assign text_color = section.settings.text_color

    assign benefits = blank

    if product and product.metafields.custom.evamats_benefits.value != blank
        assign benefits = product.metafields.custom.evamats_benefits.value

    elsif collection and collection.metafields.custom.evamats_benefits.value != blank
        assign benefits = collection.metafields.custom.evamats_benefits.value

    elsif page and page.metafields.custom.evamats_benefits.value != blank
        assign benefits = page.metafields.custom.evamats_benefits.value

    elsif article and article.metafields.custom.evamats_benefits.value != blank
        assign benefits = article.metafields.custom.evamats_benefits.value
    endif

    assign use_metaobjects = false

    if benefits != blank
        assign use_metaobjects = true
    endif

    assign padding_top = section.settings.padding_top | append: 'px'
    assign padding_top_mobile = section.settings.padding_top_mobile | append: 'px'
    assign padding_bottom = section.settings.padding_bottom | append: 'px'
    assign padding_bottom_mobile = section.settings.padding_bottom_mobile | append: 'px'

    assign title = section.settings.title
    assign image = section.settings.image

    assign metafield_title = blank
    assign metafield_image = blank

    if product
        assign metafield_title = product.metafields.custom.evamats_benefits_title
        assign metafield_image = product.metafields.custom.evamats_benefits_image

    elsif collection
        assign metafield_title = collection.metafields.custom.evamats_benefits_title
        assign metafield_image = collection.metafields.custom.evamats_benefits_image

    elsif page
        assign metafield_title = page.metafields.custom.evamats_benefits_title
        assign metafield_image = page.metafields.custom.evamats_benefits_image

    elsif article
        assign metafield_title = article.metafields.custom.evamats_benefits_title
        assign metafield_image = article.metafields.custom.evamats_benefits_image
    endif

    if metafield_title != blank
        assign title = metafield_title
    endif

    if metafield_image != blank
        assign image = metafield_image
    endif
%}

<section
        class="evamats-benefits"
        style="
                --background: {{ background }};
                --text_color: {{ text_color }};
                --padding_top: {{ padding_top }};
                --padding_top_mobile: {{ padding_top_mobile }};
                --padding_bottom: {{ padding_bottom }};
                --padding_bottom_mobile: {{ padding_bottom_mobile }};
                "
>
    <div class="page-width">

        <div class="evamats-benefits__wrapper">

            <div class="evamats-benefits__content">

                {% if title != blank %}
                    <h2 class="evamats-benefits__title">
                        {{ title }}
                    </h2>
                {% endif %}

                <div class="evamats-benefits__media evamats-benefits__media--mobile">

                    {% if image != blank %}

                        {{
                        image
                        | image_url: width: 1600
                        | image_tag:
                        loading: 'lazy',
                        widths: '600,900,1200,1600',
                        class: 'evamats-benefits__img'
                        }}

                    {% endif %}

                </div>

                <div class="evamats-benefits__accordion">

                    {% if use_metaobjects %}

                        {% for item in benefits %}

                            {% render 'evamats-benefits-item',
                                title: item.title.value,
                                text: item.description,
                                icon: item.icon.value,
                                is_metaobject: true
                            %}

                        {% endfor %}

                    {% else %}

                        {% for block in section.blocks %}

                            {% render 'evamats-benefits-item',
                                title: block.settings.heading,
                                text: block.settings.text,
                                icon: block.settings.icon,
                                is_metaobject: false
                            %}

                        {% endfor %}

                    {% endif %}

                </div>

            </div>

            <div class="evamats-benefits__media evamats-benefits__media--desktop">

                {% if image != blank %}

                    {{
                    image
                    | image_url: width: 1600
                    | image_tag:
                    loading: 'lazy',
                    widths: '600,900,1200,1600',
                    class: 'evamats-benefits__img'
                    }}

                {% endif %}

            </div>

        </div>

    </div>
</section>

{% schema %}
{
  "name": "EVAMATS Benefits",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1B1D22"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Fallback title",
      "default": "Dlaczego dywany EVAMATS są dobrym wyborem?"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback image"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "EVAMATS Benefits",
      "blocks": [
        {
          "type": "item"
        },
        {
          "type": "item"
        },
        {
          "type": "item"
        }
      ]
    }
  ]
}
{% endschema %}