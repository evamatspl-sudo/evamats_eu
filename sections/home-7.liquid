<div
            <div class="six-main">
                <div class="sixth-left">
                    <img src="{{ section.settings.img|img_url:'master' }}" alt="">
                </div>
                <div class="sixth-right">
                    <h1>{{ section.settings.hd }}</h1>
                   {{ section.settings.des }}
                    <a href="{{ section.settings.btn_url }}">
                            <button class="button">{{ section.settings.btn_text }}</button>
                            </a>
                </div>
            </div>
        </div>



{% schema %}
{
  "name": "home7",
  "settings": [
    {
      "type":"image_picker",
      "label":"Main Image",
      "id":"img"
    },
    {
      "type":"text",
      "label":"Main Heading",
      "id":"hd",
      "default":"O produkcie"
    },
    {
      "type":"richtext",
      "label":"Description",
      "id":"des",
      "default":"<p>We understand how important it is, to feel this specter of emotions. And this is exactly what we are doing in our company – helping you to form your kids` future. We understand how important it is, to feel this specter of emotions. And this is exactly what we are doing in our company – helping you to form your kids` future.</p>"
    },
    {
      "type":"text",
      "label":"Button Text",
      "id":"btn_text",
      "default":"SHOP NOW"
    },
    {
      "type":"url",
      "label":"Button Url",
      "id":"btn_url"
    }
  ],
  "presets":[
    {
      "name":"home7",
      "category":"custom"
    }
  ]
}
{% endschema %}