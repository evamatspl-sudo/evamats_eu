{{ 'section-evamats-contact-partners.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign partner_blocks = section.blocks | where: 'type', 'partner'
  assign has_partners = false
  if partner_blocks.size > 0
    assign has_partners = true
  endif
-%}

{%- if has_partners -%}
  <div class="evamats-contact-partners" id="EvamatsContactPartners-{{ section.id }}">
    <div class="evamats-contact-partners__inner page-width">
      {%- if section.settings.heading != blank -%}
        <h2 class="evamats-contact-partners__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="evamats-contact-partners__sub">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      <div class="evamats-contact-partners__grid">
        {%- for block in partner_blocks -%}
          <article class="evamats-contact-partners__card" {{ block.shopify_attributes }}>
            {%- if block.settings.logo != blank -%}
              <div class="evamats-contact-partners__logo">
                {{
                  block.settings.logo
                  | image_url: width: 180
                  | image_tag:
                    loading: 'lazy',
                    class: 'evamats-contact-partners__logo-img',
                    widths: '61, 90, 120, 180',
                    sizes: '(min-width: 750px) 90px, 61px',
                    alt: block.settings.logo.alt | default: block.settings.title
                }}
              </div>
            {%- endif -%}

            {%- if block.settings.title != blank or block.settings.address != blank -%}
              <div class="evamats-contact-partners__body">
                {%- if block.settings.title != blank -%}
                  <p class="evamats-contact-partners__title">{{ block.settings.title | escape }}</p>
                {%- endif -%}
                {%- if block.settings.address != blank -%}
                  <div class="evamats-contact-partners__address">{{ block.settings.address | newline_to_br }}</div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Contact partners",
  "tag": "section",
  "class": "section-evamats-contact-partners",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Gdzie znaleźć naszą produkcję?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Możesz zapoznać się z jakością naszych produktów lokalnie u naszych partnerów"
    }
  ],
  "blocks": [
    {
      "type": "partner",
      "name": "Partner location",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact partners",
      "blocks": [
        {
          "type": "partner",
          "settings": {
            "title": "Warszawa",
            "address": "al. „Solidarności” 163/lok.\nu010, 00-877"
          }
        },
        {
          "type": "partner",
          "settings": {
            "title": "Warszawa",
            "address": "ul. Jana Ostroroga 24C"
          }
        }
      ]
    }
  ]
}
{% endschema %}
