{{ 'section-evamats-home-hero.css' | asset_url | stylesheet_tag }}
{% render 'evamats-section-padding-style', section: section, target: '.evamats-home-hero' %}

{%- liquid
  assign bg_desktop = section.settings.image_desktop
  assign bg_mobile = section.settings.image_mobile
  assign fg_desktop = section.settings.foreground_desktop
  assign fg_mobile = section.settings.foreground_mobile

  if bg_mobile == blank
    assign bg_mobile = bg_desktop
  endif
  if fg_mobile == blank
    assign fg_mobile = fg_desktop
  endif
-%}

<section
  id="EvamatsHomeHero-{{ section.id }}"
  class="evamats-home-hero shopify-section"
  data-evamats-home-hero
>
  <div class="evamats-home-hero__bg evamats-home-hero__bg--desktop" aria-hidden="true">
    {%- if bg_desktop != blank -%}
      {{
        bg_desktop
        | image_url: width: 3840
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          class: 'evamats-home-hero__bg-image',
          sizes: '100vw',
          widths: '750, 1100, 1500, 1920, 2560, 3840'
      }}
    {%- endif -%}
  </div>

  <div class="evamats-home-hero__bg evamats-home-hero__bg--mobile" aria-hidden="true">
    {%- if bg_mobile != blank -%}
      {{
        bg_mobile
        | image_url: width: 1200
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          class: 'evamats-home-hero__bg-image',
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1200'
      }}
    {%- endif -%}
  </div>
 
  <div class="evamats-home-hero__inner page-width">
    <div class="evamats-home-hero__inner_top">
      {%- if section.settings.heading != blank -%}
        <h2 class="evamats-home-hero__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
  
      {%- if section.settings.subheading != blank -%}
        <p class="evamats-home-hero__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
  
      <div class="evamats-home-hero__filter">
        <div
          class="filter-container filter-container-json filter-container--hero"
          data-json="{{ 'all_brands.json' | asset_url }}"
          data-filter-ui="hero"
          data-files-cdn="https://cdn.shopify.com/s/files/1/0790/9218/7414/files/"
          data-label-brand="{{ 'general.config.brand' | t | escape }}"
          data-label-model="{{ 'general.config.model' | t | escape }}"
          data-label-generation="{{ 'general.config.generation' | t | escape }}"
        >
          <div class="custom-select-wrapper">
            <div class="custom-select brand-custom-select filter-field">
              <div class="filter-field__body">
                <div class="filter-field__media filter-field__media--brand">
                  <img class="filter-field__thumb filter-field__thumb--brand" alt="" width="30" height="30" hidden>
                </div>
                <div class="filter-field__content">
                  <span class="filter-field__label">{{ 'general.config.brand' | t }}</span>
                  <input type="text" class="select-selected brand-input" placeholder="{{ 'general.config.brand' | t }}" autocomplete="off">
                </div>
                {% render 'arrow-down' %}
              </div>
              <div class="select-items select-hide brand-select-options"></div>
            </div>
          </div>
          <div class="custom-select-divider"></div>
          <div class="custom-select-wrapper">
            <div class="custom-select model-custom-select filter-field">
              <div class="filter-field__body">
                {% comment %} <div class="filter-field__media filter-field__media--align" aria-hidden="true"></div> {% endcomment %}
                <div class="filter-field__content">
                  <span class="filter-field__label">{{ 'general.config.model' | t }}</span>
                  <input type="text" class="select-selected disabled model-input" placeholder="{{ 'general.config.model' | t }}" disabled autocomplete="off">
                </div>
                {% render 'arrow-down' %}
              </div>
              <div class="select-items select-hide model-select-options"></div>
            </div>
          </div>
          <div class="custom-select-divider"></div>
          <div class="custom-select-wrapper">
            <div class="custom-select years-custom-select filter-field">
              <div class="filter-field__body">
                <div class="filter-field__media filter-field__media--generation">
                  <img class="filter-field__thumb filter-field__thumb--generation" alt="" width="66" height="48" hidden>
                </div>
                <div class="filter-field__content">
                  <span class="filter-field__label">{{ 'general.config.generation' | t }}</span>
                  <input type="text" class="select-selected disabled years-input" placeholder="{{ 'general.config.generation' | t }}" autocomplete="off">
                </div>
                {% render 'arrow-down' %}
              </div>
              <div class="select-items select-hide years-select-options"></div>
            </div>
          </div>

          <button type="button" class="search-button button search-button-json" disabled aria-label="{{ 'general.config.search' | t }}">
            <span class="search-button__label">{{ 'general.config.search' | t }}</span>
          </button>
          <span class="clear-filters">{{ 'general.config.reset' | t }}</span>
        </div>
      </div>
    </div>
    

    {%- if section.settings.show_badges -%}
      <div class="evamats-home-hero__badges">
        {%- if section.settings.google_rating != blank -%}
          <div class="evamats-home-hero__badge evamats-home-hero__badge--google">
            <span class="evamats-home-hero__badge-rating">
              <svg class="evamats-home-hero__badge-star" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M10 1.5L12.3175 6.1825L17.5 6.9525L13.75 10.6175L14.635 15.7775L10 13.3275L5.365 15.7775L6.25 10.6175L2.5 6.9525L7.6825 6.1825L10 1.5Z" fill="#FBB000"/>
              </svg>
              {{ section.settings.google_rating | escape }}
            </span>
            {%- if section.settings.google_review_count != blank -%}
              <span class="evamats-home-hero__badge-count">{{ section.settings.google_review_count | escape }}</span>
            {%- endif -%}
            <svg class="evamats-home-hero__badge-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </div>
        {%- endif -%}

        {%- if section.settings.secondary_rating != blank -%}
          <div class="evamats-home-hero__badge evamats-home-hero__badge--secondary">
            <span class="evamats-home-hero__badge-rating">
              {%- if section.settings.secondary_icon != blank -%}
                {{
                  section.settings.secondary_icon
                  | image_url: width: 48
                  | image_tag: loading: 'lazy', class: 'evamats-home-hero__badge-icon evamats-home-hero__badge-icon--trust', widths: '23, 46'
                }}
              {%- else -%}
                <img
                  class="evamats-home-hero__badge-icon evamats-home-hero__badge-icon--trust"
                  src="{{ 'evamats-home-hero-badge-trust.png' | asset_url }}"
                  alt=""
                  width="23"
                  height="22"
                  loading="lazy"
                >
              {%- endif -%}
              {{ section.settings.secondary_rating | escape }}
            </span>
            {%- if section.settings.secondary_review_count != blank -%}
              <span class="evamats-home-hero__badge-count">{{ section.settings.secondary_review_count | escape }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "EVAMATS — Home hero",
  "tag": "section",
  "class": "section-evamats-home-hero",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dywaniki idealnie dopasowane do Twojego auta"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Tworzone na zamówienie. Maksymalna ochrona. Zero kompromisów."
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background image (mobile)",
      "info": "Optional. Uses desktop image when empty."
    },
    {
      "type": "image_picker",
      "id": "foreground_desktop",
      "label": "Foreground image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "foreground_mobile",
      "label": "Foreground image (mobile)",
      "info": "Optional. Uses desktop foreground when empty."
    },
    {
      "type": "header",
      "content": "Rating badges"
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "Show rating badges",
      "default": true
    },
    {
      "type": "text",
      "id": "google_rating",
      "label": "Google rating",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "google_review_count",
      "label": "Google review count",
      "default": "4481"
    },
    {
      "type": "text",
      "id": "secondary_rating",
      "label": "Secondary rating",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "secondary_review_count",
      "label": "Secondary review count",
      "default": "4481"
    },
    {
      "type": "image_picker",
      "id": "secondary_icon",
      "label": "Secondary badge icon"
    },
    {
      "type": "header",
      "content": "Section spacing (desktop)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section spacing (mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "EVAMATS — Home hero"
    }
  ]
}
{% endschema %}
