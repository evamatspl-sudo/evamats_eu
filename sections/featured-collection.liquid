{{ 'section-evamats-featured-collection.css' | asset_url | stylesheet_tag }}
{% render 'evamats-section-padding-style', section: section, target: '.evamats-featured-collection' %}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign products_to_show = section.settings.products_to_show
  assign collection = section.settings.collection
  assign product_count = 0

  if collection != blank
    for product in collection.products limit: products_to_show
      if product.type == 'mws_apo_generated'
        continue
      endif
      assign product_count = product_count | plus: 1
    endfor
  endif

  assign show_view_all = false
  if section.settings.show_view_all and collection != blank and product_count > 0
    assign show_view_all = true
  endif
-%}

<div
  id="EvamatsFeaturedCollection-{{ section.id }}"
  class="evamats-featured-collection"
  data-efc-root
>
  <div class="evamats-featured-collection__inner page-width">
    {%- if section.settings.title != blank -%}
      <div class="evamats-featured-collection__header">
        <h2 class="evamats-featured-collection__heading section_title">{{ section.settings.title | escape }}</h2>
        {%- if show_view_all -%}
          <a
            href="{{ collection.url }}"
            class="button button_5 button_5--neutral evamats-featured-collection__view-all--header small-hide"
          >
            {{ section.settings.view_all_label | escape }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- if product_count > 0 -%}
    <div class="evamats-featured-collection__slider-bleed page-width">
      <div class="evamats-featured-collection__stage">
        {%- if product_count > 3 -%}
          <button
            type="button"
            class="eva-slider-nav eva-slider-nav--absolute eva-slider-nav--prev evamats-featured-collection__nav evamats-featured-collection__nav--prev swiper-button-prev"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <span class="eva-slider-nav__icon eva-slider-nav__icon--prev" aria-hidden="true">
              <svg width="17" height="18" viewBox="0 0 17 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M8.10054 4.39663e-05L0.356982 7.7436C-0.118202 8.21879 -0.118201 8.98921 0.356983 9.46439L8.10054 17.208L9.82133 15.4872L4.15495 9.82078L16.123 9.82078L16.123 7.38722L4.15495 7.38722L9.82133 1.72084L8.10054 4.39663e-05Z" fill="white"/>
              </svg>
            </span>
          </button>
        {%- endif -%}

        <div class="evamats-featured-collection__inner ">
          <div
            class="evamats-featured-collection__swiper swiper"
            data-efc-swiper
            id="EfcSwiper-{{ section.id }}"
          >
            <div class="swiper-wrapper">
              {%- assign product_index = 0 -%}
              {%- for product in collection.products limit: products_to_show -%}
                {%- if product.type == 'mws_apo_generated' -%}{%- continue -%}{%- endif -%}
                {%- assign product_index = product_index | plus: 1 -%}
                {%- assign lazy_load_card = false -%}
                {%- if product_index > 4 -%}
                  {%- assign lazy_load_card = true -%}
                {%- endif -%}
                <div class="swiper-slide">
                  {% render 'evamats-product-card-bestseller',
                    card_product: product,
                    section_id: section.id,
                    lazy_load: lazy_load_card,
                    mobile_button_label: section.settings.mobile_button_label
                  %}
                </div>
              {%- endfor -%}
            </div>
          </div>
        </div>

        {%- if product_count > 3 -%}
          <button
            type="button"
            class="eva-slider-nav eva-slider-nav--absolute eva-slider-nav--next evamats-featured-collection__nav evamats-featured-collection__nav--next swiper-button-next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <span class="eva-slider-nav__icon eva-slider-nav__icon--next" aria-hidden="true">
              <svg width="17" height="18" viewBox="0 0 17 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M8.89946 4.39663e-05L16.643 7.7436C17.1182 8.21879 17.1182 8.98921 16.643 9.46439L8.89946 17.208L7.17867 15.4872L12.8451 9.82078H0.877005V7.38722H12.8451L7.17867 1.72084L8.89946 4.39663e-05Z" fill="white"/>
              </svg>
            </span>
          </button>
        {%- endif -%}
      </div>
    </div>

    {%- if show_view_all -%}
      <div class="evamats-featured-collection__inner page-width">
        <div class="evamats-featured-collection__view-all--footer">
          <a href="{{ collection.url }}" class="button button_5 button_5--neutral">
            {{ section.settings.view_all_label | escape }}
          </a>
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

<script>
  (function () {
    function whenSwiperReady(cb) {
      if (typeof window.Swiper !== 'undefined') {
        cb();
        return;
      }
      if (typeof window.ensureSwiperLoaded === 'function') {
        window.ensureSwiperLoaded(cb);
        return;
      }
      var tries = 0;
      var timer = setInterval(function () {
        tries += 1;
        if (typeof window.Swiper !== 'undefined') {
          clearInterval(timer);
          cb();
        } else if (tries > 80) {
          clearInterval(timer);
        }
      }, 50);
    }

    function isSliderViewport() {
      return window.matchMedia('(min-width: 750px)').matches;
    }

    function destroyMainSwiper(root) {
      if (root._efcSwiper && typeof root._efcSwiper.destroy === 'function') {
        root._efcSwiper.destroy(true, true);
        root._efcSwiper = null;
      }
      root.dataset.efcInit = '';
    }

    function initMainSwiper(root) {
      var swiperEl = root.querySelector('[data-efc-swiper]');
      if (!swiperEl) return;

      var slides = swiperEl.querySelectorAll('.swiper-slide');
      if (!slides.length) return;

      if (!isSliderViewport()) {
        destroyMainSwiper(root);
        return;
      }

      var prevEl = root.querySelector('.evamats-featured-collection__nav--prev');
      var nextEl = root.querySelector('.evamats-featured-collection__nav--next');

      whenSwiperReady(function () {
        if (!isSliderViewport()) return;
        if (root.dataset.efcInit === '1') return;
        destroyMainSwiper(root);
        root.dataset.efcInit = '1';

        var opts = {
          slidesPerView: 3,
          spaceBetween: 15,
          speed: 480,
          watchOverflow: true,
          breakpoints: {
            990: {
              slidesPerView: 4,
            },
          },
        };

        if (slides.length > 3 && prevEl && nextEl) {
          opts.navigation = { prevEl: prevEl, nextEl: nextEl };
        }

        root._efcSwiper = new window.Swiper(swiperEl, opts);
      });
    }

    function initSection(root) {
      if (!root) return;
      initMainSwiper(root);
    }

    function boot() {
      document.querySelectorAll('[data-efc-root]').forEach(initSection);
    }

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        document.querySelectorAll('[data-efc-root]').forEach(function (root) {
          destroyMainSwiper(root);
          initMainSwiper(root);
        });
      }, 150);
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }

    document.addEventListener('shopify:section:load', function (event) {
      var root = event.target.querySelector('[data-efc-root]');
      if (root) initSection(root);
    });
  })();
</script>

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "section-evamats-featured-collection",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Bestsellers"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all button label",
      "default": "View all"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 25,
      "step": 1,
      "default": 8,
      "label": "Maximum products to show"
    },
    {
      "type": "text",
      "id": "mobile_button_label",
      "label": "Mobile card button label",
      "default": "Select"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show “View all” button"
    },
    {
      "type": "header",
      "content": "Section spacing (desktop)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Section spacing (mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Featured collection",
      "settings": {
        "title": "Bestsellers",
        "view_all_label": "View all"
      }
    }
  ]
}
{% endschema %}
