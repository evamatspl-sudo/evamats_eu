{{ 'section-evamats-featured-collection.css' | asset_url | stylesheet_tag }}
{{ 'section-evamats-related-products.css' | asset_url | stylesheet_tag }}
{% render 'evamats-section-padding-style', section: section, target: '.evamats-related-products' %}

{%- liquid  assign is_cart_template = false
  if template.name == 'cart'
    assign is_cart_template = true
  endif

  if is_cart_template and cart == empty
    assign erp_skip_render = true
  endif

  assign use_collection = false
  if section.settings.custom_collection != blank
    assign use_collection = true
    assign source_products = section.settings.custom_collection.products
  elsif is_cart_template and settings.order_related_collection != blank
    assign use_collection = true
    assign source_products = settings.order_related_collection.products
  endif

  assign erp_products = blank
  assign erp_slide_count = 0
  assign erp_has_products = false

  if use_collection
    assign erp_products = source_products
  elsif recommendations.performed and recommendations.products_count > 0
    assign erp_products = recommendations.products
  endif

  if erp_products != blank
    for item in erp_products limit: 50
      if item.available != true
        continue
      endif
      if item.type == 'mws_apo_generated'
        continue
      endif
      assign erp_slide_count = erp_slide_count | plus: 1
    endfor
    if erp_slide_count > 0
      assign erp_has_products = true
    endif
  endif

  assign erp_show_nav = false
  if erp_slide_count > 3
    assign erp_show_nav = true
  endif

  unless erp_has_products
    assign erp_skip_render = true
  endunless
-%}

{%- if is_cart_template -%}
  {%- style -%}
    #shopify-section-{{ section.id }} {
      background: #f6f6f6;
    }
  {%- endstyle -%}
{%- endif -%}

{%- unless erp_skip_render -%}
{%- capture related_products_inner -%}
  <div
    id="EvamatsRelatedProducts-{{ section.id }}"
    class="evamats-related-products{% if is_cart_template %} evamats-related-products--cart{% endif %}"
    data-erp-root
  >
    {%- if section.settings.heading != blank or erp_has_products -%}
      <div class="evamats-related-products__inner page-width">
        <div class="evamats-related-products__header">
          {%- if section.settings.heading != blank -%}
            <h2 class="evamats-related-products__heading section_title">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}
          {%- if erp_show_nav -%}
            <div class="evamats-related-products__header-nav" data-erp-header-nav>
              {% render 'evamats-related-products-nav' %}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if use_collection -%}
      {% render 'evamats-related-products-slider',
        section: section,
        products: source_products,
        shuffle: true
      %}
    {%- elsif recommendations.performed and recommendations.products_count > 0 -%}
      {% render 'evamats-related-products-slider',
        section: section,
        products: recommendations.products,
        shuffle: false
      %}
    {%- endif -%}
  </div>
{%- endcapture -%}

{%- if use_collection -%}
  <div class="related-products-custom no-js-hidden">
    {{ related_products_inner }}
  </div>
{%- else -%}
  <div class="related-products-custom no-js-hidden">
    <product-recommendations
      class="isolate"
      data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}"
    >
      {{ related_products_inner }}
    </product-recommendations>
  </div>
{%- endif -%}
{%- endunless -%}

<script>
  (function () {
    function whenSwiperReady(cb) {
      if (typeof window.Swiper !== 'undefined') {
        cb();
        return;
      }
      if (typeof window.ensureSwiperLoaded === 'function') {
        window.ensureSwiperLoaded(cb);
        return;
      }
      var tries = 0;
      var timer = setInterval(function () {
        tries += 1;
        if (typeof window.Swiper !== 'undefined') {
          clearInterval(timer);
          cb();
        } else if (tries > 80) {
          clearInterval(timer);
        }
      }, 50);
    }

    function getSlidesPerView() {
      if (window.matchMedia('(min-width: 990px)').matches) return 4;
      if (window.matchMedia('(min-width: 750px)').matches) return 3;
      return 2;
    }

    function updateHeaderNav(root, slideCount) {
      var nav = root.querySelector('[data-erp-header-nav]');
      if (!nav) return;
      if (slideCount > getSlidesPerView()) {
        nav.classList.remove('is-hidden');
      } else {
        nav.classList.add('is-hidden');
      }
    }

    function destroyMainSwiper(root) {
      if (root._erpSwiper && typeof root._erpSwiper.destroy === 'function') {
        root._erpSwiper.destroy(true, true);
        root._erpSwiper = null;
      }
      root.dataset.erpInit = '';
    }

    function prepareSlides(root) {
      if (root.dataset.erpPrepared === '1') {
        return root.querySelectorAll('[data-erp-slide]').length;
      }

      var swiperEl = root.querySelector('[data-erp-swiper]');
      if (!swiperEl) return 0;

      var wrapper = swiperEl.querySelector('.swiper-wrapper');
      if (!wrapper) return 0;

      var slides = Array.prototype.slice.call(wrapper.querySelectorAll('[data-erp-slide]'));
      if (!slides.length) return 0;

      var limit = parseInt(swiperEl.dataset.erpLimit, 10);
      if (!limit || limit < 1) limit = slides.length;

      if (swiperEl.dataset.erpShuffle === '1') {
        slides.sort(function () {
          return 0.5 - Math.random();
        });
      }

      slides = slides.slice(0, limit);
      wrapper.innerHTML = '';
      slides.forEach(function (slide) {
        wrapper.appendChild(slide);
      });

      root.dataset.erpPrepared = '1';
      return slides.length;
    }

    function initMainSwiper(root) {
      var swiperEl = root.querySelector('[data-erp-swiper]');
      if (!swiperEl) return;

      var slideCount = prepareSlides(root);
      if (!slideCount) return;

      updateHeaderNav(root, slideCount);

      var prevEl = root.querySelector('.evamats-related-products__nav--prev');
      var nextEl = root.querySelector('.evamats-related-products__nav--next');

      whenSwiperReady(function () {
        if (root.dataset.erpInit === '1') return;
        destroyMainSwiper(root);
        root.dataset.erpInit = '1';

        var perView = getSlidesPerView();
        updateHeaderNav(root, slideCount);

        var opts = {
          slidesPerView: 2,
          spaceBetween: 12,
          speed: 480,
          watchOverflow: true,
          breakpoints: {
            750: {
              slidesPerView: 3,
              spaceBetween: 15,
            },
            990: {
              slidesPerView: 4,
              spaceBetween: 15,
            },
          },
        };

        if (slideCount > perView && prevEl && nextEl) {
          opts.navigation = { prevEl: prevEl, nextEl: nextEl };
        }

        root._erpSwiper = new window.Swiper(swiperEl, opts);
      });
    }

    function initSection(root) {
      if (!root) return;
      initMainSwiper(root);
    }

    function boot() {
      document.querySelectorAll('[data-erp-root]').forEach(initSection);
    }

    function initProductRecommendations(el) {
      if (!el || el.dataset.erpLoaded === '1' || !el.dataset.url) return;

      var observer = new IntersectionObserver(function (entries, obs) {
        if (!entries[0].isIntersecting) return;
        obs.disconnect();

        fetch(el.dataset.url)
          .then(function (response) {
            return response.text();
          })
          .then(function (text) {
            var html = document.createElement('div');
            html.innerHTML = text;
            var recommendations = html.querySelector('product-recommendations');
            if (recommendations && recommendations.innerHTML.trim().length) {
              el.innerHTML = recommendations.innerHTML;
              el.dataset.erpLoaded = '1';
              var root = el.querySelector('[data-erp-root]');
              if (root) initSection(root);
            } else {
              el.remove();
            }
          })
          .catch(function () {
            el.remove();
          });
      }, { rootMargin: '0px 0px 400px 0px' });

      observer.observe(el);
    }

    function bootRecommendations() {
      document.querySelectorAll('.related-products-custom product-recommendations:not([data-erp-loaded])').forEach(initProductRecommendations);
    }

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        document.querySelectorAll('[data-erp-root]').forEach(function (root) {
          destroyMainSwiper(root);
          root.dataset.erpInit = '';
          initMainSwiper(root);
        });
      }, 150);
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        boot();
        bootRecommendations();
      });
    } else {
      boot();
      bootRecommendations();
    }

    document.addEventListener('shopify:section:load', function (event) {
      var root = event.target.querySelector('[data-erp-root]');
      if (root) initSection(root);
      event.target.querySelectorAll('product-recommendations:not([data-erp-loaded])').forEach(initProductRecommendations);
    });
  })();
</script>

{% schema %}
{
  "name": "Related product custom",
  "tag": "section",
  "class": "section-evamats-related-products",
  "settings": [
    {
      "type": "collection",
      "id": "custom_collection",
      "label": "Custom collection"
    },
    {
      "type": "paragraph",
      "content": "If no collection is selected, Shopify product recommendations are used."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 12,
      "label": "Maximum products to show"
    },
    {
      "type": "text",
      "id": "card_button_label",
      "label": "Card button label",
      "default": "View product"
    },
    {
      "type": "text",
      "id": "mobile_button_label",
      "label": "Mobile card button label (legacy)",
      "default": "Select"
    },
    {
      "type": "header",
      "content": "Section spacing (desktop)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Section spacing (mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Related products custom"
    }
  ],
  "enabled_on": {
    "templates": ["cart", "product"]
  }
}
{% endschema %}
