{{ 'section-evamats-popular-models.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-evamats-popular-models.js' | asset_url }}" defer></script>

{%- comment -%}
  Legacy brand buttons (pills / brand_collection metaobject). Kept for reference.
{%- endcomment -%}
{%- comment -%}
{% comment %} {{ 'brand-buttons.css' | asset_url | stylesheet_tag }} {% endcomment %}

<div class="brand-bnts-desktop collection-colorTable {% if section.settings['collection-margin-bottom'] %} margin-bottom {% endif %}">
  ...
</div>

<script>...</script>
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading | strip
  if heading == blank
    assign heading = 'sections.brand_buttons.popular_models_heading' | t
  endif

  assign title_prefix = 'sections.brand_buttons.collection_title_prefix' | t
  assign card_image_placeholder = 'bmw_x5m_e70.webp' | asset_url

  assign featured_collections = collection.metafields.custom.featured_model_collections.value

  if featured_collections == blank or featured_collections.size == 0
    assign featured_collections = settings.collection_featured_models
  endif

  assign visible_collections_count = 0
  if featured_collections != blank
    for featured_item in featured_collections
      if featured_item != blank and featured_item.handle != collection.handle
        assign visible_collections_count = visible_collections_count | plus: 1
      endif
    endfor
  endif
-%}

{%- if collection != blank and visible_collections_count > 0 -%}
  <section
    id="EvamatsPopularModels-{{ section.id }}"
    class="evamats-popular-models page-width{% if section.settings.margin_bottom %} evamats-popular-models--margin-bottom{% endif %}"
  >
    <h2 class="evamats-popular-models__heading">{{ heading | escape }}</h2>

    <div class="evamats-popular-models__stage" data-evamats-popular-models>
      <button
        type="button"
        class="evamats-popular-models__nav evamats-popular-models__nav--prev"
        aria-label="{{ 'general.slider.previous_slide' | t }}"
      >
        <span class="evamats-popular-models__nav-icon" aria-hidden="true">
          {% render 'evamats-pagination-arrow', direction: 'prev' %}
        </span>
      </button>

      <div class="evamats-popular-models__scroller">
        <div class="evamats-popular-models__track" role="list">
        {%- assign divider_pending = false -%}
        {%- for featured_item in featured_collections -%}
          {%- if featured_item == blank or featured_item.handle == collection.handle -%}
            {%- continue -%}
          {%- endif -%}

          {%- if divider_pending -%}
            <div class="evamats-popular-models__divider" aria-hidden="true"></div>
          {%- endif -%}

          {%- liquid
            assign card_title = featured_item.title | remove: title_prefix | strip
            if card_title == blank
              assign card_title = featured_item.title
            endif

            assign card_image = featured_item.image 
          -%}

          <div class="evamats-popular-models__group" role="listitem">
            <a class="evamats-popular-models__card" href="{{ featured_item.url }}">
              <div class="evamats-popular-models__media">
                {%- if card_image != blank -%}
                  {{
                    card_image
                    | image_url: width: 446
                    | image_tag:
                      loading: 'lazy',
                      class: 'evamats-popular-models__image',
                      widths: '195, 210, 223, 446',
                      sizes: '223px',
                      alt: card_title
                  }}
                {%- else -%}
                  <img
                    class="evamats-popular-models__image"
                    src="{{ card_image_placeholder }}"
                    alt="{{ card_title | escape }}"
                    width="223"
                    height="105"
                    loading="lazy"
                  >
                {%- endif -%}
              </div>
              <p class="evamats-popular-models__title">{{ card_title | escape }}</p>
              <p class="evamats-popular-models__count">
                {{ 'sections.brand_buttons.products_count' | t: count: featured_item.products_count }}
              </p>
            </a>
          </div>

          {%- assign divider_pending = true -%}
        {%- endfor -%}
        </div>
        <div class="evamats-popular-models__fade evamats-popular-models__fade--left" aria-hidden="true" hidden>
          <span class="evamats-popular-models__fade-edge"></span>
        </div>
        <div class="evamats-popular-models__fade evamats-popular-models__fade--right" aria-hidden="true">
          <span class="evamats-popular-models__fade-edge"></span>
        </div>
      </div>

      <button
        type="button"
        class="evamats-popular-models__nav evamats-popular-models__nav--next"
        aria-label="{{ 'general.slider.next_slide' | t }}"
      >
        <span class="evamats-popular-models__nav-icon" aria-hidden="true">
          {% render 'evamats-pagination-arrow', direction: 'next' %}
        </span>
      </button>

      <div class="evamats-popular-models__footer">
        <div class="evamats-popular-models__scrollbar" aria-hidden="true">
          <span class="evamats-popular-models__scrollbar-thumb"></span>
        </div>
        <div class="evamats-popular-models__footer-nav">
          <button
            type="button"
            class="evamats-popular-models__nav evamats-popular-models__nav--footer evamats-popular-models__nav--footer-prev"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <span class="evamats-popular-models__nav-icon" aria-hidden="true">
              {% render 'evamats-pagination-arrow', direction: 'prev' %}
            </span>
          </button>
          <button
            type="button"
            class="evamats-popular-models__nav evamats-popular-models__nav--footer evamats-popular-models__nav--footer-next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <span class="evamats-popular-models__nav-icon" aria-hidden="true">
              {% render 'evamats-pagination-arrow', direction: 'next' %}
            </span>
          </button>
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.brand-buttons.name",
  "tag": "section",
  "class": "section-evamats-popular-models",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Popular models",
      "info": "Leave empty to use theme translation."
    },
    {
      "type": "checkbox",
      "id": "margin_bottom",
      "label": "Bottom spacing",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "section",
      "name": "Legacy block",
      "settings": [
        {
          "type": "url",
          "id": "product-link",
          "label": "Collection link"
        },
        {
          "type": "text",
          "id": "color-code",
          "label": "Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.brand-buttons.presets.name"
    }
  ]
}
{% endschema %}
