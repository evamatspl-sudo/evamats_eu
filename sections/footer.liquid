{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }
  }

  .evamats-footer__brand-col { flex: 0 0 250px; max-width: 250px; }
  .evamats-footer__brand-logo { max-width: 150px; height: auto; margin-bottom: 16px; }
  .evamats-footer__contact-body { gap: 14px; }
  .evamats-footer__contact-line { margin: 0; line-height: 1.45; }
  .evamats-footer__contact-note { font-size: 0.85em; color: #9a9a9a; line-height: 1.35; }
  .evamats-footer__brand-desc { margin: 0; max-width: 240px; font-size: 1.3rem; line-height: 1.55; color: #6b6b6b; }
  .evamats-footer__menu-heading { text-transform: none; }
  @media screen and (max-width: 989px) {
    .evamats-footer__main { flex-wrap: wrap; }
    .evamats-footer__brand-col { flex-basis: 100%; max-width: 100%; }
  }
{%- endstyle -%}

{% render 'evamats-section-padding-style', section: section, target: '.evamats-footer' %}

<footer class="footer evamats-footer color-{{ section.settings.color_scheme }} gradient">
  {%- liquid
    assign show_footer_social = false
    for block in section.blocks
      if block.type == 'brand_information' and block.settings.show_social
        assign show_footer_social = true
      endif
    endfor
    unless show_footer_social
      if section.settings.show_social
        assign show_footer_social = true
      endif
    endunless

    assign has_partner_blocks = false
    for block in section.blocks
      if block.type == 'partner' and block.settings.image != blank
        assign has_partner_blocks = true
        break
      endif
    endfor
    assign show_partners = false
    if section.settings.partners_heading != blank and has_partner_blocks
      assign show_partners = true
    endif

    assign has_delivery_images = false
    if section.settings.delivery_image_1 != blank or section.settings.delivery_image_2 != blank or section.settings.delivery_image_3 != blank or section.settings.delivery_image_4 != blank
      assign has_delivery_images = true
    endif
  -%} 

  {%- comment -%} ── 1. Top: menus + contacts ── {%- endcomment -%}
  <div class="evamats-footer__content-top page-width">
    <div class="evamats-footer__main">
      {%- if settings.logo_inverse != blank or section.settings.brand_description != blank -%}
        <div class="evamats-footer__brand-col">
          <a href="{{ routes.root_url }}" class="evamats-footer__brand-logo-link">
            <img src="{{ 'logo_CARVION_colored.svg' | file_url }}" class="evamats-footer__brand-logo" alt="{{ shop.name | escape }}" width="150" loading="lazy">
          </a>
          {%- if section.settings.brand_description != blank -%}
            <p class="evamats-footer__brand-desc">{{ section.settings.brand_description }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
      <div class="evamats-footer__menus">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              <div class="evamats-footer__app" {{ block.shopify_attributes }}>
                {% render block %}
              </div>
            {%- when 'link_list' -%}
              <div class="evamats-footer__menu" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <p class="evamats-footer__menu-heading">{{ block.settings.heading | escape }}</p>
                {%- endif -%}
                {%- if block.settings.menu != blank -%}
                  <ul class="evamats-footer__menu-list list-unstyled">
                    {%- for link in block.settings.menu.links -%}
                      <li>
                        <a
                          href="{{ link.url }}"
                          class="evamats-footer__menu-link{% if link.active %} evamats-footer__menu-link--active{% endif %}"
                        >
                          {{ link.title }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>
            {%- when 'image' -%}
              <div class="evamats-footer__image-block footer-block-image {{ block.settings.alignment }}" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
                  <div class="footer-block__image-wrapper global-media-settings" style="max-width: min(100%, {{ block.settings.image_width }}px);">
                    <img
                      srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                      src="{{ block.settings.image | image_url: width: 760 }}"
                      alt="{{ block.settings.image.alt | escape }}"
                      loading="lazy"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                    >
                  </div>
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                {%- endif -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>

      <div class="evamats-footer__aside">
        {%- for block in section.blocks -%}
          {%- if block.type == 'contact' -%}
            {% render 'evamats-footer-contact-block', block: block %}
          {%- elsif block.type == 'text' -%}
            <div class="evamats-footer__contact" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <p class="evamats-footer__menu-heading">{{ block.settings.heading | escape }}</p>
              {%- endif -%}
              {%- if block.settings.subtext != blank -%}
                <div class="evamats-footer__contact-body rte">
                  {{ block.settings.subtext }}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if show_footer_social -%}
          <div class="evamats-footer__social-wrap">
            {% render 'evamats-footer-socials', section: section %}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} ── 2. Newsletter ── {%- endcomment -%}
  {%- if section.settings.newsletter_enable -%}
    <div class="evamats-footer__newsletter-wrap page-width">
      <div class="evamats-footer__newsletter">
        <div class="evamats-footer__newsletter-text">
          {%- if section.settings.newsletter_heading != blank -%}
            <div class="evamats-footer__newsletter-heading">{{ section.settings.newsletter_heading }}</div>
          {%- endif -%}
          {%- if section.settings.newsletter_subtext != blank -%}
            <div class="evamats-footer__newsletter-subtext">{{ section.settings.newsletter_subtext | escape }}</div>
          {%- endif -%}
        </div>
        {%- form 'customer', id: 'ContactFooter', class: 'evamats-footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="evamats-footer__newsletter-field-wrap">
            <input
              id="NewsletterForm--{{ section.id }}"
              type="email"
              name="contact[email]"
              class="evamats-footer__newsletter-input field__input"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                autofocus
                aria-invalid="true"
                aria-describedby="ContactFooter-error"
              {% elsif form.posted_successfully? %}
                aria-describedby="ContactFooter-success"
              {% endif %}
              placeholder="{{ section.settings.newsletter_placeholder | default: 'Váš e-mail' }}"
              required
            >
            <button type="submit" class="button button_3 evamats-footer__newsletter-btn" name="commit">
              {{ section.settings.newsletter_button | default: 'Přihlásit se' }}
            </button>
          </div>
          {%- if form.errors -%}
            <small class="evamats-footer__newsletter-msg evamats-footer__newsletter-msg--error" id="ContactFooter-error">
              {% render 'icon-error' %}{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
            </small>
          {%- endif -%}
          {%- if form.posted_successfully? -%}
            <p class="evamats-footer__newsletter-msg evamats-footer__newsletter-msg--success" id="ContactFooter-success" tabindex="-1" autofocus>
              {% render 'icon-success' %}{{ 'newsletter.success' | t }}
            </p>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── 3. Payments + Delivery ── {%- endcomment -%}
  {%- if section.settings.payment_enable or has_delivery_images -%}
    <div class="evamats-footer__payments-wrap page-width">
      <hr class="evamats-footer__divider" aria-hidden="true">
      <div class="evamats-footer__payments-row">
        {%- if section.settings.payment_enable -%}
          <div class="evamats-footer__payments-group">
            {%- if section.settings.payments_label != blank -%}
              <p class="evamats-footer__payments-label">{{ section.settings.payments_label | escape }}</p>
            {%- endif -%}
            <ul class="evamats-footer__payment-list list-unstyled" role="list">
              {%- assign payment_gateways = 'visa,mc,ae,discover,jcb,dc,apay,gpay,go_pay' | split: ',' -%}
              {%- for type in payment_gateways -%}
                <li class="evamats-footer__payment-item">
                  {%- assign typeSvg = type | append: '.svg' -%}
                  <img src="{{ typeSvg | file_url }}" alt="{{ type }}" loading="lazy">
                </li>
              {%- endfor -%}
                {%- comment -%} GoPay (CZ) — заменяет p24/blik {%- endcomment -%}
                <li class="evamats-footer__payment-item evamats-footer__payment-item--gopay">
                  <img src="{{ 'image_6.png' | file_url }}" alt="GoPay" loading="lazy">
                </li>
            </ul>
          </div>
        {%- endif -%}

        {%- if has_delivery_images -%}
          <div class="evamats-footer__delivery-group">
            {%- if section.settings.delivery_label != blank -%}
              <p class="evamats-footer__payments-label">{{ section.settings.delivery_label | escape }}</p>
            {%- endif -%}
            <div class="evamats-footer__delivery-list">
              {%- assign delivery_slots = '1,2,3,4' | split: ',' -%}
              {%- for slot in delivery_slots -%}
                {%- assign img_key = 'delivery_image_' | append: slot -%}
                {%- assign link_key = 'delivery_link_' | append: slot -%}
                {%- assign delivery_img = section.settings[img_key] -%}
                {%- assign delivery_link = section.settings[link_key] -%}
                {%- if delivery_img != blank -%}
                  <div class="evamats-footer__delivery-item">
                    {%- if delivery_link != blank -%}
                      <a href="{{ delivery_link }}" target="_blank" rel="noopener noreferrer">
                    {%- endif -%}
                    {{
                      delivery_img
                      | image_url: width: 120
                      | image_tag:
                        loading: 'lazy',
                        class: 'evamats-footer__delivery-img',
                        widths: '60, 90, 120',
                        sizes: '60px',
                        alt: delivery_img.alt
                    }}
                    {%- if delivery_link != blank -%}
                      </a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── 4. Bottom bar: logo + copyright + NIP/REGON | partners ── {%- endcomment -%}
  <div class="evamats-footer__bar-wrap page-width">
    {%- if show_partners -%}<hr class="evamats-footer__divider" aria-hidden="true">{%- endif -%}
    <div class="evamats-footer__bar">
      <div class="evamats-footer__bar-start">
        <div class="evamats-footer__copyright-wrap">
          {%- if section.settings.nip_number != blank or section.settings.regon_number != blank -%}
            <p class="evamats-footer__legal">
              {%- if section.settings.nip_number != blank -%}
                <span>NIP: {{ section.settings.nip_number | escape }}</span>
              {%- endif -%}
              {%- if section.settings.nip_number != blank and section.settings.regon_number != blank -%}
                <span class="evamats-footer__legal-sep">&nbsp;&middot;&nbsp;</span>
              {%- endif -%}
              {%- if section.settings.regon_number != blank -%}
                <span>REGON: {{ section.settings.regon_number | escape }}</span>
              {%- endif -%}
            </p>
          {%- endif -%}
        </div>
      </div>

      {%- if show_partners -%}
        <div class="evamats-footer__partners">
          <p class="evamats-footer__partners-label">{{ section.settings.partners_heading | escape }}</p>
          <div class="evamats-footer__partners-logos">
            {%- for block in section.blocks -%}
              {%- if block.type == 'partner' and block.settings.image != blank -%}
                <div class="evamats-footer__partner" {{ block.shopify_attributes }}>
                  {%- if block.settings.link != blank -%}
                    <a href="{{ block.settings.link }}" class="evamats-footer__partner-link" target="_blank" rel="noopener noreferrer">
                  {%- endif -%}
                  {{
                    block.settings.image
                    | image_url: width: 160
                    | image_tag:
                      loading: 'lazy',
                      class: 'evamats-footer__partner-img',
                      widths: '70, 90, 140, 160',
                      sizes: '80px',
                      alt: block.settings.image.alt
                  }}
                  {%- if block.settings.link != blank -%}
                    </a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>

</footer>


{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Quick links",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label",
          "info": "t:sections.footer.blocks.link_list.settings.menu.info"
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "t:sections.footer.blocks.brand_information.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.footer.blocks.brand_information.settings.paragraph.content"
        },
        {
          "type": "header",
          "content": "t:sections.footer.blocks.brand_information.settings.header__1.content"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "t:sections.footer.blocks.brand_information.settings.show_social.label",
          "info": "t:sections.footer.blocks.brand_information.settings.show_social.info"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Kontaktujte nás"
        },
        {
          "type": "richtext",
          "id": "intro",
          "label": "Company / intro (optional)"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Nadpis",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
