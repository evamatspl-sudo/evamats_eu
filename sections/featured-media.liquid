{{ 'featured-media.css' | asset_url | stylesheet_tag }}

{% liquid
    assign background = section.settigs.background
    assign text_color = section.settings.text_color
    assign highlight_text_color = section.settings.highlight_text_color

    assign padding_top = section.settings.padding_top | append: 'px'
    assign padding_top_mobile = section.settings.padding_top_mobile | append: 'px'
    assign padding_bottom = section.settings.padding_bottom | append: 'px'
    assign padding_bottom_mobile = section.settings.padding_bottom_mobile | append: 'px'

    assign heading = section.settings.heading
    assign video = section.settings.video_url
    assign mp4_video = section.settings.mp4_video

    if article != blank

    if article.metafields.custom.featured_media_heading != blank
        assign heading = article.metafields.custom.featured_media_heading
    endif

    if article.metafields.custom.featured_media_video_url != blank
        assign video = article.metafields.custom.featured_media_video_url
    endif

    if article.metafields.custom.featured_media_mp4 != blank
        assign mp4_video = article.metafields.custom.featured_media_mp4
    endif

    endif
%}

<section class="featured-media" style="
        --background: {{ background }};
        --text_color: {{ text_color }};
        --highlight_text_color: {{ highlight_text_color }};
        --padding_top: {{ padding_top }};
        --padding_top_mobile: {{ padding_top_mobile }};
        --padding_bottom: {{ padding_bottom }};
        --padding_bottom_mobile: {{ padding_bottom_mobile }};
        ">

    <div class="page-width">

        {% if heading != blank %}
            <div class="featured-media__heading rte">
                {% if heading.value %}
                    {{ heading | metafield_tag }}
                {% else %}
                    {{ heading }}
                {% endif %}
            </div>
        {% endif %}

        <div class="featured-media__wrapper">

            {% if video != blank %}

                {% liquid
                    assign video_url = video

                    if video.value != blank
                    assign video_url = video.value
                    endif

                    assign video_url = video_url | escape
                %}

                <div class="featured-media__media">

                    {% if video_url contains 'youtu' %}
                        {% assign video_id = video_url
                            | replace: 'https://www.youtube.com/watch?v=', ''
                            | replace: 'https://youtu.be/', ''
                            | split: '&' | first
                        %}

                        <iframe
                                src="https://www.youtube.com/embed/{{ video_id }}"
                                allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen>
                        </iframe>

                        {% elsif video_url contains 'vimeo' %}
                        {% assign video_id = video_url | split: '/' | last %}

                        <iframe
                                src="https://player.vimeo.com/video/{{ video_id }}"
                                allow="autoplay; fullscreen; picture-in-picture"
                                allowfullscreen>
                        </iframe>
                    {% endif %}

                </div>

                {% elsif mp4_video != blank %}

                <div class="featured-media__media">
                    {{
                    mp4_video
                    | video_tag:
                    controls: true,
                    autoplay: false,
                    loop: false,
                    muted: false
                    }}
                </div>

            {% endif %}

        </div>
    </div>
</section>

{% schema %}
{
  "name": "Featured Media",
  "tag": "section",
  "class": "section featured-media-section",
  "settings": [
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1B1D22"
    },
    {
      "type": "color",
      "id": "highlight_text_color",
      "label": "Highlight text color",
      "default": "#FF2741"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "video",
      "id": "mp4_video",
      "label": "MP4 Video"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Featured Media"
    }
  ]
}
{% endschema %}

