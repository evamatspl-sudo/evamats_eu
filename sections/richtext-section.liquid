
{% style %}
    .richtext--{{ section.id }}{
        padding-top: {{ section.settings.padding_top_mobile }}px;
        padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    @media screen and (min-width: 990px) {
        .richtext--{{ section.id }} {
            padding-top: {{ section.settings.padding_top }}px;
            padding-bottom: {{ section.settings.padding_bottom }}px;
        }
    }
{% endstyle %}

<div class="richtext richtext--{{ section.id }}">
    <div class="page-width">
        {% if section.settings.header != blank %}
            <div class="richtext__header">
                {{ section.settings.header }}
            </div>
        {% endif %}
        <div class="richtext__content">
            {% if section.settings.richtext != blank %}
                <div class="richtext__richtext">
                    {{ section.settings.richtext }}
                </div>
            {% endif %}
        </div>
    </div>
</div>

{% schema %}
{
  "name": "Richtext section",
  "settings": [
    {
      "type": "richtext",
      "id": "header",
      "label": "Header"
    },
    {
      "type": "richtext",
      "id": "richtext",
      "label": "Richtext"
    },
    {
      "type": "header",
      "content": "Padding mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    },
    {
      "type": "header",
      "content": "Padding desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Richtext section"
    }
  ]
}
{% endschema %}