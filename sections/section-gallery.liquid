{{ 'evamats-breadcrumbs.css' | asset_url | stylesheet_tag }}
{{ 'section-gallery.css' | asset_url | stylesheet_tag }}
{{ 'section-gallery-fancybox.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'fancybox.css' | asset_url }}">

{%- liquid
  assign gallery_title = section.settings.title | strip
  if gallery_title == blank and page != blank
    assign gallery_title = page.title
  endif

  assign breadcrumb_parent_label = section.settings.breadcrumb_parent_label | strip
  if breadcrumb_parent_label == blank
    assign breadcrumb_parent_label = 'Carvion'
  endif

  assign breadcrumb_parent_url = section.settings.breadcrumb_parent_url | strip
  if breadcrumb_parent_url == blank
    assign breadcrumb_parent_url = routes.root_url
  endif

  assign breadcrumb_current_label = section.settings.breadcrumb_current_label | strip
  if breadcrumb_current_label == blank
    assign breadcrumb_current_label = 'Katalog'
  endif

  assign gallery_without_edges_thumb = '5os-classic-diamonds-black-red.webp' | file_url
  assign gallery_with_edges_thumb = '5os-3d-diamonds-black-red.webp' | file_url
-%}

{% assign gallery_main = shop.metaobjects['gallery']['gallery-main'] %}
{% assign types = '2os_edges,2os_noedges,5os_edges,5os_noedges,7os_edges,7os_noedges,minivan,bus,pickup_edges,pickup_noedges,tir,van_big,van_small_edges,van_small_noedges,tractors,excavators' | split: ',' %}

<div class="gallery">
  <div class="gallery__hero">
    <div class="gallery__hero-inner page-width">
      {% render 'evamats-breadcrumbs',
        parent_label: breadcrumb_parent_label,
        parent_url: breadcrumb_parent_url,
        current_label: breadcrumb_current_label,
        class: 'gallery__breadcrumbs'
      %}

      {%- if gallery_title != blank -%}
        <h1 class="gallery__title">{{ gallery_title | escape }}</h1>
      {%- endif -%}

      <div class="gallery__filters">
        <div class="gallery__tabs_edges eva__tabs">
          <div class="eva__tabs_item gallery__tabs_item" data-type="withoutEdges" role="button" tabindex="0">
            <span class="gallery__tabs_item-thumb">
              <img src="{{ gallery_without_edges_thumb }}" alt="" loading="lazy" width="60" height="60">
            </span>
            <span>{{ 'general.config.without_edges' | t }}</span>
          </div>
          <div class="eva__tabs_item gallery__tabs_item" data-type="withEdges" role="button" tabindex="0">
            <span class="gallery__tabs_item-thumb">
              <img src="{{ gallery_with_edges_thumb }}" alt="" loading="lazy" width="60" height="60">
            </span>
            <span>{{ 'general.config.with_edges' | t }}</span>
          </div>
        </div>

        <div class="gallery__tabs_types eva__tabs custom-select">
          <div class="select-header_wr">
            <div class="select-header" data-text="{{ 'general.config.gallery_body_type' | t }}">{{ 'general.config.gallery_body_type' | t }}</div>
            {% render 'icon-caret' %}
          </div>
          <div class="select-options">
            {% assign elements = 'general.config.bodyTypeElements' | t | remove: ',Other' | split: ',' %}
            {% for item in elements %}
              <div class="eva__tabs_item gallery__tabs_item" data-type="{{ item }}">{{ item }}</div>
            {% endfor %}
          </div>
        </div>

        <div class="gallery__reset">{{ 'general.config.reset' | t }}</div>
      </div>
    </div>
  </div>

  <div class="gallery__body page-width">
    {% if gallery_main %}
      <div class="gallery__container">
        {% for type in types %}
          {% for image in gallery_main[type].value %}
            <div class="gallery__image_wr">
              <a
                href="{{ image | img_url: 'master' }}"
                data-fancybox="gallery"
                data-thumb="{{ image | img_url: '160x' }}"
              >
                <img src="{{ image | img_url: '600x' }}" alt="Gallery Image" data-type="{{ type }}" class="gallery__image" loading="lazy">
              </a>
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    {% else %}
      <p></p>
    {% endif %}

    <div class="gallery__message hidden">{{ 'general.config.gallery_error_message' | t }}</div>
    <div class="gallery__divider_text hidden">{{ 'general.config.gallery_divider_text' | t }}</div>
  </div>
</div>

{% render 'gallery-fancybox-panels' %}

<div class="gallery__fancybox-assets" hidden aria-hidden="true">
  <img data-gallery-fancybox-arrow-prev src="{{ 'gallery-fancybox-arrow-prev.svg' | asset_url }}" alt="" width="27" height="54">
  <img data-gallery-fancybox-arrow-next src="{{ 'gallery-fancybox-arrow-next.svg' | asset_url }}" alt="" width="27" height="54">
</div>

<script src="{{ 'fancybox.js' | asset_url }}" defer></script>
<script src="{{ 'gallery.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Gallery",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Galeria Carvion"
    },
    {
      "type": "text",
      "id": "breadcrumb_parent_label",
      "label": "Breadcrumb — parent",
      "default": "Carvion"
    },
    {
      "type": "url",
      "id": "breadcrumb_parent_url",
      "label": "Breadcrumb — parent link",
      "info": "Leave empty for homepage."
    },
    {
      "type": "text",
      "id": "breadcrumb_current_label",
      "label": "Breadcrumb — current",
      "default": "Katalog"
    },
    {
      "type": "header",
      "content": "Lightbox"
    },
    {
      "type": "text",
      "id": "lightbox_heading",
      "label": "Lightbox heading",
      "default": "Chcesz taki efekt w swoim aucie?"
    },
    {
      "type": "text",
      "id": "lightbox_cta_label",
      "label": "Lightbox CTA label",
      "default": "Požádat o pomoc"
    },
    {
      "type": "url",
      "id": "lightbox_cta_url",
      "label": "Lightbox CTA link"
    },
    {
      "type": "text",
      "id": "lightbox_phone",
      "label": "Lightbox phone",
      "default": "+48 732 082 512"
    },
    {
      "type": "text",
      "id": "lightbox_email",
      "label": "Lightbox email",
      "default": "sklep@evamats.pl"
    }
  ]
}
{% endschema %}
