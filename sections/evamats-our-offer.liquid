      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "featured_tall",
      "name": "Featured — tall",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "featured_stack",
      "name": "Featured — medium",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "compact",
      "name": "Compact row",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our offer",
      "blocks": [
        {
          "type": "featured_tall",
          "settings": {
            "title": "Car mats"
          }
        },
        {
          "type": "featured_stack",
          "settings": {
            "title": "EVA for home"
          }
        },
        {
          "type": "featured_stack",
          "settings": {
            "title": "For pets"
          }
        },
        {
          "type": "compact",
          "settings": {
            "title": "Organizers"
