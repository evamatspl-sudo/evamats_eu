{{ 'evamats-breadcrumbs.css' | asset_url | stylesheet_tag }}
{{ 'section-evamats-collection-banner.css' | asset_url | stylesheet_tag }}
{{ 'section-evamats-collection-mobile.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign desktop_image = section.settings.image_desktop
  assign mobile_image = section.settings.image_mobile

  if desktop_image == blank
    assign desktop_image = collection.image
  endif

  if mobile_image == blank
    assign mobile_image = desktop_image
  endif

  assign root_label = section.settings.parent_label | strip
  if root_label == blank
    assign root_label = 'Evamats'
  endif

  assign root_url = section.settings.parent_url | strip
  if root_url == blank
    assign root_url = routes.root_url
  endif

  assign catalog_label = section.settings.catalog_label | strip
  if catalog_label == blank
    assign catalog_label = 'Сatalog'
  endif

  assign brand_collection = nil
  assign brand_url_setting = section.settings.brand_url | strip

  if brand_url_setting != blank
    assign brand_handle = brand_url_setting | split: '/collections/' | last | split: '?' | first
    if brand_handle != blank
      assign brand_collection = collections[brand_handle]
    endif
  endif

  if brand_collection == blank
    assign candidate = ''
    assign handle_parts = collection.handle | split: '-'
    for part in handle_parts
      if candidate == blank
        assign candidate = part
      else
        assign candidate = candidate | append: '-' | append: part
      endif
      if candidate != collection.handle
        assign test_col = collections[candidate]
        if test_col != blank
          assign brand_collection = test_col
          break
        endif
      endif
    endfor
  endif

  assign middle_label = ''
  assign middle_url = ''
  assign breadcrumb_current = catalog_label

  if brand_collection != blank
    assign middle_label = brand_collection.title
    assign middle_url = brand_collection.url
    assign breadcrumb_current = collection.title
  endif
-%}

<section
  id="EvamatsCollectionBanner-{{ section.id }}"
  class="evamats-collection-banner shopify-section"
>
  <div class="evamats-collection-banner__media{% if desktop_image == blank %} evamats-collection-banner__media--fallback{% endif %}" aria-hidden="true">
    {%- if desktop_image != blank -%}
      <picture>
        {%- if mobile_image != blank -%}
          <source media="(max-width: 749px)" srcset="{{ mobile_image | image_url: width: 1200 }}">
        {%- endif -%}
        {{
          desktop_image
          | image_url: width: 3840
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            class: 'evamats-collection-banner__image',
            sizes: '100vw',
            widths: '750, 1100, 1500, 1920, 2560, 3840'
        }}
      </picture>
    {%- endif -%}
    <div class="evamats-collection-banner__overlay"></div>
  </div>

  <div class="evamats-collection-banner__ui page-width">
    {%- if section.settings.show_breadcrumbs -%}
      {% render 'evamats-breadcrumbs',
        parent_label: root_label,
        parent_url: root_url,
        middle_label: middle_label,
        middle_url: middle_url,
        current_label: breadcrumb_current,
        class: 'evamats-collection-banner__breadcrumbs'
      %}
    {%- endif -%}

    <h1 class="evamats-collection-banner__title">
      <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
      {{- collection.title | escape -}}
    </h1>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section-evamats-collection-banner",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Background image (desktop)",
      "info": "Uses collection image when empty."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background image (mobile)",
      "info": "Optional. Uses desktop or collection image when empty."
    },
    {
      "type": "header",
      "content": "Breadcrumbs"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "parent_label",
      "label": "Breadcrumb root label",
      "default": "Evamats"
    },
    {
      "type": "url",
      "id": "parent_url",
      "label": "Breadcrumb root link",
      "info": "Defaults to homepage."
    },
    {
      "type": "text",
      "id": "catalog_label",
      "label": "Catalog breadcrumb label",
      "default": "Katalog",
      "info": "Shown on brand and top-level collection pages."
    },
    {
      "type": "url",
      "id": "brand_url",
      "label": "Parent brand collection",
      "info": "Optional. Used for model pages when auto-detection is not enough."
    }
  ]
}
{% endschema %}
