{%- liquid
  assign item_count = 0
  for block in section.blocks
    if block.type == 'item'
      assign item_count = item_count | plus: 1
    endif
  endfor
-%}

{% render 'evamats-section-padding-style', section: section, target: '.evamats-product-benefits' %}
<div
  id="EvamatsProductBenefits-{{ section.id }}"
  class="evamats-product-benefits"
>
  <div class="evamats-product-benefits__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="evamats-product-benefits__heading section_title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="evamats-product-benefits__description rte">{{ section.settings.description }}</div>
    {%- endif -%}

    {%- if item_count > 0 -%}
      <ul class="evamats-product-benefits__grid" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'item' -%}
            <li class="evamats-product-benefits__item" {{ block.shopify_attributes }}>
              <div class="evamats-product-benefits__icon" aria-hidden="true">
                {%- if block.settings.icon != blank -%}
                  {{
                    block.settings.icon
                    | image_url: width: 192
                    | image_tag:
                      loading: 'lazy',
                      class: 'evamats-product-benefits__icon-img',
                      widths: '72, 96, 144, 192',
                      sizes: '(min-width: 750px) 96px, 72px'
                  }}
                {%- endif -%}
              </div>

              {%- if block.settings.title != blank or block.settings.text_muted != blank or block.settings.text_highlight != blank -%}
                <p class="evamats-product-benefits__label">
                  {%- if block.settings.title != blank -%}
                    <span class="evamats-product-benefits__label-main">{{ block.settings.title | escape }} </span>
                  {%- endif -%}
                  {%- if block.settings.text_muted != blank -%}
                    <span class="evamats-product-benefits__label-muted"> {{ block.settings.text_muted | escape }}</span>
                  {%- endif -%}
                  {%- if block.settings.text_highlight != blank -%}
                    <span class="evamats-product-benefits__label-highlight"> {{ block.settings.text_highlight | escape }}</span>
                  {%- endif -%}
                </p>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% comment %} styles moved to assets/base_v2.css (stylesheet) {% endcomment %}

{% schema %}
{
  "name": "Product benefits",
  "tag": "section",
  "class": "section-evamats-product-benefits",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Produkt, který zákazník opravdu chce koupit"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Koberce Carvion řeší skutečný problém řidičů — špínu, opotřebení a špatné padnutí.<br>Je to produkt, který zákazník hned pochopí a koupí bez dlouhého váhání.</p>"
    },
    {
      "type": "header",
      "content": "Section spacing (desktop)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Section spacing (mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon",
          "info": "Composite icon with glow, ~96×96 px (desktop)."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Label — main (white)",
          "default": "Benefit title"
        },
        {
          "type": "text",
          "id": "text_muted",
          "label": "Label — muted (optional)",
          "info": "e.g. “(nie uniwersalne)” — 50% white."
        },
        {
          "type": "text",
          "id": "text_highlight",
          "label": "Label — highlight (optional)",
          "info": "e.g. “(~2%)” — accent green #12ffa9."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product benefits",
      "category": "V2",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "title": "Dopasowanie do konkretnego auta",
            "text_muted": " (nie uniwersalne)"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Viditelný efekt už po prvním použití"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Prémiový segment = vyšší košík"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Niski poziom reklamacji ",
            "text_highlight": "(~2%)"
          }
        }
      ]
    }
  ]
}
{% endschema %}
