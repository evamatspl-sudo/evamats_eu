{{ 'eva-product-slider.css' | asset_url | stylesheet_tag }}
<script src="{{ 'eva-product-slider.js' | asset_url }}" defer></script>

{% liquid
    assign background = section.settings.background
    assign text_color = section.settings.text_color

    assign padding_top = section.settings.padding_top | append: 'px'
    assign padding_top_mobile = section.settings.padding_top_mobile | append: 'px'
    assign padding_bottom = section.settings.padding_bottom | append: 'px'
    assign padding_bottom_mobile = section.settings.padding_bottom_mobile | append: 'px'

    assign product_ref = blank

    if article != blank and article.metafields.custom.product_card.value != blank
    assign product_ref = article.metafields.custom.product_card.value

    elsif product != blank and product.metafields.custom.product_card.value != blank
    assign product_ref = product.metafields.custom.product_card.value

    elsif collection != blank and collection.metafields.custom.product_card.value != blank
    assign product_ref = collection.metafields.custom.product_card.value

    elsif page != blank and page.metafields.custom.product_card.value != blank
    assign product_ref = page.metafields.custom.product_card.value

    else
    assign product_ref = section.settings.product
    endif
%}

{% if product_ref != blank %}
    <section class="eva-product" style="
            --background: {{ background }};
            --text_color: {{ text_color }};
            --padding_top: {{ padding_top }};
            --padding_top_mobile: {{ padding_top_mobile }};
            --padding_bottom: {{ padding_bottom  }};
            --padding_bottom_mobile: {{ padding_bottom_mobile }};
    ">

        {% if section.settings.top_right_image != blank %}
            <div class="eva-product__bg eva-product__bg--top">
                {{
                section.settings.top_right_image
                | image_url: width: 700
                | image_tag:
                loading: 'lazy',
                class: 'eva-product__bg-image'
                }}
            </div>
        {% endif %}

        {% if section.settings.bottom_left_image != blank %}
            <div class="eva-product__bg eva-product__bg--bottom">
                {{
                section.settings.bottom_left_image
                | image_url: width: 700
                | image_tag:
                loading: 'lazy',
                class: 'eva-product__bg-image'
                }}
            </div>
        {% endif %}

        <div class="page-width">
            <div class="eva-product__wrapper">

                <div class="eva-product__gallery">

                    <div class="swiper eva-product-thumbs">
                        <div class="swiper-wrapper">
                            {% for image in product_ref.images %}
                                <div class="swiper-slide">
                                    {{
                                    image
                                    | image_url: width: 120
                                    | image_tag:
                                    loading: 'lazy',
                                    class: 'eva-product__thumb-image'
                                    }}
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="swiper eva-product-main">
                        <div class="swiper-wrapper">
                            {% for image in product_ref.images %}
                                <div class="swiper-slide">
                                    {{
                                    image
                                    | image_url: width: 900
                                    | image_tag:
                                    loading: 'lazy',
                                    class: 'eva-product__main-image'
                                    }}
                                </div>
                            {% endfor %}
                        </div>

                        <div class="eva-product__pagination"></div>

                        <div class="eva-product__arrow eva-product__arrow--prev">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="8" viewBox="0 0 15 8" fill="none">
                                <path d="M3.71741 0C3.84049 3.23988e-05 3.96077 0.0367718 4.06287 0.105521C4.16497 0.17427 4.24424 0.271905 4.29055 0.385944C4.33687 0.499983 4.34812 0.625243 4.32288 0.745712C4.29763 0.86618 4.23703 0.976383 4.14883 1.06223L2.11137 3.09968H14.2297C14.3117 3.09852 14.3931 3.11367 14.4692 3.14424C14.5453 3.17481 14.6145 3.22021 14.6729 3.27777C14.7313 3.33534 14.7777 3.40394 14.8093 3.47959C14.841 3.55523 14.8573 3.63641 14.8573 3.71841C14.8573 3.8004 14.841 3.88158 14.8093 3.95723C14.7777 4.03287 14.7313 4.10147 14.6729 4.15904C14.6145 4.21661 14.5453 4.262 14.4692 4.29257C14.3931 4.32315 14.3117 4.33829 14.2297 4.33714H2.11137L4.14883 6.37459C4.20821 6.4316 4.25562 6.49989 4.28828 6.57545C4.32094 6.65102 4.33819 6.73234 4.33903 6.81465C4.33987 6.89697 4.32427 6.97863 4.29316 7.05484C4.26204 7.13105 4.21603 7.20029 4.15782 7.2585C4.09961 7.31671 4.03037 7.36272 3.95416 7.39384C3.87795 7.42495 3.79629 7.44055 3.71397 7.43971C3.63166 7.43887 3.55034 7.42162 3.47477 7.38896C3.39921 7.3563 3.33092 7.30889 3.27391 7.24951L0.180268 4.15587C0.0642776 4.03983 -0.000881195 3.88248 -0.000881195 3.71841C-0.000881195 3.55434 0.0642776 3.39699 0.180268 3.28095L3.27391 0.18731C3.33156 0.128039 3.40052 0.0809265 3.47669 0.0487547C3.55287 0.0165829 3.63472 4.80367e-06 3.71741 0Z" fill="#151515"/>
                            </svg>
                        </div>

                        <div class="eva-product__arrow eva-product__arrow--next">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="8" viewBox="0 0 15 8" fill="none">
                                <path d="M11.1321 0C11.009 3.23988e-05 10.8887 0.0367718 10.7866 0.105521C10.6845 0.17427 10.6052 0.271905 10.5589 0.385944C10.5126 0.499983 10.5013 0.625243 10.5266 0.745712C10.5518 0.86618 10.6124 0.976383 10.7006 1.06223L12.7381 3.09968H0.619727C0.537739 3.09852 0.456337 3.11367 0.380253 3.14424C0.304169 3.17481 0.234921 3.22021 0.176531 3.27777C0.118142 3.33534 0.0717773 3.40394 0.0401308 3.47959C0.00848429 3.55523 -0.0078125 3.63641 -0.0078125 3.71841C-0.0078125 3.8004 0.00848429 3.88158 0.0401308 3.95723C0.0717773 4.03287 0.118142 4.10147 0.176531 4.15904C0.234921 4.21661 0.304169 4.262 0.380253 4.29257C0.456337 4.32315 0.537739 4.33829 0.619727 4.33714H12.7381L10.7006 6.37459C10.6413 6.4316 10.5938 6.49989 10.5612 6.57545C10.5285 6.65102 10.5113 6.73234 10.5104 6.81465C10.5096 6.89697 10.5252 6.97863 10.5563 7.05484C10.5874 7.13105 10.6334 7.20029 10.6916 7.2585C10.7499 7.31671 10.8191 7.36272 10.8953 7.39384C10.9715 7.42495 11.0532 7.44055 11.1355 7.43971C11.2178 7.43887 11.2991 7.42162 11.3747 7.38896C11.4503 7.3563 11.5185 7.30889 11.5756 7.24951L14.6692 4.15587C14.7852 4.03983 14.8503 3.88248 14.8503 3.71841C14.8503 3.55434 14.7852 3.39699 14.6692 3.28095L11.5756 0.18731C11.5179 0.128039 11.4489 0.0809265 11.3728 0.0487547C11.2966 0.0165829 11.2147 4.80367e-06 11.1321 0Z" fill="#151515"/>
                            </svg>
                        </div>
                    </div>

                </div>

                <div class="eva-product__content">

                    <h2 class="eva-product__title">
                        {{ product_ref.title }}
                    </h2>

                    <div class="eva-product__price-wrapper">

                        {% if product_ref.compare_at_price > product_ref.price %}
                            <span class="eva-product__compare-price">
                                {{ product_ref.compare_at_price | money }}
                            </span>
                        {% endif %}

                        <span class="eva-product__price">
                          {{ product_ref.price | money }}
                        </span>

                        {% if product_ref.compare_at_price > product_ref.price %}
                            {% assign discount =
                                product_ref.compare_at_price
                                | minus: product_ref.price
                                | times: 100
                                | divided_by: product_ref.compare_at_price
                            %}

                            <span class="eva-product__discount">-{{ discount }}%</span>
                        {% endif %}

                    </div>

                    <a href="{{ product_ref.url }}" class="eva-product__button">
                        {{ section.settings.button_text }}
                    </a>

                </div>

            </div>
        </div>
    </section>
{% endif %}

{% schema %}
{
  "name": "EVA Product Slider",
  "settings": [
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#1B1D22"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1B1D22"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Fallback product",
      "info": "Used when no metafield or dynamic source product is available"
    },
    {
      "type": "image_picker",
      "id": "top_right_image",
      "label": "Top right image"
    },
    {
      "type": "image_picker",
      "id": "bottom_left_image",
      "label": "Bottom left image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "ZOBACZ PRODUKT"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "EVA Product Slider"
    }
  ]
}
{% endschema %}