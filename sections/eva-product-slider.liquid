{{ 'eva-product-slider.css' | asset_url | stylesheet_tag }}
{{ 'section-evamats-product-gallery.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
<script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>

{% liquid
    assign background = section.settings.background
    assign text_color = section.settings.text_color

    assign padding_top = section.settings.padding_top | append: 'px'
    assign padding_top_mobile = section.settings.padding_top_mobile | append: 'px'
    assign padding_bottom = section.settings.padding_bottom | append: 'px'
    assign padding_bottom_mobile = section.settings.padding_bottom_mobile | append: 'px'

    assign product_ref = blank

    if article != blank and article.metafields.custom.product_card.value != blank
    assign product_ref = article.metafields.custom.product_card.value

    elsif product != blank and product.metafields.custom.product_card.value != blank
    assign product_ref = product.metafields.custom.product_card.value

    elsif collection != blank and collection.metafields.custom.product_card.value != blank
    assign product_ref = collection.metafields.custom.product_card.value

    elsif page != blank and page.metafields.custom.product_card.value != blank
    assign product_ref = page.metafields.custom.product_card.value

    else
    assign product_ref = section.settings.product
    endif
%}

{% if product_ref != blank %}
    <section class="eva-product" style="
            --background: {{ background }};
            --text_color: {{ text_color }};
            --padding_top: {{ padding_top }};
            --padding_top_mobile: {{ padding_top_mobile }};
            --padding_bottom: {{ padding_bottom  }};
            --padding_bottom_mobile: {{ padding_bottom_mobile }};
    ">

        {% if section.settings.top_right_image != blank %}
            <div class="eva-product__bg eva-product__bg--top">
                {{
                section.settings.top_right_image
                | image_url: width: 700
                | image_tag:
                loading: 'lazy',
                class: 'eva-product__bg-image'
                }}
            </div>
        {% endif %}

        {% if section.settings.bottom_left_image != blank %}
            <div class="eva-product__bg eva-product__bg--bottom">
                {{
                section.settings.bottom_left_image
                | image_url: width: 700
                | image_tag:
                loading: 'lazy',
                class: 'eva-product__bg-image'
                }}
            </div>
        {% endif %}

        <div class="page-width">
            <div class="eva-product__wrapper">

                <div class="eva-product__gallery{% if product_ref.metafields.custom.body_type != blank and product_ref.metafields.custom.body_type != 'corners' %} eva-product__gallery--mats{% endif %}">
                    {% if product_ref.metafields.custom.body_type != blank and product_ref.metafields.custom.body_type != 'corners' %}
                        {% render 'evamats-product-mats-gallery', product: product_ref, section: section, single_gallery: true %}
                    {% else %}
                        <script src="{{ 'eva-product-slider.js' | asset_url }}" defer></script>

                        <div class="swiper eva-product-thumbs">
                            <div class="swiper-wrapper">
                                {% for image in product_ref.images %}
                                    <div class="swiper-slide">
                                        {{
                                        image
                                        | image_url: width: 120
                                        | image_tag:
                                        loading: 'lazy',
                                        class: 'eva-product__thumb-image'
                                        }}
                                    </div>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="swiper eva-product-main">
                            <div class="swiper-wrapper">
                                {% for image in product_ref.images %}
                                    <div class="swiper-slide">
                                        {{
                                        image
                                        | image_url: width: 900
                                        | image_tag:
                                        loading: 'lazy',
                                        class: 'eva-product__main-image'
                                        }}
                                    </div>
                                {% endfor %}
                            </div>

                            <div class="eva-product__pagination"></div>

                            {% render 'eva-slider-nav-button',
                              direction: 'prev',
                              size: 'small',
                              class: 'eva-product__arrow eva-product__arrow--prev'
                            %}

                            {% render 'eva-slider-nav-button',
                              direction: 'next',
                              size: 'small',
                              class: 'eva-product__arrow eva-product__arrow--next'
                            %}
                        </div>
                    {% endif %}
                </div>

                <div class="eva-product__content">

                    <h2 class="eva-product__title">
                        {{ product_ref.title }}
                    </h2>

                    <div class="eva-product__price-wrapper">

                        {% if product_ref.compare_at_price > product_ref.price %}
                            <span class="eva-product__compare-price">
                                {{ product_ref.compare_at_price | money }}
                            </span>
                        {% endif %}

                        <span class="eva-product__price">
                          {{ product_ref.price | money }}
                        </span>

                        {% if product_ref.compare_at_price > product_ref.price %}
                            {% assign discount =
                                product_ref.compare_at_price
                                | minus: product_ref.price
                                | times: 100
                                | divided_by: product_ref.compare_at_price
                            %}

                            <span class="eva-product__discount">-{{ discount }}%</span>
                        {% endif %}

                    </div>

                    <a href="{{ product_ref.url }}" class="eva-product__button">
                        {{ section.settings.button_text }}
                    </a>

                </div>

            </div>
        </div>
    </section>
{% endif %}

{% schema %}
{
  "name": "EVA product slider",
  "settings": [
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#1B1D22"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1B1D22"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Fallback product",
      "info": "Used when no metafield or dynamic source product is available"
    },
    {
      "type": "image_picker",
      "id": "top_right_image",
      "label": "Top right image"
    },
    {
      "type": "image_picker",
      "id": "bottom_left_image",
      "label": "Bottom left image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "ZOBRAZIT PRODUKT"
    },
    {
      "type": "header",
      "content": "Product gallery"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "label": "Gallery layout",
      "options": [
        {
          "value": "thumbnail_slider",
          "label": "Thumbnail slider"
        },
        {
          "value": "thumbnail",
          "label": "Thumbnail"
        },
        {
          "value": "stacked",
          "label": "Stacked"
        },
        {
          "value": "columns",
          "label": "Columns"
        }
      ],
      "default": "thumbnail_slider"
    },
    {
      "type": "select",
      "id": "mobile_thumbnails",
      "label": "Mobile thumbnails",
      "options": [
        {
          "value": "show",
          "label": "Show"
        },
        {
          "value": "hide",
          "label": "Hide"
        },
        {
          "value": "columns",
          "label": "Columns"
        }
      ],
      "default": "show"
    },
    {
      "type": "select",
      "id": "media_size",
      "label": "Media size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "small"
    },
    {
      "type": "select",
      "id": "media_fit",
      "label": "Media fit",
      "options": [
        {
          "value": "contain",
          "label": "Contain"
        },
        {
          "value": "cover",
          "label": "Cover"
        }
      ],
      "default": "contain"
    },
    {
      "type": "checkbox",
      "id": "constrain_to_viewport",
      "label": "Constrain to viewport",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_variants",
      "label": "Hide variant media",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "Enable video looping",
      "default": false
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "EVA product slider"
    }
  ]
}
{% endschema %}