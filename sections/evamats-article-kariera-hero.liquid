    },
    {
      "type": "paragraph",
      "content": "Vacancy metaobject button_url: external (https://…), domain (www.site.pl/…), or internal path (/contact). External links open in a new tab."
    },
    {
      "type": "header",
      "content": "Vacancy tag labels"
    },
    {
      "type": "text",
      "id": "label_contract",
      "label": "Label: contract",
      "default": "Umowa"
    },
    {
      "type": "text",
      "id": "label_languages",
      "label": "Label: languages",
      "default": "Jazyk"
    },
    {
      "type": "text",
      "id": "label_work_mode",
      "label": "Label: work mode",
