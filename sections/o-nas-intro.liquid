{%- liquid
  assign photo_count = 0
  for block in section.blocks
    if block.type == 'photo'
      assign photo_count = photo_count | plus: 1
    endif
  endfor
-%}

<div
  id="ONasIntro-{{ section.id }}"
  class="o-nas-intro o-nas-intro--photos-{{ photo_count }}"
>
  <div class="o-nas-intro__wrap page-width">
    {%- if page.title != blank -%}
      <h1 class="o-nas-intro__sr-only">{{ page.title | escape }}</h1>
    {%- endif -%}

    <div class="o-nas-intro__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="o-nas-intro__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="o-nas-intro__heading section_title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.body != blank -%}
      <div class="o-nas-intro__body rte">{{ section.settings.body }}</div>
    {%- endif -%}
  </div>

  {%- if photo_count > 0 -%}
    <div class="o-nas-intro__gallery-bleed">
      <div class="o-nas-intro__gallery" data-photo-count="{{ photo_count }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'photo' -%}
            <figure class="o-nas-intro__figure" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    class: 'o-nas-intro__img',
                    sizes: '(min-width: 990px) 22vw, 30vw',
                    widths: '200, 360, 540, 720, 900, 1200'
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'o-nas-intro__img o-nas-intro__img--placeholder' }}
              {%- endif -%}
            </figure>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
  </div>
</div>

{% comment %} styles moved to assets/base_v2.css (stylesheet) {% endcomment %}

{% schema %}
{
  "name": "O nas — intro",
  "tag": "section",
  "class": "section-o-nas-intro",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "O nas"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Twój komfort ma znaczenie",
      "info": "Gradient from white to brand red is applied to the full line."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Description",
      "default": "<p>EVAMATS to nie tylko dywaniki samochodowe. To innowacyjne rozwiązania, które połączą styl, trwałość i ekologiczne materiały. Nasz materiał jest ekologiczny, co oznacza, że dbasz nie tylko o swoje auto, ale również o środowisko.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Desktop: all photos in one row. Mobile: only the first 3 are shown — center full, left/right cropped to half width (no scroll). Put the hero shot in position 2."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "O nas — intro",
      "category": "V2",
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
