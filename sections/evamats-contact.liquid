{{ 'evamats-breadcrumbs.css' | asset_url | stylesheet_tag }}
{{ 'section-video-reviews.css' | asset_url | stylesheet_tag }}
{{ 'section-evamats-contact.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign mat_form_id = 'EvamatsContactForm-' | append: section.id
  assign mat_form_wrapper_id = 'evamats-contact-form-' | append: section.id

  assign breadcrumb_parent_label = section.settings.breadcrumb_parent_label | strip
  if breadcrumb_parent_label == blank
    assign breadcrumb_parent_label = 'Evamats'
  endif

  assign breadcrumb_parent_url = section.settings.breadcrumb_parent_url | strip
  if breadcrumb_parent_url == blank
    assign breadcrumb_parent_url = routes.root_url
  endif

  assign breadcrumb_current_label = section.settings.breadcrumb_current_label | strip
  if breadcrumb_current_label == blank
    assign breadcrumb_current_label = 'Kontakt'
  endif

  assign phone = section.settings.phone | strip
  assign phone_href = phone | replace: ' ', '' | replace: '-', ''
-%}

<div class="evamats-contact" id="EvamatsContact-{{ section.id }}">
  <div class="evamats-contact__hero">
    <div class="evamats-contact__hero-grid">
      <div class="evamats-contact__info-col">
        <div class="evamats-contact__info-inner">
          {% render 'evamats-breadcrumbs',
            parent_label: breadcrumb_parent_label,
            parent_url: breadcrumb_parent_url,
            current_label: breadcrumb_current_label,
            class: 'evamats-contact__breadcrumbs'
          %}

          {%- if section.settings.contact_heading != blank -%}
            <h1 class="evamats-contact__title">{{ section.settings.contact_heading | escape }}</h1>
          {%- endif -%}

          <div class="evamats-contact__details">
            {%- if phone != blank -%}
              <p class="evamats-contact__phone">
                <a class="evamats-contact__phone-link" href="tel:{{ phone_href | escape }}">{{ phone | escape }}</a>
              </p>
            {%- endif -%}

            {%- if section.settings.email_general_label != blank and section.settings.email_general != blank -%}
              <div class="evamats-contact__detail">
                <p class="evamats-contact__detail-label">{{ section.settings.email_general_label | escape }}</p>
                <a class="evamats-contact__detail-email" href="mailto:{{ section.settings.email_general | strip | escape }}">
                  {{- section.settings.email_general | strip | escape -}}
                </a>
              </div>
            {%- endif -%}

            {%- if section.settings.email_claims_label != blank and section.settings.email_claims != blank -%}
              <div class="evamats-contact__detail">
                <p class="evamats-contact__detail-label">{{ section.settings.email_claims_label | escape }}</p>
                <a class="evamats-contact__detail-email" href="mailto:{{ section.settings.email_claims | strip | escape }}">
                  {{- section.settings.email_claims | strip | escape -}}
                </a>
              </div>
            {%- endif -%}

            {%- if section.settings.email_production_label != blank and section.settings.email_production != blank -%}
              <div class="evamats-contact__detail">
                <p class="evamats-contact__detail-label">{{ section.settings.email_production_label | escape }}</p>
                <a class="evamats-contact__detail-email" href="mailto:{{ section.settings.email_production | strip | escape }}">
                  {{- section.settings.email_production | strip | escape -}}
                </a>
              </div>
            {%- endif -%}

            {%- if section.settings.address_label != blank and section.settings.address != blank -%}
              <div class="evamats-contact__detail">
                <p class="evamats-contact__detail-label">{{ section.settings.address_label | escape }}</p>
                <p class="evamats-contact__detail-address">{{ section.settings.address | newline_to_br }}</p>
              </div>
            {%- endif -%}

            {%- if section.settings.tin_label != blank and section.settings.tin != blank -%}
              <div class="evamats-contact__detail">
                <p class="evamats-contact__detail-label">{{ section.settings.tin_label | escape }}</p>
                <p class="evamats-contact__detail-address">{{ section.settings.tin | escape }}</p>
              </div>
            {%- endif -%}
          </div>

          <div class="evamats-contact__socials">
            {% render 'evamats-footer-socials', section: section %}
          </div>
        </div>
      </div>

      <div class="evamats-contact__form-col">
        <div class="evamats-contact__form-inner">
          {% render 'mat-consult-form',
            form_section: section,
            form_id: mat_form_id,
            wrapper_id: mat_form_wrapper_id,
            hidden_form_value: section.settings.hidden_form_tag | default: 'Kontakt — formularz (strona WWW)'
          %}
        </div>
      </div>
    </div>
  </div>
</div>

