{%- liquid
  assign feature_count = 0
  for block in section.blocks
    if block.type == 'feature'
      assign feature_count = feature_count | plus: 1
    endif
  endfor
-%}

<div
  id="AdvCleanHero-{{ section.id }}"
  class="adv-clean-hero-v2"
  style="--ach-image-text-gap: {{ section.settings.image_text_gap | default: 40 }}px;"
>
  <div class="adv-clean-hero-v2__wrap">
    <div class="adv-clean-hero-v2__media-mobile">
      {%- if section.settings.image_mobile != blank -%}
        {{
          section.settings.image_mobile
          | image_url: width: 1200
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            class: 'adv-clean-hero-v2__hero-img',
            sizes: '100vw',
            widths: '375, 550, 750, 1000, 1200'
        }}
      {%- elsif section.settings.image_desktop != blank -%}
        {{
          section.settings.image_desktop
          | image_url: width: 1600
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            class: 'adv-clean-hero-v2__hero-img',
            sizes: '100vw',
            widths: '400, 800, 1200, 1600'
        }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'adv-clean-hero-v2__hero-img adv-clean-hero-v2__placeholder' }}
      {%- endif -%}
    </div>

    <div class="adv-clean-hero-v2__panel">
      <div class="adv-clean-hero-v2__inner">
        <div class="adv-clean-hero-v2__row">
          <div class="adv-clean-hero-v2__media-desktop">
            {%- if section.settings.image_desktop != blank -%}
              {{
                section.settings.image_desktop
                | image_url: width: 2000
                | image_tag:
                  loading: 'eager',
                  fetchpriority: 'high',
                  class: 'adv-clean-hero-v2__hero-img',
                  sizes: '(min-width: 990px) 50vw, 0',
                  widths: '600, 900, 1200, 1600, 2000'
              }}
            {%- elsif section.settings.image_mobile != blank -%}
              {{
                section.settings.image_mobile
                | image_url: width: 1600
                | image_tag:
                  loading: 'eager',
                  fetchpriority: 'high',
                  class: 'adv-clean-hero-v2__hero-img',
                  sizes: '(min-width: 990px) 50vw, 0',
                  widths: '400, 800, 1200, 1600'
              }}
            {%- else -%}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'adv-clean-hero-v2__hero-img adv-clean-hero-v2__placeholder' }}
            {%- endif -%}
          </div>

          <div class="adv-clean-hero-v2__content">
            <div class="adv-clean-hero-v2__lead">
              {%- if section.settings.heading != blank -%}
                <h2 class="adv-clean-hero-v2__heading section_title">{{ section.settings.heading | escape }}</h2>
              {%- endif -%}

              {% render 'evamats-trust-badge',
                badge_text: section.settings.badge_text,
                badge_faces_image: section.settings.badge_faces_image
              %}
            </div>

            {%- if feature_count > 0 -%}
              <ul class="adv-clean-hero-v2__features">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'feature' -%}
                    <li class="adv-clean-hero-v2__feature" {{ block.shopify_attributes }}>
                      <div class="adv-clean-hero-v2__feature-icon">
                        {%- if block.settings.icon != blank -%}
                          {{
                            block.settings.icon
                            | image_url: width: 200
                            | image_tag: loading: 'lazy', class: 'adv-clean-hero-v2__feature-img', widths: '70, 120, 200'
                          }}
                        {%- else -%}
                          {{ 'image' | placeholder_svg_tag: 'adv-clean-hero-v2__feature-img adv-clean-hero-v2__placeholder' }}
                        {%- endif -%}
                      </div>
                      <p class="adv-clean-hero-v2__feature-text">{{ block.settings.text | escape }}</p>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}

            <div class="adv-clean-hero-v2__tail">
              {%- if section.settings.tagline != blank -%}
                <p class="adv-clean-hero-v2__tagline">{{ section.settings.tagline | escape }}</p>
              {%- endif -%}
              {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
                <a class="button button_3 adv-clean-hero-v2__cta" href="{{ section.settings.cta_url }}">{{ section.settings.cta_label | escape }}</a>
              {%- elsif section.settings.cta_label != blank -%}
                <span class="button button_3 adv-clean-hero-v2__cta disabled" aria-disabled="true">{{ section.settings.cta_label | escape }}</span>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% comment %} styles moved to assets/base_v2.css (style) {% endcomment %}

{% schema %}
{
  "name": "ADV clean hero v2",
  "tag": "section",
  "class": "section_v2",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nový způsob, jak udržet čistotu v autě — bez každodenního úklidu"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "50k+ řidičů"
    },
    {
      "type": "header",
      "content": "Badge faces"
    },
    {
      "type": "paragraph",
      "content": "One image (e.g. a row of faces on transparent PNG). If empty, grey circles show."
    },
    {
      "type": "image_picker",
      "id": "badge_faces_image",
      "label": "Faces image (single)"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline (red, next to CTA)",
      "default": "Jednoduše. Účinně. Bez kompromisů."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Zobacz produkt"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Image (desktop, left)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image (mobile, top)"
    },
    {
      "type": "range",
      "id": "image_text_gap",
      "label": "Space between photo and text (desktop, left padding on text)",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Struktura, která zachytává nečistoty"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ADV clean hero v2",
      "category": "V2",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "text": "Struktura, která zachytává nečistoty"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Powierzchnia, która nie chłonie wilgoci"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Dopasowanie, które nie przesuwa się pod nogami"
          }
        }
      ]
    }
  ]
}
{% endschema %}
