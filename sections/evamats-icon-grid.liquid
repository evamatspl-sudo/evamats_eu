{%- liquid
  assign item_count = 0
  for block in section.blocks
    if block.type == 'item'
      assign item_count = item_count | plus: 1
    endif
  endfor

  assign layout_style = section.settings.layout_style | default: 'grid'
  assign heading_alignment = section.settings.heading_alignment | default: 'center'
  assign section_classes = 'evamats-icon-grid'
  if layout_style == 'rows'
    assign section_classes = section_classes | append: ' evamats-icon-grid--rows'
  endif
  if heading_alignment == 'left'
    assign section_classes = section_classes | append: ' evamats-icon-grid--heading-left'
  endif
-%}

{% render 'evamats-section-padding-style', section: section, target: '.evamats-icon-grid' %}
<div
  id="EvamatsIconGrid-{{ section.id }}"
  class="{{ section_classes }}"
>
  <div class="evamats-icon-grid__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="evamats-icon-grid__heading section_title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if item_count > 0 -%}
      <ul class="evamats-icon-grid__grid" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'item' -%}
            <li class="evamats-icon-grid__item" {{ block.shopify_attributes }}>
              <div class="evamats-icon-grid__icon" aria-hidden="true">
                {%- if block.settings.icon != blank -%}
                  {{
                    block.settings.icon
                    | image_url: width: 96
                    | image_tag: loading: 'lazy', class: 'evamats-icon-grid__icon-img', alt: ''
                  }}
                {%- endif -%}
              </div>

              <div class="evamats-icon-grid__body">
                {%- if block.settings.heading != blank -%}
                  <h3 class="evamats-icon-grid__title">{{ block.settings.heading | escape }}</h3>
                {%- endif -%}

                {%- if block.settings.text != blank -%}
                  <p class="evamats-icon-grid__text">{{ block.settings.text | escape }}</p>
                {%- endif -%}
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% comment %} styles moved to assets/base_v2.css (stylesheet) {% endcomment %}

{% schema %}
{
  "name": "EVAMATS — Icon grid",
  "tag": "section",
  "class": "section-evamats-icon-grid",
  "settings": [
