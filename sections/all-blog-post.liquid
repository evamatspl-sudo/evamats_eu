{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'section-main-blog.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .blog-articles__article.is-hidden {
    display: none;
  }
{%- endstyle -%}

{%- liquid
  assign blog_handles_raw = section.settings.posts_to_show | split: ','
-%}

<div class="main-blog page-width section-{{ section.id }}-padding">
  <div class="main-blog__top-wrap">
    <div class="main-blog__count-result">
      <span class="js-search-count">0</span>
      <span class="js-search-label" data-singular="result" data-plural="results">results</span>
    </div>

    <button type="button" class="main-blog__search-reset">
      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 10 10" fill="none">
        <g opacity="0.4">
          <path d="M10 8L8 10L5 7L2 10L0 8L3 5L0 2L2 0L5 3L8 0L10 2L7 5L10 8Z" fill="#8090A4"/>
        </g>
      </svg>
      <span>Reset</span>
    </button>
  </div>

  <div class="blog-articles{% if section.settings.layout == 'collage' %} blog-articles--collage{% endif %}">
    {%- for handle_part in blog_handles_raw -%}
      {%- assign handle_trimmed = handle_part | strip -%}
      {%- if handle_trimmed != blank and blogs[handle_trimmed] != blank -%}
        {%- for article in blogs[handle_trimmed].articles -%}
          <div class="blog-articles__article article">
            {%- render 'article-card',
              article: article,
              media_height: section.settings.image_height,
              media_aspect_ratio: article.image.aspect_ratio,
              show_image: section.settings.show_image,
              show_date: section.settings.show_date,
              show_author: section.settings.show_author,
              show_excerpt: true
            -%}
          </div>
        {%- endfor -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "All blog post",
  "tag": "section",
  "class": "section-all-blog-post",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "posts_to_show",
      "label": "Blogs to show",
      "info": "Comma-separated blog handles, e.g. audi,bmw,toyota,range-rover"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "collage",
          "label": "Collage"
        }
      ],
      "default": "grid",
      "label": "Layout"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_image.label"
    },
    {
      "type": "select",
      "id": "image_height",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "large",
      "label": "Image height"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": false,
      "label": "t:sections.featured-blog.settings.show_date.label"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": false,
      "label": "t:sections.featured-blog.settings.show_author.label"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "All blog posts"
    }
  ]
}
{% endschema %}
