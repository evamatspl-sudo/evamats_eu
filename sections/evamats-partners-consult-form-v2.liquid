{%- liquid
  assign mat_form_id = 'PartnersConsultForm-' | append: section.id
  assign mat_form_wrapper_id = 'partners-consult-form-' | append: section.id
-%}

{% render 'evamats-section-padding-style', section: section, target: '.evamats-partners-consult-form-v2' %}
<div
  id="PartnersConsultForm-{{ section.id }}"
  class="evamats-partners-consult-form-v2 has_anchor"
>
  <div id="partners_form" class="anchor"></div>
  <div  class="evamats-partners-consult-form-v2__inner page-width">
    {% render 'mat-consult-form',
      form_section: section,
      form_id: mat_form_id,
      wrapper_id: mat_form_wrapper_id,
      hidden_form_value: section.settings.hidden_form_tag | default: 'Partnerzy — zapytanie (strona WWW)',
      form_layout: 'partners'
    %}

    {%- if section.settings.alt_button_url != blank or section.settings.alt_button_label != blank -%}
      <div class="epcf-alt-cta">
        <div class="epcf-alt-cta__divider" aria-hidden="true">
          <span class="epcf-alt-cta__divider-line"></span>
          <span class="epcf-alt-cta__divider-text">{{ section.settings.alt_divider_text | default: 'lub' | escape }}</span>
          <span class="epcf-alt-cta__divider-line"></span>
        </div>
        {%- if section.settings.alt_title != blank -%}
          <p class="epcf-alt-cta__title">{{ section.settings.alt_title | escape }}</p>
        {%- endif -%}
        {%- if section.settings.alt_text != blank -%}
          <p class="epcf-alt-cta__text">{{ section.settings.alt_text | escape }}</p>
        {%- endif -%}
        {%- if section.settings.alt_button_label != blank -%}
          <a
            class="epcf-alt-cta__btn button button_3"
            href="{{ section.settings.alt_button_url | default: '#' }}"
          >
            {{ section.settings.alt_button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% comment %} styles moved to assets/base_v2.css (stylesheet) {% endcomment %}

