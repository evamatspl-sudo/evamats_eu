                          {% assign startDate = 0 %}
                          {% assign endDate = 0 %}
    
                          {% assign arr = product.metafields.custom.year_of_production | split: ',' %}
                          
                          {% for item in arr %}
                            {% if forloop.index == 1 %}
                              {% assign startDate = item %}
                            {% endif %}
                            {% if forloop.index == 2 %}
                              {% assign endDate = item %}
                            {% endif %}
                          {% endfor %}
    
                          {% for item in (startDate..endDate) %}
