                  {% assign ratingValue = product.metafields.custom.fake_rating_value %}
                  {% assign ratingCount = product.metafields.custom.fake_rating_counter %}
                {% else %}
                  {% assign ratingValue = settings.fake_rating_value %}
                  {% assign ratingCount = settings.fake_rating_count %}
                {% endif %}
               
                  {% assign rating_value = ratingValue | times: 1.0 %} <!-- Преобразуем строку в число -->
                  {% assign fill_percentage = rating_value | divided_by: 5 | times: 100 %} <!-- Процент заполнения -->
                  <div class="stars" aria-label="{{ rating_value | round: 1 }} из 5">
                    <div class="overlay" style="--fill: {{ fill_percentage }}%;"></div>
                    {% for i in (1..5) %}
                      <div class="star"></div>
                    {% endfor %}
                  </div>
                  <div class="rating-value">
                    {{ rating_value | round: 1 }}/5 ({{ ratingCount }})
                  </div>
              </div>
