{{ 'product-config.css' | asset_url | stylesheet_tag }}
{{ 'application-form.css' | asset_url | stylesheet_tag }}

{% assign application_form_id = 'application_form_id' %}
{%- form 'contact', id: application_form_id, class: 'isolate' -%}
    
    {%- if form.posted_successfully? -%}
        <div class="popup_overlay popup-overlay--application_form_message show">
            <div class="popup">
                <div class="popup-content">

                    <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
                        {% render 'icon-success' %}
                        {{ 'templates.contact.form.post_success' | t }}
                      </h2>
        
                </div>
            </div>
            <span class="popup_close_btn" >{% render 'icon-close' %}</span>
        </div>
    {%- elsif form.errors -%}
        <div class="popup_overlay popup-overlay--application_form_message show">
            <div class="popup">
                <div class="popup-content">
                      <div class="form__message">
                        <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
                          {% render 'icon-error' %}
                          {{ 'templates.contact.form.error_heading' | t }}
                        </h2>
                      </div>
                      <ul class="form-status-list caption-large" role="list">
                        <li>
                          <a href="#ContactForm-email" class="link">
                            {{ form.errors.translated_fields.email | capitalize }}
                            {{ form.errors.messages.email }}
                          </a>
                        </li>
                      </ul>
                </div>
            </div>
            <span class="popup_close_btn" >{% render 'icon-close' %}</span>
        </div>
      {%- endif -%}
<div id="popupOverlayApplicationForm" class=" popup_overlay popup-overlay--application_form">
    <div class="popup">
        <div class="popup-content">
            <div class="application_form__content config_container">
                <div class="product__config_image product__config_image--desktop">
                    <img src="{{ "1x1_FFFFFF.jpg" | file_url }}" alt="" loading='lazy'>
                </div>
                
                <div class="application_form__config ">
                    {% if section.settings.alternative_zestaw  %}
                        <div class="product__dropdown_wr disabled">
                            <div class="product__dropdown_title">{{'general.config.vehicle_text' | t}} <span class="product__dropdown_value"></span>  {% render 'icon-caret' %} {% render 'icon-edit' %}</div>
                            <div class="product__dropdown_inner">
                                <div class="line-item-property__field">
                                    <textarea id="pojazd"  name="contact[{{'general.config.vehicle' | t}}]" required></textarea>
                                    <div class="error-message" style="display: none;">{{ 'general.config.error_message_field' | t }}</div>
                                </div>  

                                <button type="button" class="product__dropdown_button button button_5" disabled>{{ 'general.config.continue' | t }}</button>
                            </div>
                        </div>
                    {% endif %}
                    {% unless section.settings.alternative_zestaw %}
                        <div class="product__dropdown_wr open" data-dropdown="year">
                            <div class="product__dropdown_title">{{ 'general.config.select_year' | t }}: <span class="product__dropdown_value"></span>  {% render 'icon-caret' %} {% render 'icon-edit' %}</div>
                            <div class="product__dropdown_inner open">
                            <fieldset class="product-form__input product-form__input--dropdown">
                                {% assign productionYears = '' %}
                                
                                <div class="select">
                                <select required class=" select__select" id="rok-produkcji" name="contact[Rok produkcji: *]"  form="{{ application_form_id }}" aria-required="true" data-text="{{ 'general.config.please_select' | t }}">
                                    <option value="" >{{ 'general.config.please_select' | t }}</option>
                                {% assign currentYear = 'now' | date: "%Y" | plus: 0%}
                
                                {% if product.metafields.custom.year_of_production %}
                                    {% assign startDate = 0 %}
                                    {% assign endDate = 0 %}
                
                                    {% assign arr = product.metafields.custom.year_of_production | split: ',' %}
                                    
                                    {% for item in arr %}
                                    {% if forloop.index == 1 %}
                                        {% assign startDate = item %}
                                    {% endif %}
                                    {% if forloop.index == 2 %}
                                        {% assign endDate = item %}
                                    {% endif %}
                                    {% endfor %}
                
                                    {% for item in (startDate..endDate) %}
                                    <option value="{{item}}">{{item}}</option>
                                    {% endfor %}
                
                                {% else %}
                
                                    {% for item in (1980..currentYear) %}
                                    <option value="{{item}}">{{item}}</option>
                                    {% endfor %}
                                {% endif %}
                                
                                
                                
                                </select>
                                </div>
                                <div class="error-message" style="display: none;">{{ 'general.config.error_message' | t }}</div>
                            </fieldset>
            
                            <button type="button" class="product__dropdown_button button button_5" disabled>{{ 'general.config.continue' | t }}</button>
                            </div>
                        </div>
                    {% endunless %}

                    <div class="product__dropdown_wr disabled" data-dropdown="mats_set_type">
                        <div class="product__dropdown_title">{{ 'general.config.select_mats_type_and_set' | t }}: <span class="product__dropdown_value"></span>  {% render 'icon-caret' %} {% render 'icon-edit' %}</div>
                        <div class="product__dropdown_inner">
                            <variant-radios>
                            {% comment %} Mats type {% endcomment %}
                                <fieldset class="js product-form__input lip__field" data-name="mats_type">
                                    <legend class="form__label lip__title">
                                      <span class="form__label_text">{{'general.config.mats_type' | t}}</span> 
                                        <div class="lip__title_value"></div>
                                    </legend>
                                    <input type="radio" id="mats_type-1-0" data-name="classic" name="{{'general.config.mats_type' | t}}" data-title="{{'general.config.without_edges' | t}}" value="{{'general.config.without_edges' | t}}"  checked="">
                                    <label for="mats_type-1-0" class="default_option">
                                        <img src="{{ '5os-classic-diamonds-black-red.webp' | file_url}}" alt="" loading="lazy">
                                        <div class="label__tooltip">{{'general.config.without_edges' | t}}</div>
                                        <span class="evamats-config-option-label">{{ 'general.config.without_edges' | t | remove: 'Carvion' | remove: 'EVAMATS' | strip | replace: '  ', ' ' }}</span>
                                        <span class="visually-hidden">{{'products.product.variant_sold_out_or_unavailable' | t}}</span>
                                    </label>
                                    <input type="radio" id="mats_type-1-1" data-name="3d" name="{{'general.config.mats_type' | t}}" data-title="{{'general.config.with_edges' | t}}" value="{{'general.config.with_edges' | t}}" >
                                    <label for="mats_type-1-1" class="default_option">
                                        <img src="{{ '5os-3d-diamonds-black-red.webp' | file_url}}" alt="" loading="lazy">
                                        <div class="label__tooltip">{{'general.config.with_edges' | t }}</div>
                                        <span class="evamats-config-option-label">{{ 'general.config.with_edges' | t | remove: 'Carvion' | remove: 'EVAMATS' | strip | replace: '  ', ' ' }}</span>
                                        <span class="visually-hidden">{{'products.product.variant_sold_out_or_unavailable' | t}}</span>
                                    </label>
                                </fieldset>
                                {% comment %} Mats type {% endcomment %}

                                {% comment %} Mats set  {% endcomment %}
                                {% if section.settings.alternative_zestaw %}
                                    <div class="line-item-property__field">
                                        <label for="mats_set">{{ 'general.config.mats_set' | t }}</label>
                                        <textarea id="mats_set" name="contact[{{ 'general.config.mats_set' | t }}]" required></textarea>
                                        <div class="error-message" style="display: none;">{{ 'general.config.error_message_field' | t }}</div>
                                    </div>
                                {% else %}
                                    <fieldset class="js product-form__input lip__field" data-name="mats_set">
                                        <legend class="form__label lip__title">
                                          <span class="form__label_text">{{'general.config.mats_set' | t}}</span> 
                                           
                                            <div class="lip__title_value"></div>
                                        </legend>
                                        
                                        <input type="radio" id="Zestaw-2-0" data-name="{{ 'general.config.only_driver_mat' | t | escape }}" name="{{'general.config.mats_set' | t}}" data-title="{{'general.config.only_driver_mat' | t}}" value="{{'general.config.only_driver_mat' | t}}"  checked="">
                                        <label for="Zestaw-2-0" class="default_option">
                                            <img src="{{ '5os-mat-front-1.svg' | file_url }}" alt="" loading="lazy">
                                            <div class="label__tooltip">{{'general.config.only_driver_mat' | t}}</div>
                                        </label>

                                        <input type="radio" id="Zestaw-2-1" data-name="{{'general.config.front' | t}}" name="{{'general.config.mats_set' | t}}" data-title="{{'general.config.front' | t}}" value="{{'general.config.front' | t}}" >
                                        <label for="Zestaw-2-1" class="default_option">
                                            <img src="{{ '5os-mat-front-2.svg' | file_url }}" alt="" loading="lazy">
                                            <div class="label__tooltip">{{'general.config.front' | t}}</div>
                                            <div class="label_badge">-5%</div>
                                        </label>

                                        <input type="radio" id="Zestaw-2-2" data-name="{{'general.config.rear' | t}}" name="{{'general.config.mats_set' | t}}" data-title="{{'general.config.rear' | t}}" value="{{'general.config.rear' | t}}" >
                                        <label for="Zestaw-2-2" class="default_option">
                                            <img src="{{ '5os-mat-back-2.svg' | file_url }}" alt="" loading="lazy">
                                            <div class="label__tooltip">{{'general.config.rear' | t}}</div>
                                        </label>
                                        
                                        <input type="radio" id="Zestaw-2-3" data-name="{{'general.config.front_rear' | t}}" name="{{'general.config.mats_set' | t}}" data-title="{{'general.config.front_rear' | t}}" value="{{'general.config.front_rear' | t}}" >
                                        <label for="Zestaw-2-3" class="default_option">
                                            <img src="{{ '5os-mat-front-back.svg' | file_url }}" alt="" loading="lazy">
                                            <div class="label__tooltip">{{'general.config.front_rear' | t}}</div>
                                            <div class="label_badge">-10%</div>
                                        </label>
                                        
                                        <input type="radio" id="Zestaw-2-4" data-name="{{'general.config.trunk' | t}}"  name="{{'general.config.mats_set' | t}}" data-title="{{'general.config.trunk' | t}}" value="{{'general.config.trunk' | t}}" >
                                        <label for="Zestaw-2-4" class="default_option">
                                            <img src="{{ '5os-mat-trunk.svg' | file_url }}" alt="" loading="lazy">
                                            <div class="label__tooltip">{{'general.config.trunk' | t}}</div>
                                        </label>
                                        
                                        <input type="radio" id="Zestaw-2-5" data-name="{{'general.config.front_rear_trunk' | t}}" name="{{'general.config.mats_set' | t}}" data-title="{{'general.config.front_rear_trunk' | t}}" value="{{'general.config.front_rear_trunk' | t}}" >
                                        <label for="Zestaw-2-5" class="default_option">
                                            <img src="{{ '5os-mat-set.svg' | file_url }}" alt="" loading="lazy">
                                            <div class="label__tooltip">{{'general.config.front_rear_trunk' | t}}</div>
                                            <div class="label_badge">-15%</div>
                                        </label>
                                    </fieldset>
                                {% endif %}
                                {% comment %} Mats set  {% endcomment %}
                            </variant-radios>

                            <button type="button" class="product__dropdown_button button button_5" disabled>{{ 'general.config.continue' | t }}</button>
                        </div>
                    </div>

                      {% comment %} matPattern {% endcomment %}
                    <div class="product__dropdown_wr disabled" data-dropdown="mat_patterns_colors">
                        <div class="product__dropdown_title">{{ 'general.config.select_shape_and_colors' | t }}: <span class="product__dropdown_value"></span>  {% render 'icon-caret' %} {% render 'icon-edit' %}</div>
                        <div class="product__dropdown_inner">
                            <div class="product__config_main">
                            <fieldset  class="lip__field" data-type="matPattern">
