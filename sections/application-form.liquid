                                <div class="lip__grid">
                                    <label class="lip__item">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.cell_shape' | t }}]" data-value="diamonds" value="diamonds" data-title="{{ 'general.config.diamonds' | t }}" checked> 
                                    <img src="{{ 'diamonds.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.config.diamonds' | t }}</div>
                                    </label>
                                    <label class="lip__item">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.cell_shape' | t }}]" data-value="honey" value="honeycomb" data-title="{{ 'general.config.honeycomb' | t }}" > 
                                    <img src="{{ 'honey.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.config.honeycomb' | t }}</div>
                                    </label>
                                    {% if product.metafields.custom.body_type == '5os' or product.metafields.custom.body_type == 'custom' or product.metafields.custom.body_type == '7os' or product.metafields.custom.body_type == '2os' or product.metafields.custom.body_type == 'pickup' or product.metafields.custom.body_type == 'van_maly' or product.metafields.custom.body_type == 'pickup2kabina' or product.metafields.custom.body_type == 'electro' %}
                                      <label class="lip__item">
                                        <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.cell_shape' | t }}]" data-value="drop" value="{{ 'general.config.drops_property_value' | t }}" data-title="{{ 'general.config.mat_pattern_drops' | t }}">
                                        <img src="{{ 'drop.webp' | file_url }}" alt="{{ 'general.config.mat_pattern_drops' | t }}" loading="lazy">
                                        <div class="label__tooltip">{{ 'general.config.mat_pattern_drops' | t }}</div>
                                      </label>
                                    {% endif %}
                                </div>
                            </fieldset>
                            {% comment %} matPattern {% endcomment %}
                            {% comment %} matColor {% endcomment %}
                            <fieldset class="lip__field diamonds_active" data-type="matColor">
                                <div class='lip__title'>{{ 'general.config.material_color' | t }}: <div class="lip__title_value"></div></div>
                                <div class="lip__grid">
                                  <label class="lip__item honey diamonds drop">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="black" value="{{ 'general.colors.black' | t }}" data-title="{{ 'general.colors.black' | t }}" checked>
                                    <img src="{{ 'material-black.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.black' | t }}</div>
                                  </label>
                                  <label class="lip__item honey diamonds drop">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="brown" value="{{ 'general.colors.brown' | t }}" data-title="{{ 'general.colors.brown' | t }}">
                                    <img src="{{ 'material-brown.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.brown' | t }}</div>
                                  </label>
                                  <label class="lip__item honey diamonds drop">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="darkgrey" value="{{ 'general.colors.grey' | t }}" data-title="{{ 'general.colors.grey' | t }}">
                                    <img src="{{ 'material-darkgrey.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.grey' | t }}</div>
                                  </label>
                                  <label class="lip__item honey diamonds">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="darkblue" value="{{ 'general.colors.dark_blue' | t }}" data-title="{{ 'general.colors.dark_blue' | t }}">
                                    <img src="{{ 'material-darkblue.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.dark_blue' | t }}</div>
                                  </label>
                                  <label class="lip__item honey diamonds">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="blue" value="{{ 'general.colors.blue' | t }}" data-title="{{ 'general.colors.blue' | t }}">
                                    <img src="{{ 'material-blue.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.blue' | t }}</div>
                                  </label>
                                  <label class="lip__item honey diamonds">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="darkgreen" value="{{ 'general.colors.green' | t }}" data-title="{{ 'general.colors.green' | t }}">
                                    <img src="{{ 'material-green.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.green' | t }}</div>
                                  </label>
                                  <label class="lip__item honey diamonds">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="red" value="{{ 'general.colors.red' | t }}" data-title="{{ 'general.colors.red' | t }}">
                                    <img src="{{ 'material-red.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.red' | t }}</div>
                                  </label>
                                  <label class="lip__item honey diamonds">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="maroon" value="{{ 'general.colors.maroon' | t }}" data-title="{{ 'general.colors.maroon' | t }}">
                                    <img src="{{ 'material-maroon.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.maroon' | t }}</div>
                                  </label>
                                  <label class="lip__item honey diamonds drop">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="lightbeige" value="{{ 'general.colors.light_beige' | t }}" data-title="{{ 'general.colors.light_beige' | t }}">
                                    <img src="{{ 'material-lightbeige.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.light_beige' | t }}</div>
