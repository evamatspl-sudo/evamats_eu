                                    <img src="{{ 'material-beige.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.beige' | t }}</div>
                                  </label>
                                  <label class="lip__item only_diamonds diamonds">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="purple" value="{{ 'general.colors.purple' | t }}" data-title="{{ 'general.colors.purple' | t }}">
                                    <img src="{{ 'material-purple.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.purple' | t }}</div>
                                  </label>
                                  <label class="lip__item only_diamonds diamonds">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="lime" value="{{ 'general.colors.lime' | t }}" data-title="{{ 'general.colors.lime' | t }}">
                                    <img src="{{ 'material-lime.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.lime' | t }}</div>
                                  </label>
                                  <label class="lip__item only_diamonds diamonds">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="yellow" value="{{ 'general.colors.yellow' | t }}" data-title="{{ 'general.colors.yellow' | t }}">
                                    <img src="{{ 'material-yellow.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.yellow' | t }}</div>
                                  </label>
                                  <label class="lip__item only_diamonds diamonds">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="orange" value="{{ 'general.colors.orange' | t }}" data-title="{{ 'general.colors.orange' | t }}">
                                    <img src="{{ 'material-orange.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.orange' | t }}</div>
                                  </label>
                                  <label class="lip__item honey diamonds">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="ivory" value="{{ 'general.colors.ivory' | t }}" data-title="{{ 'general.colors.ivory' | t }}">
                                    <img src="{{ 'material-ivory.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.ivory' | t }}</div>
                                  </label>
                                  <label class="lip__item only_diamonds diamonds">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="pink" value="{{ 'general.colors.pink' | t }}" data-title="{{ 'general.colors.pink' | t }}">
                                    <img src="{{ 'material-pink.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.pink' | t }}</div>
                                  </label>
                                  <label class="lip__item only_diamonds diamonds">
                                    <input type="radio" form="{{ application_form_id }}" name="contact[{{ 'general.config.material_color' | t }}]" data-value="white" value="{{ 'general.colors.white' | t }}" data-title="{{ 'general.colors.white' | t }}">
                                    <img src="{{ 'material-white.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.white' | t }}</div>
                                  </label>
                                </div>
                              </fieldset>

                            {% comment %} matColor {% endcomment %}
                            <div class="lip__comment openPopup" data-popup="popupOverlayLipComment" role="button" tabindex="0">
                                *{{'general.config.comment' | t}}
                                <span class="lip__comment_icon" aria-hidden="true">
                                {% render 'icon-info' %}
                                </span>
                            </div>

                            {% comment %} trimColor {% endcomment %}
                            <fieldset  class="lip__field" data-type="trimColor">
                                <div class='lip__title'>{{ 'general.config.trim_color' | t }}: <div class="lip__title_value"></div></div>
                                <div class="lip__grid">
                                  <label class="lip__item">
                                    <input type="radio"  form="{{ application_form_id }}" name="contact[{{ 'general.config.trim_color' | t }}]" data-value="black" value="{{ 'general.colors.black' | t }}"  data-title="{{ 'general.colors.black' | t }}" checked>
                                    <img src="{{ 'trim-black.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.black' | t }}</div>
                                  </label>                  
                                  <label class="lip__item">
                                    <input type="radio"  form="{{ application_form_id }}" name="contact[{{ 'general.config.trim_color' | t }}]" data-value="red" value="{{ 'general.colors.red' | t }}" data-title="{{ 'general.colors.red' | t }}">
                                    <img src="{{ 'trim-red.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.red' | t }}</div>
                                  </label>
                                  <label class="lip__item">
                                    <input type="radio"  form="{{ application_form_id }}" name="contact[{{ 'general.config.trim_color' | t }}]" data-value="lightgrey" value="{{ 'general.colors.light_grey' | t }}" data-title="{{ 'general.colors.light_grey' | t }}">
                                    <img src="{{ 'trim-lightgrey.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.light_grey' | t }}</div>
                                  </label>
                                  <label class="lip__item">
                                    <input type="radio"  form="{{ application_form_id }}" name="contact[{{ 'general.config.trim_color' | t }}]" data-value="darkgrey" value="{{ 'general.colors.grey' | t }}" data-title="{{ 'general.colors.grey' | t }}">
                                    <img src="{{ 'trim-grey.webp' | file_url }}" alt="" loading="lazy">
                                    <div class="label__tooltip">{{ 'general.colors.grey' | t }}</div>
