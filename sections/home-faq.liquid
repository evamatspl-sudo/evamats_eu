{% comment %} home-faq styles in assets/base.css; page variant in section-home-faq-page.css {% endcomment %}
{%- liquid
  assign is_page_faq = false
  if section.settings.design_variant == 'page'
    assign is_page_faq = true
  endif

  assign breadcrumb_parent_label = section.settings.breadcrumb_parent_label | strip
  if breadcrumb_parent_label == blank
    assign breadcrumb_parent_label = 'Evamats'
  endif

  assign breadcrumb_parent_url = section.settings.breadcrumb_parent_url | strip
  if breadcrumb_parent_url == blank
    assign breadcrumb_parent_url = routes.root_url
  endif

  assign breadcrumb_current_label = section.settings.breadcrumb_current_label | strip
  if breadcrumb_current_label == blank
    assign breadcrumb_current_label = 'FAQ'
  endif
-%}

{%- if is_page_faq -%}
  {{ 'evamats-breadcrumbs.css' | asset_url | stylesheet_tag }}
  {{ 'section-home-faq-page.css' | asset_url | stylesheet_tag }}
{%- else -%}
  {% render 'evamats-section-padding-style', section: section, target: '.home-faq-v2' %}
{%- endif -%}

<div id="faqs" class="product-faqs home-faq-v2{% if is_page_faq %} home-faq-v2--page{% endif %}">
  <div class="page-width">
    <div class="home-faq-v2__shell{% if section.settings.view_all_label != blank and is_page_faq == false %} home-faq-v2__shell--has-cta{% endif %}">
      <div class="home-faq-v2__intro">
        {%- if is_page_faq -%}
          {% render 'evamats-breadcrumbs',
            parent_label: breadcrumb_parent_label,
            parent_url: breadcrumb_parent_url,
            current_label: breadcrumb_current_label,
            class: 'home-faq-v2__breadcrumbs'
          %}
        {%- endif -%}

        <div class="home-faq-v2__heading">
          {%- if is_page_faq -%}
            <h1 class="home-faq-v2__title home-faq-v2__title--page">
              <span class="home-faq-v2__title-main">{{ section.settings.hd | escape }}</span>
              {%- if section.settings.heading_accent != blank -%}
                <span class="home-faq-v2__title-accent">{{ section.settings.heading_accent | escape }}</span>
              {%- endif -%}
            </h1>
          {%- else -%}
            <h2 class="home-faq-v2__title">
              <span class="home-faq-v2__title-desktop">{{ section.settings.hd | escape }}</span>
              <span class="home-faq-v2__title-mobile">
                {%- if section.settings.heading_mobile != blank -%}
                  {{ section.settings.heading_mobile | escape }}
                {%- else -%}
                  {{ section.settings.hd | escape }}
                {%- endif -%}
              </span>
            </h2>
          {%- endif -%}
        </div>
      </div>

      <div class="home-faq-v2__main">
        <div class="faqs-all-question">
          {%- assign theme_list_str = '' -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.category != blank -%}
              {%- assign t = block.settings.category | strip -%}
              {%- capture theme_marker -%}||{{ t }}||{%- endcapture -%}
              {%- unless theme_list_str contains theme_marker -%}
                {%- assign theme_list_str = theme_list_str | append: theme_marker -%}
              {%- endunless -%}
            {%- endif -%}
          {%- endfor -%}
          {%- assign theme_order = theme_list_str | split: '||' -%}

          {%- for theme_name in theme_order -%}
            {%- if theme_name != blank -%}
              <div class="faq-question faq-category home-faq-v2__row home-faq-v2__row--category">
                <div class="accordion accordion--category">
                  <div class="home-faq-v2__accordion-row">
                    <div class="h6 home-faq-v2__question-title">{{ theme_name | escape }}</div>
                    <span class="home-faq-v2__toggle-icon" aria-hidden="true"></span>
                  </div>
                </div>
                <div class="panel panel--category">
                  {%- for block in section.blocks -%}
                    {%- if block.settings.category != blank -%}
                      {%- assign block_theme = block.settings.category | strip -%}
                      {%- if block_theme == theme_name -%}
                        <div class="faq-question faq-question--inner home-faq-v2__row home-faq-v2__row--inner" {{ block.shopify_attributes }}>
                          <div class="accordion">
                            <div class="home-faq-v2__accordion-row">
                              <div class="h6 faq-question__title home-faq-v2__question-title">{{ block.settings.hd }}</div>
                              <span class="home-faq-v2__toggle-icon" aria-hidden="true"></span>
                            </div>
                          </div>
                          <div class="panel">
                            {%- if block.settings.des_html != blank -%}
                              {{ block.settings.des_html }}
                            {%- else -%}
                              {{ block.settings.des }}
                            {%- endif -%}
                          </div>
                        </div>
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}

          {%- for block in section.blocks -%}
            {%- if block.settings.category == blank -%}
              <div class="faq-question home-faq-v2__row home-faq-v2__row--item" {{ block.shopify_attributes }}>
                <div class="accordion">
                  <div class="home-faq-v2__accordion-row">
                    <div class="h6 faq-question__title home-faq-v2__question-title">{{ block.settings.hd }}</div>
                    <span class="home-faq-v2__toggle-icon" aria-hidden="true"></span>
                  </div>
                </div>
                <div class="panel">
                  {%- if block.settings.des_html != blank -%}
                    {{ block.settings.des_html }}
                  {%- else -%}
                    {{ block.settings.des }}
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {%- unless is_page_faq -%}
        {%- if section.settings.view_all_label != blank -%}
          {%- liquid
            assign faq_cta_href = section.settings.view_all_url
            if faq_cta_href == blank
              assign faq_cta_href = '#'
            endif
          -%}
          <div class="home-faq-v2__cta-wrap">
            <a class="button button_5 button_5--neutral" href="{{ faq_cta_href }}">{{ section.settings.view_all_label | escape }}</a>
          </div>
        {%- endif -%}
      {%- endunless -%}
    </div>
  </div>
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in section.blocks -%}
    {
      "@type": "Question",
      "name": {{ block.settings.hd | strip_newlines | strip_html | escape | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ block.settings.des_html | default: block.settings.des | strip_newlines | strip_html | escape | json }}
      }
    }{%- unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>

<script defer>
  (function () {
    function setPanelHeight(panel, open) {
      if (!panel || !panel.classList.contains('panel')) return;
      var isCategory = panel.classList.contains('panel--category');
      if (open) {
        panel.style.maxHeight = isCategory ? (panel.scrollHeight + 10000) + 'px' : panel.scrollHeight + 'px';
      } else {
        panel.style.maxHeight = null;
      }
    }
    function expandParentCategoryPanel(panel) {
      var parent = panel.closest('.panel--category');
      if (parent && parent.style.maxHeight) {
        parent.style.maxHeight = (parent.scrollHeight + 10000) + 'px';
      }
    }
    var acc = document.querySelectorAll('#faqs .accordion');
    for (var i = 0; i < acc.length; i++) {
      acc[i].addEventListener('click', function (e) {
        e.stopPropagation();
        this.classList.toggle('active');
        var panel = this.nextElementSibling;
        var wasOpen = panel && panel.style.maxHeight && panel.style.maxHeight !== '0px';
        setPanelHeight(panel, !wasOpen);
        if (panel && !panel.classList.contains('panel--category')) {
          expandParentCategoryPanel(panel);
        }
      });
    }
  })();
</script>

{% schema %}
{
  "name": "home-faq",
  "settings": [
    {
      "type": "select",
      "id": "design_variant",
      "label": "Design variant",
      "options": [
        {
          "value": "home",
          "label": "Home (sidebar layout)"
        },
        {
          "value": "page",
          "label": "Page (breadcrumbs, full width)"
        }
      ],
      "default": "home"
    },
    {
      "type": "text",
      "label": "Main heading (desktop)",
      "id": "hd",
      "default": "Často kladené otázky"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent (page variant)",
      "info": "Gray suffix after the main heading. Used only when Design variant is Page."
    },
    {
      "type": "text",
      "id": "heading_mobile",
      "label": "Heading (mobile)",
      "default": "FAQ",
      "info": "Centered shorter title on small screens. Home variant only."
    },
    {
      "type": "text",
      "id": "breadcrumb_parent_label",
      "label": "Parent breadcrumb label",
      "default": "Evamats",
      "info": "Page variant only."
    },
    {
      "type": "url",
      "id": "breadcrumb_parent_url",
      "label": "Parent breadcrumb URL",
      "info": "Page variant only. Leave empty for homepage."
    },
    {
      "type": "text",
      "id": "breadcrumb_current_label",
      "label": "Current breadcrumb label",
      "default": "FAQ",
      "info": "Page variant only."
    },
    {
      "type": "url",
      "id": "eyebrow_link",
      "label": "Eyebrow link",
      "info": "If set, eyebrow becomes a link. Home variant only."
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all button label",
      "default": "Zobacz wszystko",
      "info": "Home variant only."
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all button link",
      "info": "Home variant only."
    },
    {
      "type": "header",
      "content": "Section spacing (desktop)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section spacing (mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "label": "Category (optional)",
          "id": "category",
          "info": "Leave empty for top-level question. Same name = one dropdown with multiple questions inside."
        },
        {
          "type": "richtext",
          "label": "Question",
          "id": "hd",
          "default": "<p>What types of freight services do you offer?</p>"
        },
        {
          "type": "richtext",
          "label": "Answer",
          "id": "des",
          "default": "<p>At StyleCo Blinds, we understand your home is supposed to be a sanctuary for you. We specialize in designing blinds, drapery and shutters that are both beautiful and functional. We believe in sustainable design so we only use natural materials and recycled material where possible; which reduces our carbon footprint while creating a unique style that.</p>"
        },
        {
          "type": "html",
          "label": "Answer (HTML)",
          "id": "des_html",
          "info": "Optional. If filled, this HTML is shown instead of the Answer above. Use for links, lists, iframes, etc."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "home-faq",
      "category": "custom",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "hd": "<p>What types of freight services do you offer?</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
