{% javascript %}
  class StickyHeader extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.header = document.querySelector('.section-header');
      this.headerIsAlwaysSticky = this.getAttribute('data-sticky-type') === 'always' || this.getAttribute('data-sticky-type') === 'reduce-logo-size';
      this.headerBounds = {};

      this.setHeaderHeight();

      window.matchMedia('(max-width: 990px)').addEventListener('change', this.setHeaderHeight.bind(this));

      if (this.headerIsAlwaysSticky) {
        this.header.classList.add('shopify-section-header-sticky');
      };

      this.currentScrollTop = 0;
      this.preventReveal = false;
      this.predictiveSearch = this.querySelector('predictive-search');

      this.onScrollHandler = this.onScroll.bind(this);
      this.hideHeaderOnScrollUp = () => this.preventReveal = true;

      this.addEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.addEventListener('scroll', this.onScrollHandler, false);

      this.createObserver();
    }

    setHeaderHeight() {
      document.documentElement.style.setProperty('--header-height', `${this.header.offsetHeight}px`);
    }

    disconnectedCallback() {
      this.removeEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.removeEventListener('scroll', this.onScrollHandler);
    }

    createObserver() {
      let observer = new IntersectionObserver((entries, observer) => {
        this.headerBounds = entries[0].intersectionRect;
        observer.disconnect();
      });

      observer.observe(this.header);
    }

    onScroll() {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

      if (this.predictiveSearch && this.predictiveSearch.isOpen) return;

      if (scrollTop > this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        this.header.classList.add('scrolled-past-header');
        if (this.preventHide) return;
        requestAnimationFrame(this.hide.bind(this));
      } else if (scrollTop < this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        this.header.classList.add('scrolled-past-header');
        if (!this.preventReveal) {
          requestAnimationFrame(this.reveal.bind(this));
        } else {
          window.clearTimeout(this.isScrolling);

          this.isScrolling = setTimeout(() => {
            this.preventReveal = false;
          }, 66);

          requestAnimationFrame(this.hide.bind(this));
        }
      } else if (scrollTop <= this.headerBounds.top) {
        this.header.classList.remove('scrolled-past-header');
        requestAnimationFrame(this.reset.bind(this));
      }

      this.currentScrollTop = scrollTop;
    }

    hide() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.add('shopify-section-header-hidden', 'shopify-section-header-sticky');
      this.closeMenuDisclosure();
      this.closeSearchModal();
      this.closeEvamatsDrawer();
    }

    reveal() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.add('shopify-section-header-sticky', 'animate');
      this.header.classList.remove('shopify-section-header-hidden');
    }

    reset() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.remove('shopify-section-header-hidden', 'shopify-section-header-sticky', 'animate');
    }

    closeMenuDisclosure() {
      this.disclosures = this.disclosures || this.header.querySelectorAll('header-menu');
      this.disclosures.forEach(disclosure => disclosure.close());
    }

    closeSearchModal() {
      this.searchModal = this.searchModal || this.header.querySelector('details-modal');
      if (this.searchModal) this.searchModal.close(false);
    }

    closeEvamatsDrawer() {
      const drawer = this.querySelector('[data-evamats-header-drawer].is-open');
      if (!drawer) return;
      if (typeof drawer._evamatsCloseDrawer === 'function') {
        drawer._evamatsCloseDrawer();
      }
    }
  }

  customElements.define('sticky-header', StickyHeader);

  const initEvamatsHeaderDrawer = (root) => {
    const drawer = root.querySelector('[data-evamats-header-drawer]');
    if (!drawer || drawer.dataset.evamatsDrawerInit === 'true') return;
    drawer.dataset.evamatsDrawerInit = 'true';

    const viewStack = ['main'];
    const drawerTransitionMs = 280;

    const getView = (viewId) => drawer.querySelector(`[data-drawer-view="${viewId}"]`);

    const showViewInstant = (viewId) => {
      drawer.querySelectorAll('[data-drawer-view]').forEach((view) => {
        const isTarget = view.dataset.drawerView === viewId;
        view.hidden = !isTarget;
        view.classList.toggle('is-active', isTarget);
        view.classList.remove('is-exiting');
      });
      drawer.classList.toggle('is-sub-open', viewId !== 'main');
    };

    const animateToView = (viewId) => {
      const nextView = getView(viewId);
      const currentView = getView(viewStack[viewStack.length - 1]);
      if (!nextView || currentView === nextView) return;

      drawer.classList.toggle('is-sub-open', viewId !== 'main');

      nextView.hidden = false;
      nextView.classList.remove('is-active');
      void nextView.offsetWidth;
      nextView.classList.add('is-active');

      if (currentView) {
        currentView.classList.remove('is-active');
        currentView.hidden = true;
      }

      window.setTimeout(() => {
        drawer.querySelectorAll('[data-drawer-view]').forEach((view) => {
          if (view.dataset.drawerView === viewId) return;
          view.hidden = true;
          view.classList.remove('is-active');
        });
      }, drawerTransitionMs);
    };

    const openSubView = (viewId) => {
      animateToView(viewId);
      viewStack.push(viewId);
    };

    const goBack = () => {
      if (viewStack.length <= 1) return;

      const closingId = viewStack.pop();
      const prevId = viewStack[viewStack.length - 1];
      const closingView = getView(closingId);
      const prevView = getView(prevId);
      const goingToMain = prevId === 'main';

      drawer.querySelectorAll('[data-drawer-view]').forEach((view) => {
        if (view === closingView) return;
        view.hidden = true;
        view.classList.remove('is-active', 'is-exiting');
      });

      if (closingView) {
        closingView.hidden = false;
        closingView.classList.add('is-exiting');
        closingView.classList.remove('is-active');
        void closingView.offsetWidth;
      }

      window.setTimeout(() => {
        if (closingView) {
          closingView.hidden = true;
          closingView.classList.remove('is-exiting');
        }

        if (prevView) {
          prevView.hidden = false;
          prevView.classList.add('is-active');
        }

        drawer.classList.toggle('is-sub-open', !goingToMain);
      }, drawerTransitionMs);
    };

    const resetViews = () => {
      viewStack.length = 0;
      viewStack.push('main');
      showViewInstant('main');
    };

    const openDrawer = () => {
      if (drawer.classList.contains('is-closing')) return;

      drawer.classList.remove('is-closing');
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      document.body.classList.add('overflow-hidden');
      root.querySelectorAll('[data-evamats-drawer-open]').forEach((btn) => btn.setAttribute('aria-expanded', 'true'));
    };

    const closeDrawer = () => {
      if (!drawer.classList.contains('is-open') || drawer.classList.contains('is-closing')) return;

      drawer.classList.add('is-closing');
      drawer.classList.remove('is-open');

      root.querySelectorAll('[data-evamats-drawer-open]').forEach((btn) => btn.setAttribute('aria-expanded', 'false'));

      window.setTimeout(() => {
        drawer.classList.remove('is-closing', 'is-sub-open');
        drawer.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('overflow-hidden');
        resetViews();
      }, drawerTransitionMs);
    };

    drawer._evamatsCloseDrawer = closeDrawer;

    root.querySelectorAll('[data-evamats-drawer-open]').forEach((btn) => {
      btn.addEventListener('click', openDrawer);
    });

    drawer.querySelectorAll('[data-evamats-drawer-close]').forEach((btn) => {
      btn.addEventListener('click', closeDrawer);
    });

    drawer.querySelectorAll('[data-drawer-open-sub]').forEach((btn) => {
      btn.addEventListener('click', () => {
        openSubView(btn.dataset.drawerOpenSub);
      });
    });

    drawer.querySelectorAll('[data-drawer-back]').forEach((btn) => {
      btn.addEventListener('click', goBack);
    });

    document.addEventListener('keydown', (event) => {
      if (!drawer.classList.contains('is-open') || drawer.classList.contains('is-closing')) return;
      if (event.key === 'Escape') {
        if (viewStack.length > 1) {
          goBack();
        } else {
          closeDrawer();
        }
      }
    });
  };

  document.querySelectorAll('sticky-header, .header-wrapper').forEach(initEvamatsHeaderDrawer);

  const initEvamatsHeaderHoverMenus = (root) => {
    const header = root.querySelector('.evamats-header');
    if (!header || header.dataset.evamatsHoverMenusInit === 'true') return;
    header.dataset.evamatsHoverMenusInit = 'true';

    const desktopQuery = window.matchMedia('(min-width: 750px)');
    const menus = header.querySelectorAll('header-menu');
    const closeTimers = new WeakMap();

    const isDesktop = () => desktopQuery.matches;

    const setOpen = (menuEl, open) => {
      const details = menuEl.querySelector('details');
      const summary = details?.querySelector('summary');
      if (!details || !summary) return;

      if (open) {
        menus.forEach((other) => {
          if (other !== menuEl) setOpen(other, false);
        });
        details.setAttribute('open', '');
        summary.setAttribute('aria-expanded', 'true');
      } else {
        details.removeAttribute('open');
        summary.setAttribute('aria-expanded', 'false');
      }
    };

    const scheduleClose = (menuEl) => {
      clearTimeout(closeTimers.get(menuEl));
      closeTimers.set(
        menuEl,
        setTimeout(() => setOpen(menuEl, false), 120)
      );
    };

    const cancelClose = (menuEl) => {
      clearTimeout(closeTimers.get(menuEl));
    };

    menus.forEach((menuEl) => {
      const details = menuEl.querySelector('details');
      const summary = details?.querySelector('summary');
      if (!details || !summary) return;

      menuEl.addEventListener('mouseenter', () => {
        if (!isDesktop()) return;
        cancelClose(menuEl);
        setOpen(menuEl, true);
      });

      menuEl.addEventListener('mouseleave', () => {
        if (!isDesktop()) return;
        scheduleClose(menuEl);
      });

      summary.addEventListener('click', (event) => {
        if (!isDesktop()) return;
        event.preventDefault();
      });
    });

    desktopQuery.addEventListener('change', () => {
      menus.forEach((menuEl) => {
        cancelClose(menuEl);
        setOpen(menuEl, false);
      });
    });

    const catalogPanel = header.querySelector('.evamats-header__catalog-panel');
    if (catalogPanel) {
      catalogPanel.addEventListener('mousedown', (event) => {
        if (!isDesktop()) return;
        if (event.target.closest('a[href]')) return;
        event.preventDefault();
      });

      catalogPanel.querySelectorAll('[role="button"].evamats-header__catalog-l1-row, [role="button"].evamats-header__catalog-l2-row').forEach((row) => {
        row.addEventListener('click', (event) => {
          if (!isDesktop()) return;
          event.preventDefault();
        });
      });
    }
  };

  document.querySelectorAll('sticky-header, .header-wrapper').forEach(initEvamatsHeaderHoverMenus);
{% endjavascript %}

