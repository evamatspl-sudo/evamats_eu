{%- style -%}
  .section-header {
    position: sticky;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .evamats-header__logo {
      height: 52px;
    }
  {%- endif -%}

  {%- assign catalog_menu = section.settings.catalog_menu -%}
  {%- if catalog_menu != blank -%}
    {%- for link in catalog_menu.links -%}
      {%- if link.links != blank -%}
        .evamats-header__catalog-panel:has(.evamats-header__catalog-l1-item[data-catalog-flyout="{{ forloop.index }}"]:hover) .evamats-header__catalog-l2-slot[data-catalog-flyout="{{ forloop.index }}"],
        .evamats-header__catalog-panel:has(.evamats-header__catalog-l1-item[data-catalog-flyout="{{ forloop.index }}"]:focus-within) .evamats-header__catalog-l2-slot[data-catalog-flyout="{{ forloop.index }}"],
        .evamats-header__catalog-panel:has(.evamats-header__catalog-l2-slot[data-catalog-flyout="{{ forloop.index }}"]:hover) .evamats-header__catalog-l2-slot[data-catalog-flyout="{{ forloop.index }}"] {
          display: block;
        }

        .evamats-header__catalog-panel:has(.evamats-header__catalog-l2-slot[data-catalog-flyout="{{ forloop.index }}"]:hover) .evamats-header__catalog-l1-item[data-catalog-flyout="{{ forloop.index }}"] .evamats-header__catalog-l1-icon .evamats-header-drawer__catalog-icon--inline path,
        .evamats-header__catalog-panel:has(.evamats-header__catalog-l2-slot[data-catalog-flyout="{{ forloop.index }}"]:hover) .evamats-header__catalog-l1-item[data-catalog-flyout="{{ forloop.index }}"] .evamats-header__catalog-l1-icon .evamats-header-drawer__catalog-icon--inline svg path {
          fill: #ff2741;
        }

        .evamats-header__catalog-panel:has(.evamats-header__catalog-l2-slot[data-catalog-flyout="{{ forloop.index }}"]:hover) .evamats-header__catalog-l1-item[data-catalog-flyout="{{ forloop.index }}"] .evamats-header__catalog-l1-chevron {
          color: #ff2741;
        }

        .evamats-header__catalog-panel:has(.evamats-header__catalog-l2-slot[data-catalog-flyout="{{ forloop.index }}"]:hover) .evamats-header__catalog-l1-item[data-catalog-flyout="{{ forloop.index }}"] .evamats-header__catalog-l1-icon img {
          filter: brightness(0) saturate(100%) invert(27%) sepia(89%) saturate(7492%) hue-rotate(337deg) brightness(101%) contrast(101%);
        }

        .evamats-header__catalog-panel:has(.evamats-header__catalog-l2-slot[data-catalog-flyout="{{ forloop.index }}"]:hover) .evamats-header__catalog-l1-item[data-catalog-flyout="{{ forloop.index }}"] .evamats-header__catalog-l1-icon .evamats-header-drawer__catalog-icon--default {
          color: #ff2741;
        }
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endstyle -%}


