{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
{{ 'section-evamats-cart.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

<cart-items class="evamats-cart{% if cart == empty %} is-empty{% endif %}">
  {%- unless cart == empty -%}
    {% render 'drawer_progress', section_id: section.id, part: 'upsell' %}
  {%- endunless -%}

  <div class="evamats-cart__main page-width{% unless cart == empty %} section-{{ section.id }}-padding{% endunless %}">
    {% comment %} <div class="title-wrapper-with-link">
      <h1 class="title title--primary">{{ 'sections.cart.title' | t }}</h1>
      <a href="/collections/all-car-mats" class="underlined-link">{{ 'general.continue_shopping' | t }}</a>
    </div> {% endcomment %}

    <div class="cart__warnings">
      <h1 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h1>
      <a href="/collections/all-car-mats" class="button">
        {{ 'general.continue_shopping' | t }}
      </a>

      {%- if shop.customer_accounts_enabled and customer == null -%}
        <h2 class="cart__login-title">{{ 'sections.cart.login.title' | t }}</h2>
        <p class="cart__login-paragraph">
          {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
        </p>
      {%- endif -%}
    </div>

    {%- if cart != empty -%}
      <div class="evamats-cart__body">
        <div class="evamats-cart__body-inner">
          <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">
            <div class="cart__items" id="main-cart-items" data-id="{{ section.id }}">
              <div class="js-contents evamats-cart__layout">
                <div class="evamats-cart__col-main">
                  {% render 'drawer_progress', section_id: section.id, part: 'gift' %}
                  <div class="evamats-cart__surface">
                    <div class="evamats-cart-items" role="list" aria-label="{{ 'sections.cart.caption' | t }}">
                      {%- for item in cart.items -%}
                        {% render 'evamats-cart-item', item: item, line_index: item.index | plus: 1, section_id: section.id %}
                      {%- endfor -%}
                    </div>
                  </div>
                </div>

                {% render 'evamats-cart-sidebar', section_id: section.id %}
              </div>
            </div>

            <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
            <p class="visually-hidden" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </form>
        </div>
      </div>
    {%- endif -%}
  </div>
</cart-items>

{%- if cart != empty -%}
  <div class="sticky_container">
    <button type="button" class="sticky_add_to_cart button" aria-label="{{ 'sections.cart.checkout' | t }}">
      {% render 'icon-cart' %}
    </button>
  </div>

  <script>
    window.initEvamatsCartReservationTimer = function () {
      var countdownElement = document.getElementById('countdown-timer');
      var extendButton = document.getElementById('extend-button');
      if (!countdownElement) return;

      if (window.__evamatsCartTimerInterval) {
        clearInterval(window.__evamatsCartTimerInterval);
        window.__evamatsCartTimerInterval = null;
      }

      var reservationDuration = 10 * 60;
      var remainingTime;

      if (localStorage.getItem('remainingTime')) {
        remainingTime = parseInt(localStorage.getItem('remainingTime'), 10);
      } else {
        remainingTime = reservationDuration;
        localStorage.setItem('remainingTime', remainingTime);
      }

      function updateCountdown() {
        var minutes = Math.floor(remainingTime / 60);
        var seconds = remainingTime % 60;
        countdownElement.textContent = minutes + ':' + (seconds < 10 ? '0' : '') + seconds;

        if (remainingTime > 0) {
          remainingTime--;
          localStorage.setItem('remainingTime', remainingTime);
        } else {
          clearInterval(window.__evamatsCartTimerInterval);
          window.__evamatsCartTimerInterval = null;
          countdownElement.textContent = '00:00';
          if (extendButton) extendButton.style.display = 'inline-block';
          localStorage.removeItem('remainingTime');
        }
      }

      function startTimer(duration) {
        remainingTime = duration;
        localStorage.setItem('remainingTime', remainingTime);
        updateCountdown();
        if (extendButton) extendButton.style.display = 'none';
        window.__evamatsCartTimerInterval = setInterval(updateCountdown, 1000);
      }

      if (extendButton && !extendButton.dataset.bound) {
        extendButton.dataset.bound = 'true';
        extendButton.addEventListener('click', function (e) {
          e.preventDefault();
          startTimer(reservationDuration);
        });
      }

      updateCountdown();
      window.__evamatsCartTimerInterval = setInterval(updateCountdown, 1000);
    };

    document.addEventListener('click', function (event) {
      var clearBtn = event.target.closest('[data-clear-cart]');
      if (!clearBtn) return;
      event.preventDefault();
      fetch(window.routes.cart_url + '/clear.js', { method: 'POST' })
        .then(function () {
          sessionStorage.removeItem('evamatsCartTermsAccepted');
          window.location.reload();
        })
        .catch(function (err) {
          console.error(err);
        });
    });

    document.addEventListener('DOMContentLoaded', function () {
      window.initEvamatsCartReservationTimer();
      if (window.initEvamatsCartSidebarControls) {
        window.initEvamatsCartSidebarControls();
      }
    });
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}

