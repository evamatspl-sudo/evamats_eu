{%- liquid
  assign card_count = 0
  for block in section.blocks
    if block.type == 'card'
      assign card_count = card_count | plus: 1
    endif
  endfor

  assign cta_url = section.settings.cta_url
  if cta_url == blank
    assign cta_url = '#'
  endif

  assign hover_label = section.settings.card_cta_label
  if hover_label == blank
    assign hover_label = section.settings.mobile_cta_label
  endif
-%}

<div
  id="PartnersAudience-{{ section.id }}"
  class="partners-audience-v2"
  aria-label="{{ section.settings.heading | escape }}"
>
  <div class="partners-audience-v2__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="partners-audience-v2__heading section_title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if card_count > 0 -%}
      <ul class="partners-audience-v2__grid" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'card' -%}
            <li class="partners-audience-v2__item" {{ block.shopify_attributes }}>
              <a
                class="partners-audience-v2__card"
                href="{{ cta_url }}"
                {% if section.settings.cta_url == blank %}
                  aria-disabled="true"
                  tabindex="-1"
                {% endif %}
              >
                {%- if block.settings.image != blank -%}
                  <div class="partners-audience-v2__media" aria-hidden="true">
                    {{
                      block.settings.image
                      | image_url: width: 800
                      | image_tag:
                        loading: 'lazy',
                        class: 'partners-audience-v2__media-img',
                        widths: '163, 305, 610, 800',
                        sizes: '(min-width: 750px) 305px, 163px'
                    }}
                  </div>
                {%- endif -%}

                <div class="partners-audience-v2__copy">
                  {%- if block.settings.title != blank -%}
                    <h3 class="partners-audience-v2__title">{{ block.settings.title | escape }}</h3>
                  {%- endif -%}

                  {%- if block.settings.text != blank -%}
                    <p class="partners-audience-v2__text">{{ block.settings.text | escape }}</p>
                  {%- endif -%}
                </div>

                {%- if hover_label != blank -%}
                  <span class="partners-audience-v2__card-cta button button_3" aria-hidden="true">
                    {{ hover_label | escape }}
                  </span>
                {%- endif -%}
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.promo_title != blank or section.settings.promo_text != blank -%}
      <div class="partners-audience-v2__promo">
        {%- if section.settings.promo_title != blank -%}
          <p class="partners-audience-v2__promo-title">{{ section.settings.promo_title | escape }}</p>
        {%- endif -%}
        {%- if section.settings.promo_text != blank -%}
          <p class="partners-audience-v2__promo-text">{{ section.settings.promo_text | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.mobile_cta_label != blank -%}
      <div class="partners-audience-v2__footer-cta">
        <a
          class="button button_3 partners-audience-v2__footer-btn"
          href="{{ cta_url }}"
          {% if section.settings.cta_url == blank %}
            aria-disabled="true"
            tabindex="-1"
          {% endif %}
        >
          {{ section.settings.mobile_cta_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% comment %} styles moved to assets/base_v2.css (stylesheet) {% endcomment %}

{% schema %}
{
  "name": "Partners audience",
  "tag": "section",
  "class": "section-partners-audience-v2",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dla kogo jest ta współpraca?"
    },
    {
      "type": "header",
      "content": "Link i przyciski"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL linku",
      "info": "Desktop: klik w kartę. Mobile: przycisk pod kartami. Ten sam adres."
    },
    {
      "type": "text",
      "id": "card_cta_label",
      "label": "Card hover button (desktop)",
      "default": "Wyślij zapytanie"
    },
    {
      "type": "text",
      "id": "mobile_cta_label",
      "label": "Mobile button",
      "default": "Wyślij zapytanie"
    },
    {
      "type": "header",
      "content": "Promo strip (below cards)"
    },
    {
      "type": "text",
      "id": "promo_title",
      "label": "Promo title",
      "default": "Chcesz rozpocząć własny biznes?"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Promo text",
      "default": "Zacznij sprzedaż bez własnej produkcji"
    } 
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Audience card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Card title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Card description."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partners audience",
      "category": "V2",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Ręczne wykonanie",
            "text": "Tworzysz produkty z dbałością o każdy detal? Nasze dywaniki EVA to idealne uzupełnienie Twojej oferty — łatwe w dopasowaniu, trwałe i estetyczne."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Dealerzy samochodowi",
            "text": "Zwiększ wartość każdego auta przy sprzedaży. Dywaniki EVA to praktyczny dodatek, który robi świetne pierwsze wrażenie i podnosi atrakcyjność oferty."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "E-commerce",
            "text": "Szukasz produktu, który dobrze się sprzedaje online? Dywaniki EVA są lekkie, łatwe w wysyłce i dostępne w wielu wariantach — idealne do skalowania sprzedaży."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Studia detailingu",
            "text": "Podnieś standard swoich usług. Dywaniki EVA to perfekcyjne wykończenie po detailingu — czystość, trwałość i efekt „jak nowe auto”."
          }
        }
      ]
    }
  ]
}
{% endschema %}
