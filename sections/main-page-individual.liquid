{%- liquid
  assign parent_label = section.settings.parent_label | strip
  if parent_label == blank
    assign parent_label = 'Carvion'
  endif

  assign parent_url = section.settings.parent_url | strip
  if parent_url == blank
    assign parent_url = routes.root_url
  endif

  assign current_label = section.settings.current_label | strip
  if current_label == blank and page != blank
    assign current_label = page.title
  endif
-%}

<div
  id="EvamatsIndividualOrder-{{ section.id }}"
  class="evamats-individual-order"
>
  <div class="evamats-individual-order__inner page-width">
    {% render 'evamats-breadcrumbs',
      parent_label: parent_label,
      parent_url: parent_url,
      current_label: current_label,
      class: 'evamats-individual-order__breadcrumbs'
    %}

    <div class="evamats-individual-order__intro">
      <h1 class="evamats-individual-order__heading section_title">
        {{ 'general.config.custom_order_title' | t }}
      </h1>
      <p class="evamats-individual-order__subtitle">
        {{ 'general.config.custom_order_subtitle' | t }}
      </p>
    </div>
  </div>
</div>

{% stylesheet %}
  .evamats-individual-order {
    --eio-pt: 48px;
    --eio-pb: 32px;
    padding-top: var(--eio-pt);
    padding-bottom: var(--eio-pb);
    background: #fff;
    color: #1b1d22;
  }

  .evamats-individual-order__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .evamats-individual-order__breadcrumbs {
    align-self: flex-start;
    width: 100%;
    margin-bottom: 32px;
  }

  .evamats-individual-order__intro {
    max-width: 42rem;
    margin: 0 auto;
  }

  .evamats-individual-order__heading {
    margin: 0 auto 16px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    background: linear-gradient(90deg, #1b1d22 50.962%, #ff2741 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  .evamats-individual-order__subtitle {
    margin: 0;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: -0.02em;
    color: #1b1d22;
  }

  @media screen and (max-width: 749px) {
    .evamats-individual-order {
      --eio-pt: 28px;
      --eio-pb: 24px;
    }

    .evamats-individual-order__breadcrumbs {
      margin-bottom: 24px;
    }

    .evamats-individual-order__heading {
      max-width: none;
    }

    .evamats-individual-order__subtitle {
      font-size: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Individual order intro",
  "tag": "section",
  "class": "section section-evamats-individual-order",
  "settings": [
    {
      "type": "text",
      "id": "parent_label",
      "label": "Breadcrumb — parent",
      "default": "Carvion"
    },
    {
      "type": "url",
      "id": "parent_url",
      "label": "Breadcrumb — parent link",
      "info": "Leave empty for homepage."
    },
    {
      "type": "text",
      "id": "current_label",
      "label": "Breadcrumb — current page",
      "info": "Leave empty to use page title."
    }
  ]
}
{% endschema %}
