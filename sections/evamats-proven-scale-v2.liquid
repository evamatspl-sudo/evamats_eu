{%- liquid
  assign desktop_image = section.settings.image_desktop
  assign mobile_image = section.settings.image_mobile
  if mobile_image == blank
    assign mobile_image = desktop_image
  endif
-%}

{{ 'section-evamats-proven-scale-v2.css' | asset_url | stylesheet_tag }}
{% render 'evamats-section-padding-style', section: section, target: '.evamats-proven-scale-v2' %}
<div
  id="EvamatsProvenScale-{{ section.id }}"
  class="evamats-proven-scale-v2"
>
  <div class="evamats-proven-scale-v2__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="evamats-proven-scale-v2__heading section_title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.intro != blank -%}
      <p class="evamats-proven-scale-v2__intro evamats-proven-scale-v2__intro--mobile">{{ section.settings.intro | escape }}</p>
    {%- endif -%}

    <div class="evamats-proven-scale-v2__hero">
      {%- if desktop_image != blank -%}
        <div class="evamats-proven-scale-v2__media" aria-hidden="true">
          <picture>
            {%- if section.settings.image_mobile != blank -%}
              <source media="(max-width: 749px)" srcset="{{ mobile_image | image_url: width: 800 }}">
            {%- elsif mobile_image != blank -%}
              <source media="(max-width: 749px)" srcset="{{ mobile_image | image_url: width: 800 }}">
            {%- endif -%}
            {{
              desktop_image
              | image_url: width: 3040
              | image_tag:
                loading: 'lazy',
                class: 'evamats-proven-scale-v2__media-img',
                widths: '375, 750, 1100, 1500, 2000, 3040',
                sizes: '(min-width: 990px) 1520px, (min-width: 750px) 100vw, 100vw'
            }}
          </picture>
          <div class="evamats-proven-scale-v2__fade evamats-proven-scale-v2__fade--top"></div>
          <div class="evamats-proven-scale-v2__fade evamats-proven-scale-v2__fade--bottom"></div>
        </div>
      {%- endif -%}

      {%- if section.settings.intro != blank -%}
        <p class="evamats-proven-scale-v2__intro evamats-proven-scale-v2__intro--desktop">{{ section.settings.intro | escape }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="evamats-proven-scale-v2__stats" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              {%- liquid
                if block.settings.use_orders_counter
                  assign stat_value = shop.metafields.custom.orders_counter
                else
                  assign stat_value = block.settings.value
                endif
              -%}
              <li class="evamats-proven-scale-v2__stat" {{ block.shopify_attributes }}>
                {%- if stat_value != blank -%}
                  <p class="evamats-proven-scale-v2__stat-value">
                    <span class="evamats-proven-scale-v2__stat-number">{{ stat_value | escape }}</span>
                    {%- if block.settings.show_plus -%}
                      <span class="evamats-proven-scale-v2__stat-plus" aria-hidden="true">+</span>
                    {%- endif -%}
                  </p>
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <p class="evamats-proven-scale-v2__stat-label">{{ block.settings.label | escape }}</p>
                {%- endif -%}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</div>

{% comment %} styles in assets/section-evamats-proven-scale-v2.css {% endcomment %}

{% schema %}
{
  "name": "Carvion proven scale v2",
  "tag": "section",
  "class": "section-evamats-proven-scale-v2",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sprawdzony produkt, gotowy do skalowania"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro text",
      "default": "Produkt jest sprawdzony na rynku i gotowy do rozwoju w modelu B2B."
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Hero image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Hero image (mobile)",
      "info": "Optional. Uses desktop image when empty."
    },
    {
      "type": "header",
      "content": "Section spacing (desktop)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Section spacing (mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "checkbox",
          "id": "use_orders_counter",
          "label": "Use orders counter metafield",
          "info": "Uses shop.metafields.custom.orders_counter instead of Value field.",
          "default": false
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "3 082"
        },
        {
          "type": "checkbox",
          "id": "show_plus",
          "label": "Show plus sign",
          "default": true
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Spokojených zákazníků"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Carvion proven scale v2",
      "category": "V2",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "3 082",
            "show_plus": true,
            "label": "Spokojených zákazníků"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "1567",
            "show_plus": true,
            "label": "Dostupných modelů aut"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "56 732",
            "show_plus": true,
            "label": "Zrealizowane komplety"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "27",
            "show_plus": true,
            "label": "Doručení do více než 27 zemí"
          }
        }
      ]
    }
  ]
}
{% endschema %}
