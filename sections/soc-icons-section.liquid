    },
    {
      "type":"image_picker",
      "label":"Social network icon #2",
      "id":"img2"
    },
    {
  "type": "url",
  "id": "button_link2",
  "label": "Social media links #2"
  },
    {
      "type":"richtext",
      "label":"Social network name #3",
      "id":"des3",
