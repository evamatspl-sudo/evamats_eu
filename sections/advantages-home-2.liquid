<section>
            <div class="first-main">
                <div class="row">
                    <div class="col-lg-4">
                        <div class="first-column">
                            <img src="{{ section.settings.img1|img_url:'master' }}" alt="">
                            {{ section.settings.des1 }}
                        </div>

                    </div>
                    <div class="col-lg-4">
                        <div class="first-column">
                            <img src="{{ section.settings.img2|img_url:'master' }}" alt="">
                            {{ section.settings.des2 }}
                        </div>

                    </div>
                    <div class="col-lg-4">
                        <div class="first-column">
                            <img src="{{ section.settings.img3|img_url:'master' }}" alt="">
                            {{ section.settings.des3 }}
                        </div>
                    </div>
                </div>
            </div>
        </section>
<style>
.first-main {
    margin-top: 0;
    box-shadow: unset;
    background: #000101;
}
  .first-main .row .col-lg-4 .first-column img {
    width: 50px;
    height: 50px;
    object-fit: contain;
}
  .first-main .row .col-lg-4 .first-column p{
    font-weight: 600;
    width: 70%;
  }
  @media screen and (min-width: 992px){
     .col-lg-4 {
    justify-content: center;
    display: flex;
    align-items: center;
}
  }
 @media screen and (min-width: 990px){
.first-main .row {
    max-width: var(--page-width);
    padding: 0.8rem 5rem 0;
  
}
  .first-main{
    display: flex;
    justify-content: center;
  }
  }
  </style>
{% schema %}
{
  "name": "Advantages (home2)",
  "settings": [
    {
      "type":"image_picker",
      "label":"Image",
      "id":"img1"
    },
    {
      "type":"richtext",
      "label":"Image Text",
      "id":"des1",
      "default":"<p>Don't lose <br> appearance over time</p>"
    },
    {
      "type":"image_picker",
      "label":"Image",
      "id":"img2"
    },
    {
      "type":"richtext",
      "label":"Image Text",
      "id":"des2",
      "default":"<p>Resistant to <br> temperature changes</p>"
    },
    {
      "type":"image_picker",
      "label":"Image",
      "id":"img3"
    },
    {
      "type":"richtext",
      "label":"Image Text",
      "id":"des3",
      "default":" <p>Resistant to <br> chemicals</p>"
    }
  ],
  "presets":[
    {
      "name":"Advantages (home2)",
      "category":"custom"
    }
  ]
}
{% endschema %}

