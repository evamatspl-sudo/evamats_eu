{%- liquid
  assign card_count = 0
  for block in section.blocks
    if block.type == 'card'
      assign card_count = card_count | plus: 1
    endif
  endfor
-%}

{% render 'evamats-section-padding-style', section: section, target: '.evamats-partners-coop-v2' %}
<div
  id="EvamatsPartnersCoop-{{ section.id }}"
  class="evamats-partners-coop-v2"
>
  {%- liquid
    assign bg_image_top_right = section.settings.bg_image_top_right
    if bg_image_top_right == blank
      assign bg_image_top_right = section.settings.decor_image
    endif
    assign bg_image_bottom_left = section.settings.bg_image_bottom_left
  -%}
  {%- if bg_image_top_right != blank or bg_image_bottom_left != blank -%}
    <div class="evamats-partners-coop-v2__bg" aria-hidden="true">
      {%- if bg_image_top_right != blank -%}
        <div class="evamats-partners-coop-v2__bg-piece evamats-partners-coop-v2__bg-piece--tr">
          {{
            bg_image_top_right
            | image_url: width: 1420
            | image_tag:
              loading: 'lazy',
              class: 'evamats-partners-coop-v2__bg-img',
              widths: '290, 580, 710, 1420',
              sizes: '(min-width: 750px) 709px, 291px'
          }}
        </div>
      {%- endif -%}
      {%- if bg_image_bottom_left != blank -%}
        <div class="evamats-partners-coop-v2__bg-piece evamats-partners-coop-v2__bg-piece--bl">
          {{
            bg_image_bottom_left
            | image_url: width: 1420
            | image_tag:
              loading: 'lazy',
              class: 'evamats-partners-coop-v2__bg-img',
              widths: '290, 580, 710, 1420',
              sizes: '(min-width: 750px) 709px, 291px'
          }}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="evamats-partners-coop-v2__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="evamats-partners-coop-v2__heading section_title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if card_count > 0 -%}
      <ul class="evamats-partners-coop-v2__grid" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'card' -%}
            {%- liquid
              assign card_variant = block.settings.card_variant | default: 'dropshipping'
              assign card_class = 'evamats-partners-coop-v2__card evamats-partners-coop-v2__card--' | append: card_variant
            -%}
            <li class="evamats-partners-coop-v2__item" {{ block.shopify_attributes }}>
              <article class="{{ card_class }}">
                <div class="evamats-partners-coop-v2__card-head">
                    <p class="evamats-partners-coop-v2__label">{{ block.settings.label | escape }}</p>
                    <p class="evamats-partners-coop-v2__subtitle">{{ block.settings.subtitle | escape }}</p>
                  {%- if block.settings.title != blank -%}
                    <div class="evamats-partners-coop-v2__title">
                      {%- assign title_lines = block.settings.title | newline_to_br | split: '<br />' -%}
                      {%- for line in title_lines -%}
                        {%- if line != blank -%}
                          <p>{{ line }}</p>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>

                <ul class="evamats-partners-coop-v2__features" role="list">
                  {%- for i in (1..4) -%}
                    {%- assign feature_text_key = 'feature_' | append: i | append: '_text' -%}
                    {%- assign feature_icon_key = 'feature_' | append: i | append: '_icon' -%}
                    {%- assign feature_text = block.settings[feature_text_key] -%}
                    {%- assign feature_icon = block.settings[feature_icon_key] -%}
                    {%- if feature_text != blank -%}
                      {%- liquid
                        assign feature_icon_asset = ''
                        if card_variant == 'dropshipping'
                          case i
                            when 1
                              assign feature_icon_asset = 'partners-coop-icon-01.svg'
                            when 2
                              assign feature_icon_asset = 'partners-coop-icon-02.svg'
                            when 3
                              assign feature_icon_asset = 'partners-coop-icon-03.svg'
                            when 4
                              assign feature_icon_asset = 'partners-coop-icon-04.svg'
                          endcase
                        elsif card_variant == 'partner'
                          case i
                            when 1
                              assign feature_icon_asset = 'partners-coop-icon-05.svg'
                            when 2
                              assign feature_icon_asset = 'partners-coop-icon-06.svg'
                            when 3
                              assign feature_icon_asset = 'partners-coop-icon-07.svg'
                            when 4
                              assign feature_icon_asset = 'partners-coop-icon-08.svg'
                          endcase
                        elsif card_variant == 'support'
                          case i
                            when 1
                              assign feature_icon_asset = 'partners-coop-icon-03.svg'
                            when 2
                              assign feature_icon_asset = 'partners-coop-icon-10.svg'
                            when 3
                              assign feature_icon_asset = 'partners-coop-icon-11.svg'
                            when 4
                              assign feature_icon_asset = 'partners-coop-icon-12.svg'
                          endcase
                        endif
                      -%}
                      <li class="evamats-partners-coop-v2__feature">
                        {%- if feature_icon != blank or feature_icon_asset != '' -%}
                          <span class="evamats-partners-coop-v2__feature-icon" aria-hidden="true">
                            {%- if feature_icon != blank -%}
                              {{
                                feature_icon
                                | image_url: width: 60
                                | image_tag:
                                  loading: 'lazy',
                                  class: 'evamats-partners-coop-v2__feature-icon-img',
                                  alt: '',
                                  widths: '24, 30, 60',
                                  sizes: '(min-width: 750px) 30px, 24px'
                              }}
                            {%- else -%}
                              <img
                                src="{{ feature_icon_asset | asset_url }}"
                                alt=""
                                class="evamats-partners-coop-v2__feature-icon-img"
                                width="30"
                                height="30"
                                loading="lazy"
                              >
                            {%- endif -%}
                          </span>
                        {%- endif -%}
                        <span class="evamats-partners-coop-v2__feature-text">{{ feature_text | escape }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              </article>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% comment %} styles moved to assets/base.css (stylesheet) {% endcomment %}

{% schema %}
{
  "name": "Partners coop models",
  "tag": "section",
  "class": "section-evamats-partners-coop-v2",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Jak vypadá spolupráce s Carvion?"
