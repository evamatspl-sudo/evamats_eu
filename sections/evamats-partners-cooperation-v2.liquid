    {
      "type": "header",
      "content": "Background images"
    },
    {
      "type": "image_picker",
      "id": "bg_image_top_right",
      "label": "Background image (top right)"
    },
    {
      "type": "image_picker",
      "id": "bg_image_bottom_left",
      "label": "Background image (bottom left)"
    },
    {
      "type": "header",
      "content": "Section spacing (desktop)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
