        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle (below label)"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Title (money/result block)",
          "default": "Card title"
        },
        {
          "type": "header",
          "content": "Feature 1"
        },
        {
          "type": "image_picker",
          "id": "feature_1_icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "feature_1_text",
          "label": "Text"
        },
        {
          "type": "header",
          "content": "Feature 2"
        },
        {
          "type": "image_picker",
          "id": "feature_2_icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "feature_2_text",
          "label": "Text"
        },
        {
          "type": "header",
          "content": "Feature 3"
        },
        {
          "type": "image_picker",
          "id": "feature_3_icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "feature_3_text",
          "label": "Text"
        },
        {
          "type": "header",
          "content": "Feature 4"
        },
        {
          "type": "image_picker",
          "id": "feature_4_icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "feature_4_text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partners coop models",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "card_variant": "dropshipping",
            "label": "Model bez inwestycji (dropshipping / afiliacja)",
            "subtitle": "Prodáváte — my vyrábíme a odesíláme",
            "title": "Zarób nawet 2000 zł tygodniowo przy 10 zamówieniach",
