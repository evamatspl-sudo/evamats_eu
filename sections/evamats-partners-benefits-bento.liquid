{% render 'evamats-section-padding-style', section: section, target: '.evamats-kariera-benefits' %}
<div
  id="EvamatsKarieraBenefits-{{ section.id }}"
  class="evamats-kariera-benefits"
>
  <div class="evamats-kariera-benefits__inner page-width">
    {%- if section.settings.overline != blank or section.settings.heading != blank -%}
      <div class="evamats-kariera-benefits__intro">
        {%- if section.settings.overline != blank -%}
          <p class="evamats-kariera-benefits__overline">{{ section.settings.overline | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="evamats-kariera-benefits__heading section_title">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="evamats-kariera-benefits__grid">
      {%- for block in section.blocks -%}

        {%- if block.type == 'panel_left' -%}
          {%- assign ekb_ct = block.settings.content_type | default: 'list' -%}
          <article class="evamats-kariera-benefits__panel evamats-kariera-benefits__panel--a{% if ekb_ct == 'text' %} evamats-kariera-benefits__panel--text-only{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="evamats-kariera-benefits__panel-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}

            {%- if ekb_ct == 'list' -%}
              {%- assign ekb_has_items = false -%}
              {%- for ekb_i in (1..5) -%}
                {%- assign ekb_tk = 'item_' | append: ekb_i | append: '_text' -%}
                {%- if block.settings[ekb_tk] != blank -%}{%- assign ekb_has_items = true -%}{%- endif -%}
              {%- endfor -%}
              {%- if ekb_has_items -%}
                <ul class="evamats-kariera-benefits__list" role="list">
                  {%- for ekb_i in (1..5) -%}
                    {%- assign ekb_tk = 'item_' | append: ekb_i | append: '_text' -%}
                    {%- assign ekb_ik = 'item_' | append: ekb_i | append: '_icon' -%}
                    {%- assign ekb_tv = block.settings[ekb_tk] -%}
                    {%- assign ekb_iv = block.settings[ekb_ik] -%}
                    {%- if ekb_tv != blank -%}
                      <li class="evamats-kariera-benefits__row">
                        {%- if ekb_iv != blank -%}
                          {%- assign ekb_uid = block.id | append: '-a-' | append: ekb_i -%}
                          <span class="evamats-kariera-benefits__row-icon" aria-hidden="true">
                            {% render 'evamats-benefit-icon', icon: ekb_iv, uid: ekb_uid %}
                          </span>
                        {%- endif -%}
                        <span class="evamats-kariera-benefits__row-text">{{ ekb_tv | escape }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            {%- else -%}
              {%- if block.settings.description != blank -%}
                <p class="evamats-kariera-benefits__description">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            {%- endif -%}

            {%- if block.settings.image != blank -%}
              <div class="evamats-kariera-benefits__panel-media evamats-kariera-benefits__panel-media--a">
                {{
                  block.settings.image
                  | image_url: width: 900
                  | image_tag:
                    loading: 'lazy',
                    class: 'evamats-kariera-benefits__panel-img'
                }}
                {%- if block.settings.badge_label != blank or block.settings.badge_value != blank -%}
                  <div class="evamats-kariera-benefits__margin-badge">
                    {%- if block.settings.badge_value != blank -%}
                      <span class="evamats-kariera-benefits__margin-badge-value">{{ block.settings.badge_value | escape }}</span>
                    {%- endif -%}
                    {%- if block.settings.badge_label != blank -%}
                      <span class="evamats-kariera-benefits__margin-badge-label">{{ block.settings.badge_label | escape }}</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </article>

        {%- elsif block.type == 'panel_center' -%}
          {%- assign ekb_ct = block.settings.content_type | default: 'logo' -%}
          <article class="evamats-kariera-benefits__panel evamats-kariera-benefits__panel--b{% if ekb_ct == 'logo' %} evamats-kariera-benefits__panel--logo{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="evamats-kariera-benefits__panel-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}

            {%- if ekb_ct == 'logo' -%}
              <div class="evamats-kariera-benefits__culture-foot">
                {%- if settings.logo != blank -%}
                  <div class="evamats-kariera-benefits__culture-logo">
                    {{
                      settings.logo
                      | image_url: width: 206
                      | image_tag:
                        loading: 'lazy',
                        class: 'evamats-kariera-benefits__culture-logo-img',
                        widths: '88, 103, 206',
                        sizes: '(min-width: 750px) 103px, 88px'
                    }}
                  </div>
                {%- endif -%}
                {%- if block.settings.tagline != blank -%}
                  <p class="evamats-kariera-benefits__culture-tagline">{{ block.settings.tagline | escape }}</p>
                {%- endif -%}
              </div>

            {%- elsif ekb_ct == 'text' -%}
              {%- if block.settings.description != blank -%}
                <p class="evamats-kariera-benefits__description evamats-kariera-benefits__description--b">{{ block.settings.description | escape }}</p>
              {%- endif -%}
              <div class="evamats-kariera-benefits__panel-b-foot">
                {% render 'evamats-trust-badge',
                  badge_text: block.settings.badge_text,
                  badge_faces_image: block.settings.badge_faces_image
                %}
              </div>
              {%- if block.settings.image != blank -%}
                <div class="evamats-kariera-benefits__panel-media evamats-kariera-benefits__panel-media--b" aria-hidden="true">
                  {{
                    block.settings.image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      class: 'evamats-kariera-benefits__panel-img evamats-kariera-benefits__panel-img--b'
                  }}
                </div>
              {%- endif -%}

            {%- elsif ekb_ct == 'list' -%}
              {%- assign ekb_has_items = false -%}
              {%- for ekb_i in (1..5) -%}
                {%- assign ekb_tk = 'item_' | append: ekb_i | append: '_text' -%}
                {%- if block.settings[ekb_tk] != blank -%}{%- assign ekb_has_items = true -%}{%- endif -%}
              {%- endfor -%}
              {%- if ekb_has_items -%}
                <ul class="evamats-kariera-benefits__list" role="list">
                  {%- for ekb_i in (1..5) -%}
                    {%- assign ekb_tk = 'item_' | append: ekb_i | append: '_text' -%}
                    {%- assign ekb_ik = 'item_' | append: ekb_i | append: '_icon' -%}
                    {%- assign ekb_tv = block.settings[ekb_tk] -%}
                    {%- assign ekb_iv = block.settings[ekb_ik] -%}
                    {%- if ekb_tv != blank -%}
                      <li class="evamats-kariera-benefits__row">
                        {%- if ekb_iv != blank -%}
                          {%- assign ekb_uid = block.id | append: '-b-' | append: ekb_i -%}
                          <span class="evamats-kariera-benefits__row-icon" aria-hidden="true">
                            {% render 'evamats-benefit-icon', icon: ekb_iv, uid: ekb_uid %}
                          </span>
                        {%- endif -%}
                        <span class="evamats-kariera-benefits__row-text">{{ ekb_tv | escape }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            {%- endif -%}
          </article>

        {%- elsif block.type == 'panel_right' -%}
          {%- assign ekb_ct = block.settings.content_type | default: 'list' -%}
          <article class="evamats-kariera-benefits__panel evamats-kariera-benefits__panel--c{% if ekb_ct == 'list' %} evamats-kariera-benefits__panel--has-list{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.bg_image != blank -%}
              <div class="evamats-kariera-benefits__panel-bg" aria-hidden="true">
                {{
                  block.settings.bg_image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    class: 'evamats-kariera-benefits__panel-bg-img'
                }}
              </div>
            {%- endif -%}

            <div class="evamats-kariera-benefits__panel-c-inner{% if block.settings.bg_image != blank and block.settings.show_bg_overlay %} has-overlay{% endif %}">
              {%- if block.settings.title != blank -%}
                <h3 class="evamats-kariera-benefits__panel-title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}

              {%- if ekb_ct == 'list' -%}
                {%- assign ekb_has_items = false -%}
                {%- for ekb_i in (1..5) -%}
                  {%- assign ekb_tk = 'item_' | append: ekb_i | append: '_text' -%}
                  {%- if block.settings[ekb_tk] != blank -%}{%- assign ekb_has_items = true -%}{%- endif -%}
                {%- endfor -%}
                {%- if ekb_has_items -%}
                  <ul class="evamats-kariera-benefits__list" role="list">
                    {%- for ekb_i in (1..5) -%}
                      {%- assign ekb_tk = 'item_' | append: ekb_i | append: '_text' -%}
                      {%- assign ekb_ik = 'item_' | append: ekb_i | append: '_icon' -%}
                      {%- assign ekb_tv = block.settings[ekb_tk] -%}
                      {%- assign ekb_iv = block.settings[ekb_ik] -%}
                      {%- if ekb_tv != blank -%}
                        <li class="evamats-kariera-benefits__row">
                          {%- if ekb_iv != blank -%}
                            {%- assign ekb_uid = block.id | append: '-c-' | append: ekb_i -%}
                            <span class="evamats-kariera-benefits__row-icon" aria-hidden="true">
                              {% render 'evamats-benefit-icon', icon: ekb_iv, uid: ekb_uid %}
                            </span>
                          {%- endif -%}
                          <span class="evamats-kariera-benefits__row-text">{{ ekb_tv | escape }}</span>
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              {%- else -%}
                {%- if block.settings.description != blank -%}
                  <p class="evamats-kariera-benefits__description evamats-kariera-benefits__description--c">{{ block.settings.description | escape }}</p>
                {%- endif -%}
              {%- endif -%}
            </div>
          </article>

        {%- elsif block.type == 'panel_bottom' -%}
          {%- assign ekb_ct = block.settings.content_type | default: 'list' -%}
          <article class="evamats-kariera-benefits__panel evamats-kariera-benefits__panel--d{% if ekb_ct == 'list' %} evamats-kariera-benefits__panel--has-list{% endif %}" {{ block.shopify_attributes }}>
            <div class="evamats-kariera-benefits__panel-d-inner">
              <div class="evamats-kariera-benefits__panel-d-copy">
                {%- if block.settings.title != blank -%}
                  <h3 class="evamats-kariera-benefits__panel-title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}

                {%- if ekb_ct == 'list' -%}
                  {%- assign ekb_has_items = false -%}
                  {%- for ekb_i in (1..5) -%}
                    {%- assign ekb_tk = 'item_' | append: ekb_i | append: '_text' -%}
                    {%- if block.settings[ekb_tk] != blank -%}{%- assign ekb_has_items = true -%}{%- endif -%}
                  {%- endfor -%}
                  {%- if ekb_has_items -%}
                    <ul class="evamats-kariera-benefits__list" role="list">
                      {%- for ekb_i in (1..5) -%}
                        {%- assign ekb_tk = 'item_' | append: ekb_i | append: '_text' -%}
                        {%- assign ekb_ik = 'item_' | append: ekb_i | append: '_icon' -%}
                        {%- assign ekb_tv = block.settings[ekb_tk] -%}
                        {%- assign ekb_iv = block.settings[ekb_ik] -%}
                        {%- if ekb_tv != blank -%}
                          <li class="evamats-kariera-benefits__row">
                            {%- if ekb_iv != blank -%}
                              {%- assign ekb_uid = block.id | append: '-d-' | append: ekb_i -%}
                              <span class="evamats-kariera-benefits__row-icon" aria-hidden="true">
                                {% render 'evamats-benefit-icon', icon: ekb_iv, uid: ekb_uid %}
                              </span>
                            {%- endif -%}
                            <span class="evamats-kariera-benefits__row-text">{{ ekb_tv | escape }}</span>
                          </li>
                        {%- endif -%}
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                {%- else -%}
                  {%- if block.settings.description != blank -%}
                    <p class="evamats-kariera-benefits__description evamats-kariera-benefits__description--foot">{{ block.settings.description | escape }}</p>
                  {%- endif -%}
                {%- endif -%}
              </div>

              {%- if block.settings.image != blank -%}
                <div class="evamats-kariera-benefits__panel-media evamats-kariera-benefits__panel-media--d">
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      class: 'evamats-kariera-benefits__panel-img evamats-kariera-benefits__panel-img--d'
                  }}
                </div>
              {%- endif -%}
            </div>
          </article>

        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

