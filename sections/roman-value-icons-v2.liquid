                      <circle cx="30" cy="30" r="29" stroke="#FF2741" stroke-width="2"/>
                      <g clip-path="url(#rvi-c1-{{ rvi_iid }})">
                        <mask id="rvi-m1-{{ rvi_iid }}" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="15" y="15" width="30" height="30">
                          <path d="M45 15H15V45H45V15Z" fill="white"/>
                        </mask>
                        <g mask="url(#rvi-m1-{{ rvi_iid }})">
