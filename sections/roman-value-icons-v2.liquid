      </div>

      {%- if rvi_image != blank -%}
        <div class="roman-value-icons-v2__col roman-value-icons-v2__col--media">
          {{
            rvi_image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              class: 'roman-value-icons-v2__img',
              sizes: '(min-width: 990px) 50vw, 100vw',
              widths: '400, 600, 800, 1000, 1200'
          }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

