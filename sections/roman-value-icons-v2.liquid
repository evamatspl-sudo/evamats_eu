{%- liquid
  assign rvi_sid = section.id | replace: '_', ''
  assign rvi_image = section.settings.side_image
-%}

<div
  id="RomanValueIcons-{{ section.id }}"
  class="roman-value-icons-v2"
>
  <div class="roman-value-icons-v2__inner page-width">
    <div class="roman-value-icons-v2__layout{% if rvi_image == blank %} roman-value-icons-v2__layout--text-only{% endif %}">
      <div class="roman-value-icons-v2__col roman-value-icons-v2__col--text">
        {%- if section.settings.heading != blank -%}
          <h2 class="roman-value-icons-v2__heading section_title">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        <div class="roman-value-icons-v2__list" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'item' -%}
              {%- assign rvi_iid = rvi_sid | append: '-' | append: block.id | replace: '_', '' -%}
              <div class="roman-value-icons-v2__row" role="listitem" {{ block.shopify_attributes }}>
                <div class="roman-value-icons-v2__icon" aria-hidden="true">
                  {%- assign rvi_icon = block.settings.icon | default: '1' | append: '' -%}
