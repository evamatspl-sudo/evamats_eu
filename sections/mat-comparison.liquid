{{ 'comparison.css' | asset_url | stylesheet_tag }}
{{ 'mat-comparison.css' | asset_url | stylesheet_tag }}

{% liquid
    assign text_color = section.settings.text_color
    assign background = section.settings.background
    assign description = section.settings.description
    assign subheading_color = section.settings.subheading_color

    assign padding_top = section.settings.padding_top | append: 'px'
    assign padding_top_mobile = section.settings.padding_top_mobile | append: 'px'
    assign padding_bottom = section.settings.padding_bottom | append: 'px'
    assign padding_bottom_mobile = section.settings.padding_bottom_mobile | append: 'px'

%}

<divclass="mat-comparison" style="
        --text-color: {{ text_color }};
        --subheading-color: {{ subheading_color }};
        --background: {{ background }};
        --padding_top: {{ padding_top }};
        --padding_top_mobile: {{ padding_top_mobile }};
        --padding_bottom: {{ padding_bottom  }};
        --padding_bottom_mobile: {{ padding_bottom_mobile }};">

    <div class="mat-comparison__page-width">
        <div class="mat-comparison__wrapper">

            <div class="mat-comparison__media">

                <div class="mat-comparison__media-inner">
                    <span class="mat-comparison__label">{{ section.settings.left_label }}</span>

                    <div class="comparison">
                        {% for block in section.blocks %}
                            <div class="comparison__block_wrapper">
                                <div class="comparison__block {% if forloop.index == 1 %}active{% endif %}">
                                    <div class="comparison__before">
                                        <picture>
                                            <source media="(max-width: 767px)" srcset="{{ block.settings.image_before | img_url: '600x' }}">
                                            <img src="{{ block.settings.image_before | img_url: '1000x' }}" alt="" loading='lazy'>
                                        </picture>

                                    </div>
                                    <div class="comparison__after">
                                        <picture>
                                            <source media="(max-width: 767px)" srcset="{{ block.settings.image_after | img_url: '600x' }}">
                                            <img src="{{ block.settings.image_after | img_url: '1000x' }}" alt="" class="comparison__after" loading='lazy'>
                                        </picture>
                                    </div>

                                    <label>
                                        <input type="range" min="0" max="100" value="50" class="comparison__range">
                                    </label>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

            </div>

            <div class="mat-comparison__content">

                <div class="mat-comparison__content-width">
                    {% if section.settings.subheading != blank %}
                        <p class="mat-comparison__subheading">
                            {{ section.settings.subheading }}
                        </p>
                    {% endif %}

                    {% if section.settings.heading != blank %}
                        <h2 class="mat-comparison__heading">
                            {{ section.settings.heading }}
                        </h2>
                    {% endif %}

                    {% if description != blank %}
                        <div class="mat-comparison__items">
                            {{ description }}
                        </div>
                    {% endif %}
                </div>
            </div>

        </div>
    </div>
</div>

{% schema %}
{
  "name": "Mat Comparison",
  "settings": [
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1B1D22"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#EF022D"
    },
    {
      "type": "text",
      "id": "left_label",
      "label": "Label",
      "default": "Welurowe"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "JAKA JEST RÓŻNICA?"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Na co zwrócić uwagę przy wyborze dywaników?</p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_before",
          "label": "Image Before",
          "info": "Recommended size: 2000x1250. Recommended format: .webp"
        },
        {
          "type": "image_picker",
          "id": "image_after",
          "label": "Image After",
          "info": "Recommended size: 2000x1250. Recommended format: .webp"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mat Comparison"
    }
  ]
}
{% endschema %}