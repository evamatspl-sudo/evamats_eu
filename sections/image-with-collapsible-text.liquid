
{% style %}
    .image-with-collapsible-text--{{ section.id }}{
        padding-top: {{ section.settings.padding_top_mobile }}px;
        padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    @media screen and (min-width: 990px) {
        .image-with-collapsible-text--{{ section.id }} {
            padding-top: {{ section.settings.padding_top }}px;
            padding-bottom: {{ section.settings.padding_bottom }}px;
        }
    }
{% endstyle %}

<div class="image-with-collapsible-text image-with-collapsible-text--{{ section.id }}">
    <div class="page-width">
        <div class="image-with-collapsible-text__wrapper">
            <div class="image-with-collapsible-text__content">
                {% if section.settings.header != blank %}
                    <div class="image-with-collapsible-text__header">
                        {{ section.settings.header }}
                    </div>
                {% endif %}
                {% if section.settings.richtext != blank %}
                    <div class="image-with-collapsible-text__richtext">
                        {{ section.settings.richtext }}
                    </div>
                {% endif %}
                {% if section.settings.collapsible_richtext != blank %}
                    <div id="collapsibleTextContent" class="image-with-collapsible-text__collapsible">
                        {{ section.settings.collapsible_richtext }}
                    </div>
                    <div id="collapsibleTextButton" data-more-text="{{ section.settings.button_text_more | strip_html }}"  data-less-text="{{ section.settings.button_text_less  | strip_html  }}" class="btn-read-more-page">
                        {{ section.settings.button_text_more }}
                    </div>
                {% endif %}
            </div>
            <div class="image-with-collapsible-text__image">
                {% if section.settings.image != blank %}
                    {{
                        section.settings.image
                        | image_url: width: 1500
                        | image_tag:
                        width: imageWidth,
                        height: imageHeight,
                        class: 'lazy',
                        sizes: '100vw',
                        widths: '375, 550, 750, 1100, 1500',
                        loading: 'lazy',
                        alt: section.settings.image.alt
                    }}
                {% else %}
                    {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script>
    const collapsibleTextButton = document.getElementById('collapsibleTextButton');
    const collapsibleTextContent = document.getElementById('collapsibleTextContent');
    collapsibleTextButton.addEventListener('click', ()=>{
        if(collapsibleTextContent.classList.contains('active')){
            collapsibleTextContent.classList.remove('active'); 
            collapsibleTextButton.innerText = collapsibleTextButton.getAttribute('data-more-text')
        }else{
            collapsibleTextContent.classList.add('active');  
            collapsibleTextButton.innerText = collapsibleTextButton.getAttribute('data-less-text')
        }
    });
</script>
 
{% schema %}
  {
    "name": "Image with collaps text",
    "settings": [
        {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
        },
        {
            "type": "richtext",
            "id": "header",
            "label": "Header"
        },
        {
            "type": "richtext",
            "id": "richtext",
            "label": "Richtext"
        },
        {
            "type": "richtext",
            "id": "collapsible_richtext",
            "label": "Collapsible block"
        },
        {
            "type": "text",
            "id": "button_text_more",
            "label": "Button text (more)",
            "default": "Read more"
        },
        {
            "type": "text",
            "id": "button_text_less",
            "label": "Button text (less)",
            "default": "Read less"
        },
        {
            "type": "header",
            "content": "Padding mobile"
        },
        {
            "type": "range",
            "id": "padding_top_mobile",
            "min": 0,
            "max": 80,
            "step": 1,
            "unit": "px",
            "label": "Padding top",
            "default": 0
        },
        {
            "type": "range",
            "id": "padding_bottom_mobile",
            "min": 0,
            "max": 80,
            "step": 1,
            "unit": "px",
            "label": "Padding bottom",
            "default": 80
        },
        {
            "type": "header",
            "content": "Padding desktop"
        },
        {
            "type": "range",
            "id": "padding_top",
            "min": 0,
            "max": 80,
            "step": 1,
            "unit": "px",
            "label": "Padding top",
            "default": 80
        },
        {
            "type": "range",
            "id": "padding_bottom",
            "min": 0,
            "max": 80,
            "step": 1,
            "unit": "px",
            "label": "Padding bottom",
            "default": 80
        }
    ],
    "presets": [
      {
        "name": "Image with collaps text"
      }
    ]
  }
{% endschema %}