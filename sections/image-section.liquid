{%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

<div class="image-section section-{{ section.id }}-padding">
  <div class="image-section__background">
    <h2 class="image-section__title section__title">{{ section.settings.title }}</h2>
    {%- if section.settings.bg_img -%}
      <picture>
        {%- if section.settings.bg_image_mob != blank -%}
          <source
            media="(max-width: 650px)"
            srcset="
              {%- if section.settings.bg_image_mob.width >= 375 -%}{{ section.settings.bg_image_mob | image_url: width: 375 }} 375w,{%- endif -%}
              {%- if section.settings.bg_image_mob.width >= 550 -%}{{ section.settings.bg_image_mob | image_url: width: 550 }} 550w,{%- endif -%}
              {%- if section.settings.bg_image_mob.width >= 750 -%}{{ section.settings.bg_image_mob | image_url: width: 750 }} 750w,{%- endif -%}
            "
          >
        {%- endif -%}
        {{
          section.settings.bg_img
          | image_url: width: 3840
          | image_tag:
            width: imageWidth,
            height: imageHeight,
            class: 'image-section__img',
            sizes: '100vw',
            widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
        }}
      </picture>
    {%- endif -%}
    {%- if section.settings.auto != blank -%}
      <img
        class="image-section__auto"
        src="{{ section.settings.auto | img_url: '800x' }}"
        alt=""
        loading="lazy"
      >
    {%- endif -%}
    <button class='button openPopup' data-popup="popupOverlayApplicationForm" style="display:block;margin:0 auto;">{{'general.config.get_a_price' | t}}</button>
  </div>
</div>


{% schema %}
{
  "name": "Image section",
  "class": "section-image-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mob",
      "label": "Image Mobile"
    },
    {
      "type": "image_picker",
      "id": "auto",
      "label": "Auto"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Image section"
    }
  ]
}
{% endschema %}
  
