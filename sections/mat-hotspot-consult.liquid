    },
    {
      "type": "text",
      "id": "label_name",
      "label": "Name field label",
      "default": "First and Last Name"
    },
    {
      "type": "text",
      "id": "placeholder_name",
      "label": "Name placeholder",
      "default": "John Smith"
    },
    {
      "type": "text",
      "id": "label_phone",
      "label": "Phone field label",
      "default": "Phone"
    },
    {
