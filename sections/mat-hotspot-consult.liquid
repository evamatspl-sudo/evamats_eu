{%- liquid
  assign mat_form_id = 'MatConsultForm-' | append: section.id
  assign mat_form_wrapper_id = 'mat-consult-form-' | append: section.id
-%}

{% render 'evamats-section-padding-style', section: section, target: '.mat-consult' %}

<div
  id="mat-consult-{{ section.id }}"
  class="mat-consult"
  data-section-id="{{ section.id }}"
>
  <div class="page-width mat-consult__page">
    <div class="mat-consult__grid">
      <div class="mat-consult__visual-col">
        <div class="mat-consult__mat">
          {%- if section.settings.mat_image != blank -%}
            {%- liquid
              assign mat_alt = section.settings.mat_image_alt | default: section.settings.mat_image.alt | default: ''
            -%}
            {{
              section.settings.mat_image
              | image_url: width: 1600
              | image_tag:
                loading: 'lazy',
                class: 'mat-consult__mat-img',
                sizes: '(min-width: 990px) 50vw, 100vw',
                widths: '375, 550, 750, 1100, 1600',
                alt: mat_alt
            }}
          {%- else -%}
            <div class="mat-consult__mat-placeholder" aria-hidden="true"></div>
          {%- endif -%}

          {%- for block in section.blocks -%}
            {%- if block.type == 'hotspot' -%}
              <button
                type="button"
                class="mat-consult__hotspot"
                style="--mx: {{ block.settings.position_x }}%; --my: {{ block.settings.position_y }}%;"
                {{ block.shopify_attributes }}
                aria-label="{{ block.settings.tooltip_heading | default: 'Information' | escape }}"
                tabindex="0"
              >
                <span class="mat-consult__pin" aria-hidden="true">
                  <svg class="mat-consult__pin-svg" width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle class="mat-consult__pin-outer" cx="24" cy="24" r="24" fill="#FF2741" opacity="0.5" />
                    <circle class="mat-consult__pin-mid" cx="24" cy="24" r="13" fill="#FF2741" />
                    <circle class="mat-consult__pin-core" cx="24" cy="24" r="5" fill="white" />
                  </svg>
                </span>
                {%- if block.settings.tooltip_heading != blank or block.settings.tooltip_text != blank -%}
                  {%- liquid
                    assign px = block.settings.position_x | plus: 0
                    assign py = block.settings.position_y | plus: 0
                    assign tip_row = 'mid'
                    if py <= 33
                      assign tip_row = 'top'
                    elsif py >= 67
                      assign tip_row = 'bot'
                    endif
                    assign tip_col = 'center'
                    if px <= 33
                      assign tip_col = 'left'
                    elsif px >= 67
                      assign tip_col = 'right'
                    endif
                  -%}
                  <span
                    class="mat-consult__tooltip mat-consult__tooltip--r-{{ tip_row }} mat-consult__tooltip--c-{{ tip_col }}"
                    role="tooltip"
                  >
                    {%- if block.settings.tooltip_heading != blank -%}
                      <span class="mat-consult__tooltip-title">{{ block.settings.tooltip_heading | escape }}</span>
                    {%- endif -%}
                    {%- if block.settings.tooltip_text != blank -%}
                      <span class="mat-consult__tooltip-body">{{ block.settings.tooltip_text | escape }}</span>
                    {%- endif -%}
                  </span>
                {%- endif -%}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <div class="mat-consult__form-col">
        {% render 'mat-consult-form',
          form_section: section,
          form_id: mat_form_id,
          wrapper_id: mat_form_wrapper_id,
          hidden_form_value: 'Mat — consultation (hotspot)'
        %}
      </div>
    </div>
  </div>
</div>

