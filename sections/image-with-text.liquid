{{ 'component-rte.css' | asset_url | stylesheet_tag }}
{{ 'section-evamats-image-with-text.css' | asset_url | stylesheet_tag }}

<div
  class="image-with-text evamats-image-with-text"
  style="--eiw-outer-pt: {{ section.settings.padding_top }}px; --eiw-outer-pb: {{ section.settings.padding_bottom }}px; --eiw-card-px: {{ section.settings.card_padding_x }}px; --eiw-card-py: {{ section.settings.card_padding_y }}px;"
>
  <div class="page-width">
    <div class="evamats-image-with-text__card">
      <div class="image-with-text__grid evamats-image-with-text__grid{% if section.settings.layout == 'text_first' %} evamats-image-with-text__grid--reverse{% endif %}">
        <div class="image-with-text__media-item grid__item">
          <div
            class="image-with-text__media image-with-text__media--contain{% if section.settings.image_2 != blank %} image-with-text__media--two_images{% endif %} {% if section.settings.image != blank %}media{% else %}image-with-text__media--placeholder placeholder{% endif %}"
          >
            {%- if section.settings.image != blank -%}
              {%- capture sizes -%}
                (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
              {%- endcapture -%}
              {{
                section.settings.image
                | image_url: width: 1500
                | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500'
              }}
              {% if section.settings.image_2 != blank %}
                {{
                  section.settings.image_2
                  | image_url: width: 1500
                  | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500'
                }}
              {% endif %}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
        </div>
        <div class="image-with-text__text-item grid__item">
          <div
            id="ImageWithText--{{ section.id }}"
            class="image-with-text__content image-with-text__content--adapt"
          >
            {%- for block in section.blocks -%}
              {% case block.type %}
                {%- when 'heading' -%}
                  {%- liquid
                    assign heading_text = block.settings.heading | strip
                    assign heading_lead = heading_text | split: '.' | first | strip
                    assign heading_rest = heading_text | remove_first: heading_lead | remove_first: '.' | strip
                  -%}
                  <h2 class="image-with-text__heading evamats-image-with-text__heading" {{ block.shopify_attributes }}>
                    {%- if heading_lead != blank and heading_rest != blank -%}
                      <span class="evamats-image-with-text__heading-index">{{ heading_lead }}.</span>
                      {{ heading_rest | escape }}
                    {%- else -%}
                      {{ heading_text | escape }}
                    {%- endif -%}
                  </h2>
                {%- when 'text' -%}
                  {%- liquid
                    assign points_text = block.settings.text | replace: '✔ ', '' | replace: '✔', ''
                    assign points_text = points_text | replace: '<br/><br/>', '</p><p>'
                    assign points_text = points_text | replace: '<br><br>', '</p><p>'
                  -%}
                  <div class="image-with-text__text rte evamats-image-with-text__points" {{ block.shopify_attributes }}>
                    {{ points_text }}
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with text",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Second image"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "image_first",
          "label": "Image first"
        },
        {
          "value": "text_first",
          "label": "Text first"
        }
      ],
      "default": "image_first",
      "label": "Layout"
    },
    {
      "type": "header",
      "content": "Card spacing"
    },
    {
      "type": "range",
      "id": "card_padding_x",
      "min": 0,
      "max": 99,
      "step": 1,
      "unit": "px",
      "label": "Card horizontal padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "card_padding_y",
      "min": 0,
      "max": 99,
      "step": 1,
      "unit": "px",
      "label": "Card vertical padding",
      "default": 81
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "1. Image with text",
          "label": "Heading"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with text",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        }
      ]
    }
  ]
}
{% endschema %}
