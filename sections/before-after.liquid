{{ 'comparison.css' | asset_url | stylesheet_tag }}

<div class="comparison">
    <div class="page-width">
        <div class="comparison__content">
            {%- if section.settings.heading_main != blank or section.settings.heading_accent != blank or section.settings.title != blank or section.settings.heading_line2 != blank -%}
            <div class="comparison__heading">
              {%- if section.settings.heading_main != blank or section.settings.heading_accent != blank -%}
                <h2 class="comparison__heading-h2">
                  {%- if section.settings.heading_main != blank -%}
                    <span class="comparison__heading-main">{{ section.settings.heading_main | escape }}</span>
                  {%- endif -%}
                  {%- if section.settings.heading_accent != blank -%}
                    <span class="comparison__heading-accent">{{ section.settings.heading_accent | escape }}</span>
                  {%- endif -%}
                </h2>
              {%- elsif section.settings.title != blank -%}
                <h2 class="comparison__heading-h2">{{ section.settings.title | escape }}</h2>
              {%- endif -%}
              {%- if section.settings.heading_line2 != blank -%}
                <p class="comparison__heading-sub">{{ section.settings.heading_line2 | escape }}</p>
              {%- endif -%}
            </div>
            {%- endif -%}

            <div class="comparison__wrapper">

                <div class="comparison__container">
                    {% for block in section.blocks %}
                        {%- liquid
                          assign cmp_shape = forloop.index
                          if cmp_shape > 3
                            assign cmp_shape = 3
                          endif
                        -%}
                        <div class="comparison__block_wrapper">
                            <div class="comparison__block {% if forloop.index == 1 %}active{% endif %}" id="tab-{{ forloop.index }}">
                                <div class="comparison__before">
                                    <div class="comparison_label comparison_label--shape-{{ cmp_shape }}">
                                      {%- if block.settings.label_before_main != blank or block.settings.label_before_accent != blank -%}
                                        <span class="comparison_label__inner">
                                          {%- if block.settings.label_before_main != blank -%}
                                            <span class="comparison_label__text comparison_label__text--main">{{ block.settings.label_before_main | escape }}</span>
                                          {%- endif -%}
                                          {%- if block.settings.label_before_accent != blank -%}
                                            <span class="comparison_label__text comparison_label__text--accent">{{ block.settings.label_before_accent | escape }}</span>
                                          {%- endif -%}
                                        </span>
                                      {%- elsif block.settings.label_before != blank -%}
                                        <span class="comparison_label__inner">{{ block.settings.label_before | escape }}</span>
                                      {%- endif -%}
                                    </div>
                                    <picture>
                                        <source media="(max-width: 767px)" srcset="{{ block.settings.image_before | img_url: '300x' }}">
                                        <img src="{{ block.settings.image_before | img_url: '1000x' }}" alt="" loading='lazy'>
                                    </picture>
                                    
                                </div>
                                <div class="comparison__after">
                                    <picture>
                                        <source media="(max-width: 767px)" srcset="{{ block.settings.image_after | img_url: '300x' }}">
                                        <img src="{{ block.settings.image_after | img_url: '1000x' }}" alt="" class="comparison__after" loading='lazy'>
                                    </picture>
                                </div>
                                
                                <label>
                                    <input type="range" min="0" max="100" value="50" class="comparison__range">
                                </label>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
            <div class="comparison__scrollbar">
                <div class="comparison__scrollbar-thumb">{% render 'icon-hand' %}</div>
            </div>
            {%- if section.settings.button_label != blank -%}
              {%- liquid
                assign ba_btn_url = section.settings.button_link
                if ba_btn_url == blank
                  assign ba_btn_url = '#'
                endif
              -%}
              <div class="button-row-v2 comparison__cta-wrap">
                <a class="button button_2" href="{{ ba_btn_url }}">{{ section.settings.button_label | escape }}</a>
              </div>
            {%- endif -%}
        </div>
    </div>
</div>
{% schema %}
{
  "name": "Image Comparison",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title (legacy)",
      "info": "Used only if split heading fields below are both empty."
    },
    {
      "type": "text",
      "id": "heading_main",
      "label": "Heading — main (white)"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading — accent (red)"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading — second line"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "info": "Leave empty to hide the button."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_before",
          "label": "Image Before",
          "info": "Recommended size: 2000x1250. Recommended format: .webp"
        },
        {
          "type": "image_picker",
          "id": "image_after",
          "label": "Image After",
          "info": "Recommended size: 2000x1250. Recommended format: .webp"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "label_before",
          "label": "Label before (single color)",
          "info": "Used if split label fields are empty. Block order 1–3 picks label SVG width."
        },
        {
          "type": "text",
          "id": "label_before_main",
          "label": "Label before — main (white)"
        },
        {
          "type": "text",
          "id": "label_before_accent",
          "label": "Label before — accent (red)"
        },
        {
          "type": "text",
          "id": "label_after",
          "label": "Label after"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Comparison"
    }
  ]
}
{% endschema %}
