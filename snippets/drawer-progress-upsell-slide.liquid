{% comment %}
  Cart upsell slide — Figma 1710:11001 desktop / 1710:10905 mobile
{% endcomment %}
{%- assign upsell_variant = item.selected_or_first_available_variant -%}
{%- assign upsell_price = upsell_variant.price -%}
{%- assign upsell_compare = upsell_variant.compare_at_price -%}
{%- assign upsell_has_discount = false -%}
{%- if upsell_compare > upsell_price -%}
  {%- assign upsell_has_discount = true -%}
  {%- assign upsell_discount = upsell_compare | minus: upsell_price | times: 100.0 | divided_by: upsell_compare | round -%}
{%- endif -%}

<div
  class="drawer__progress_products_item product__upsell_item cart-upsell-strip{% if item.tags contains 'sold_out' %} sold_out{% endif %} swiper-slide"
  {% if random_pick %}data-upsell-random{% endif %}
  data-id="{{ upsell_variant.id }}"
>
  {% if item.tags contains 'sold_out' %}
    <div class="cart-upsell-strip__sold-out">{{ 'products.product.sold_out' | t }}</div>
  {% endif %}

  <div class="cart-upsell-strip__row">
    <a href="{{ item.url }}" class="cart-upsell-strip__media" target="_blank" tabindex="-1" aria-hidden="true">
      {% if item.featured_image %}
        {% assign upsell_img_w = 180 %}
        {% assign upsell_img_h = upsell_img_w | divided_by: item.featured_image.aspect_ratio | round %}
        <img
          src="{{ item.featured_image | image_url: width: upsell_img_w }}"
          alt=""
          class="cart-upsell-strip__image product__upsell_image"
          width="{{ upsell_img_w }}"
          height="{{ upsell_img_h }}"
          loading="lazy"
        >
      {% endif %}
    </a>

    <div class="cart-upsell-strip__body product__upsell_item_heading">
      <a href="{{ item.url }}" class="cart-upsell-strip__title product__upsell_item_title" target="_blank">{{ item.title }}</a>

      {% if item.title contains 'Podpiętka z materiału EVA' or item.title contains 'EVA material heel pad' %}
        <div class="cart-upsell-strip__note product__upsell_item_note">{{ 'sections.cart.upsell_eva_note' | t }}</div>
      {% endif %}

      <div class="cart-upsell-strip__priceline">
        {%- if upsell_has_discount -%}
          <span class="cart-upsell-strip__old-price">
            <span class="cart-upsell-strip__old-value">{{ upsell_compare | money }}</span>
            <span class="cart-upsell-strip__old-line" aria-hidden="true"></span>
          </span>
          <span class="product__upsell_discount cart-upsell-strip__discount">
            {%- render 'evamats-upsell-discount-badge', value: upsell_discount -%}
          </span>
        {%- endif -%}
        <span class="cart-upsell-strip__price product__upsell_price">{{ upsell_price | money }}</span>
      </div>

      {% if item.variants.size > 1 %}
        <div class="cart-upsell-strip__variants product__upsell_item_variants">
          {% assign activeIndex = 0 %}
          {% for itemVariant in item.variants %}
            {% if itemVariant.available %}
              {% assign activeIndex = forloop.index %}
              {% break %}
            {% endif %}
          {% endfor %}
          {% for itemVariant in item.variants %}
            <button
              type="button"
              class="cart-upsell-strip__variant product__upsell_item_variant {% unless itemVariant.available %}disabled{% endunless %}{% if forloop.index == activeIndex %} active{% endif %}"
              data-id="{{ itemVariant.id }}"
            >
              {{ itemVariant.title }}
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="cart-upsell-strip__actions product-form__buttons">
      <button
        id="ProductSubmitButton-{{ section_id }}-{{ item.id }}"
        type="button"
        name="add"
        class="cart-upsell-strip__cart-btn product-form__submit"
        aria-label="{{ 'sections.cart.upsell_add_to_cart' | t }}"
        {% if upsell_variant.available == false or quantity_rule_soldout %}
          disabled
        {% endif %}
      >
        <span class="cart-upsell-strip__cart-btn-icon" aria-hidden="true">
          {% render 'icon-cart' %}
        </span>
        <div class="loading-overlay__spinner hidden">
          <span class="loader"></span>
        </div>
      </button>
    </div>
  </div>
</div>
