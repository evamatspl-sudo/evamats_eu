{%- comment -%}
  Cart progress banner gift icon — theme setting or default SVG.
{%- endcomment -%}
<div class="evamats-cart-gift-banner__gift" aria-hidden="true">
  {%- if settings.cart_progress_gift_image != blank -%}
    {%- liquid
      assign gift_image = settings.cart_progress_gift_image
      assign gift_image_max = 400
      if gift_image.width < gift_image_max
        assign gift_image_max = gift_image.width
      endif
    -%}
    {{
      gift_image
      | image_url: width: gift_image_max
      | image_tag:
        class: 'evamats-cart-gift-banner__gift-image',
        loading: 'lazy',
        widths: '53, 87, 106, 174, 200, 400',
        sizes: '(max-width: 749px) 53px, 87px',
        alt: ''
    }}
  {%- else -%}
    <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M8 18V32H32V18" stroke="#FF2741" stroke-width="2" stroke-linejoin="round"/>
      <path d="M20 18V32" stroke="#FF2741" stroke-width="2"/>
      <path d="M8 18H32V14C32 12.8954 31.1046 12 30 12H10C8.89543 12 8 12.8954 8 14V18Z" stroke="#FF2741" stroke-width="2" stroke-linejoin="round"/>
      <path d="M20 12C20 9.5 17.5 7 15 7C12.5 7 11 8.5 11 10.5C11 12.5 20 12 20 12Z" stroke="#FF2741" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M20 12C20 9.5 22.5 7 25 7C27.5 7 29 8.5 29 10.5C29 12.5 20 12 20 12Z" stroke="#FF2741" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  {%- endif -%}
</div>
