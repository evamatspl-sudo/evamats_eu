{%- comment -%}
  Footer contact block — structured rows with hardcoded icons.
  @param block {block}
{%- endcomment -%}

{%- liquid
  assign contact_email = block.settings.email | strip
  assign contact_phone = block.settings.phone | strip
  assign contact_address = block.settings.address | strip
  assign phone_href = contact_phone | replace: ' ', '' | replace: '-', ''
-%}

<div class="evamats-footer__contact" {{ block.shopify_attributes }}>
  {%- if block.settings.heading != blank -%}
    <p class="evamats-footer__menu-heading">{{ block.settings.heading | escape }}</p>
  {%- endif -%}

  {%- if block.settings.intro != blank or contact_email != blank or contact_phone != blank or contact_address != blank -%}
    <div class="evamats-footer__contact-body">
      {%- if block.settings.intro != blank -%}
        <div class="evamats-footer__contact-intro rte">
          {{ block.settings.intro }}
        </div>
      {%- endif -%}

      {%- if contact_email != blank -%}
        <div class="evamats-footer__contact-row evamats-footer__contact-row--email">
          <span class="evamats-footer__contact-icon" aria-hidden="true">
            {% render 'evamats-footer-contact-icon', icon: 'email' %}
          </span>
          <a class="evamats-footer__contact-value evamats-footer__contact-value--email" href="mailto:{{ contact_email | escape }}">
            {{- contact_email | escape -}}
          </a>
        </div>
      {%- endif -%}

      {%- if contact_phone != blank -%}
        <div class="evamats-footer__contact-row evamats-footer__contact-row--phone">
          <span class="evamats-footer__contact-icon" aria-hidden="true">
            {% render 'evamats-footer-contact-icon', icon: 'phone' %}
          </span>
          <a class="evamats-footer__contact-value evamats-footer__contact-value--phone" href="tel:{{ phone_href | escape }}">
            {{- contact_phone | escape -}}
          </a>
        </div>
      {%- endif -%}

      {%- if contact_address != blank -%}
        <div class="evamats-footer__contact-row evamats-footer__contact-row--address">
          <span class="evamats-footer__contact-icon" aria-hidden="true">
            {% render 'evamats-footer-contact-icon', icon: 'address' %}
          </span>
          <p class="evamats-footer__contact-value evamats-footer__contact-value--address">
            {{ contact_address | newline_to_br }}
          </p>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>
