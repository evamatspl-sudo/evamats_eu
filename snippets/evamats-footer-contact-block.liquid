{%- comment -%}
  Footer contact block — structured rows with hardcoded icons.
  @param block {block}
{%- endcomment -%}

{%- liquid
  assign contact_email = block.settings.email | strip
  assign contact_phone = block.settings.phone | strip
  assign contact_address = block.settings.address | strip
  assign phone_href = contact_phone | replace: ' ', '' | replace: '-', ''
-%}

<div class="evamats-footer__contact" {{ block.shopify_attributes }}>
  {%- if block.settings.heading != blank -%}
    <p class="evamats-footer__menu-heading">{{ block.settings.heading | escape }}</p>
  {%- endif -%}

  {%- if block.settings.intro != blank or contact_email != blank or contact_phone != blank or contact_address != blank -%}
    <div class="evamats-footer__contact-body rte">
      {%- if block.settings.intro != blank -%}
        <div class="evamats-footer__contact-intro rte">{{ block.settings.intro }}</div>
      {%- endif -%}
      {%- if contact_email != blank -%}
        <p class="evamats-footer__contact-line">✉️ <strong>E-mail:</strong> <a href="mailto:{{ contact_email | escape }}">{{- contact_email | escape -}}</a></p>
      {%- endif -%}
      {%- if contact_phone != blank -%}
        <p class="evamats-footer__contact-line">📞 <strong>Telefon:</strong> <a href="tel:{{ phone_href | escape }}">{{- contact_phone | escape -}}</a></p>
      {%- endif -%}
      {%- if contact_address != blank -%}
        {%- assign addr_parts = contact_address | strip | split: '
' -%}
        <p class="evamats-footer__contact-line">📍 <strong>Adresa:</strong><br>{{ addr_parts[0] | strip }}{%- if addr_parts.size > 1 -%}<br><span class="evamats-footer__contact-note">{%- for part in addr_parts offset: 1 -%}{{ part | strip }}{%- unless forloop.last -%}<br>{%- endunless -%}{%- endfor -%}</span>{%- endif -%}</p>
      {%- endif -%}
  {%- endif -%}
</div>
