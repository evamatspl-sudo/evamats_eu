{% assign progress_bar_setting = settings.progress_bar_type | default: settings.progrss_bar_type %}
{% assign progress_part = part | default: 'all' %}
{% assign is_cart_drawer = false %}
{% if section_id == 'cart-drawer' %}
  {% assign is_cart_drawer = true %}
{% endif %}

{% comment %} Critical CSS: upsell strip first paint (Figma 1710:11033 / 11001 / 10905) {% endcomment %}
<style id="cart-upsell-critical-css">
  .evamats-cart-upsell {
    background: #f6f6f6;
    padding: 0 0 50px;
    margin: 0;
  }
  .evamats-cart-upsell__inner {
    padding-top: 20px;
    box-sizing: border-box;
  }
  .evamats-cart-upsell__heading {
    margin: 0 0 20px;
    font-weight: 400;
    font-size: 22px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text-primary, #1b1d22);
  }
  .drawer__progress_products-block {
    position: relative;
    width: 100%;
    container-type: inline-size;
    box-sizing: border-box;
    --cart-upsell-fade: #f6f6f6;
  }
  .drawer__progress_products-block::before,
  .drawer__progress_products-block::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    z-index: 2;
    width: 72px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .drawer__progress_products-block::before {
    left: 0;
    background: linear-gradient(90deg, var(--cart-upsell-fade) 0%, rgba(246, 246, 246, 0) 100%);
  }
  .drawer__progress_products-block::after {
    right: 0;
    background: linear-gradient(270deg, var(--cart-upsell-fade) 0%, rgba(246, 246, 246, 0) 100%);
  }
  .drawer__progress_products-block.has-fade-prev::before,
  .drawer__progress_products-block.has-fade-next::after {
    opacity: 1;
  }
  @media screen and (min-width: 750px) {
    .drawer__progress_products-block::before,
    .drawer__progress_products-block::after {
      width: 127px;
    }
  }
  .drawer__progress_products.swiper {
    position: relative;
    overflow: hidden;
    margin: 0;
    padding: 0;
    background: transparent;
    border-radius: 0;
    box-sizing: border-box;
  }
  .drawer__progress_products .swiper-wrapper {
    display: flex;
    align-items: stretch !important;
    box-sizing: border-box;
  }
  .drawer__progress_products .swiper-slide {
    flex-shrink: 0;
    box-sizing: border-box;
    width: 261px;
    height: auto;
    align-self: stretch !important;
  }
  .drawer__progress_products .drawer__progress_products_item.cart-upsell-strip {
    padding: 8px;
    background: #fff;
  }
  .cart-upsell-strip {
    display: flex;
    flex-direction: column;
    height: 110px;
    padding: 8px;
    border-radius: 10px;
    background: #fff;
    box-sizing: border-box;
    overflow: hidden;
  }
  .cart-upsell-strip__row {
    display: flex;
    align-items: center;
    gap: 11px;
    min-width: 0;
    height: 100%;
  }
  .cart-upsell-strip__media {
    flex-shrink: 0;
    width: 70px;
    height: 70px;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }
  .cart-upsell-strip__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .cart-upsell-strip__body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    justify-content: center;
  }
  .cart-upsell-strip__title {
    margin: 0;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.3;
    letter-spacing: -0.02em;
    text-decoration: none;
    color: var(--color-text-primary, #1b1d22);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .cart-upsell-strip__priceline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px 6px;
  }
  .cart-upsell-strip__price {
    font-weight: 600;
    font-size: 14px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text-primary, #1b1d22);
  }
  .cart-upsell-strip__cart-btn {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    padding: 0;
    border: 0;
    border-radius: 10px;
    background: #ff2741;
    color: #fff;
    cursor: pointer;
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .cart-upsell-strip__cart-btn .icon-cart {
    fill: #fff;
  }
  .cart-upsell-strip__variants {
    display: none;
  }
  @media screen and (min-width: 750px) {
    .evamats-cart-upsell__inner {
      padding-top: 50px;
    }
    .drawer__progress_products .drawer__progress_products_item.cart-upsell-strip {
      padding: 10px;
    }
    .cart-upsell-strip {
      padding: 10px;
    }
    .cart-upsell-strip__row {
      gap: 20px;
    }
  }
  @container (min-width: 750px) {
    .drawer__progress_products .swiper-slide {
      width: 466px !important;
      max-width: none;
    }
    .cart-upsell-strip__media {
      width: 90px;
      height: 90px;
    }
    .cart-upsell-strip__title {
      font-size: 16px;
      line-height: 1.35;
      -webkit-line-clamp: 1;
    }
    .cart-upsell-strip__price {
      font-size: 16px;
    }
    .cart-upsell-strip__cart-btn {
      width: 52px;
      height: 52px;
      border-radius: 12px;
    }
    .cart-upsell-strip {
      border-radius: 12px;
    }
  }
</style>

{% capture drawer_products %}
  {% assign drawer_pool_collection = settings.order_related_collection %}
  {% assign drawer_random_limit = settings.order_related_collection_limit | default: 5 %}
  {% assign drawer_collection_eligible = 0 %}

  {% if drawer_pool_collection != blank %}
    {% for p in drawer_pool_collection.products %}
      {% if p.available %}
        {% assign _tl = p.title | downcase %}
        {% assign _skip_h = false %}
        {% if _tl contains 'heel pad' or _tl contains 'heelpad' or _tl contains 'podpiętka' or _tl contains 'podpietka' or _tl contains 'fersenpolster' %}
          {% assign _skip_h = true %}
        {% endif %}
        {% if p.tags contains 'heel-pad' or p.tags contains 'heel_pad' or p.tags contains 'heelpad' %}
          {% assign _skip_h = true %}
        {% endif %}
        {% unless _skip_h %}
          {% assign drawer_collection_eligible = drawer_collection_eligible | plus: 1 %}
        {% endunless %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% assign drawer_use_collection_random = false %}
  {% if drawer_pool_collection != blank and drawer_collection_eligible > 0 %}
    {% assign drawer_use_collection_random = true %}
  {% endif %}

  {% if drawer_use_collection_random or settings.order_related_products != blank %}
    <div class="drawer__progress_products-block">
      <div class="drawer__progress_products swiper">
        <div
          class="swiper-wrapper"
          {% if drawer_use_collection_random %}
            id="drawer-upsell-random-wrapper"
            data-random-pool
            data-random-limit="{{ drawer_random_limit }}"
          {% endif %}
        >
          {% if drawer_use_collection_random %}
            {% for item in drawer_pool_collection.products %}
              {% if item.available %}
                {% render 'drawer-progress-upsell-if-not-heeled', item: item, section_id: section_id, random_pick: true %}
              {% endif %}
            {% endfor %}
          {% else %}
            {% for item in settings.order_related_products %}
              {% if item.available %}
                {% render 'drawer-progress-upsell-if-not-heeled', item: item, section_id: section_id %}
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>
      </div>
      <div class="drawer__progress_products-arrows">
        {% render 'eva-slider-arrows', color: 'white', class: 'drawer__progress_products-arrows-inner' %}
      </div>
    </div>
    {% if drawer_use_collection_random %}
      <script>
        (function () {
          var wrap = document.getElementById('drawer-upsell-random-wrapper');
          if (!wrap || !wrap.hasAttribute('data-random-pool')) return;
          var limit = parseInt(wrap.getAttribute('data-random-limit'), 10) || 5;
          var slides = wrap.querySelectorAll('.swiper-slide[data-upsell-random]');
          if (!slides.length) return;
          var arr = Array.prototype.slice.call(slides);
          arr.sort(function () {
            return 0.5 - Math.random();
          });
          var selected = arr.slice(0, Math.min(limit, arr.length));
          wrap.innerHTML = '';
          selected.forEach(function (el) {
            wrap.appendChild(el);
          });
        })();
      </script>
    {% endif %}
  {% endif %}
{% endcapture %}

{% assign drawer_products_stripped = drawer_products | strip %}
{% assign has_upsell_products = false %}
{% if drawer_products_stripped != '' %}
  {% assign has_upsell_products = true %}
{% endif %}

{% if progress_part == 'upsell' or progress_part == 'all' %}
  {% if has_upsell_products %}
    {% if is_cart_drawer %}
      {{ drawer_products }}
    {% else %}
      <section class="evamats-cart-upsell" aria-labelledby="evamats-cart-upsell-heading-{{ section_id }}">
        <div class="evamats-cart-upsell__inner page-width">
          <h2 id="evamats-cart-upsell-heading-{{ section_id }}" class="evamats-cart-upsell__heading">
            {{ 'sections.cart.upsell_heading' | t }}
          </h2>
          {{ drawer_products }}
        </div>
      </section>
    {% endif %}
  {% endif %}
{% endif %}

{% if progress_part == 'gift' or progress_part == 'all' %}
  {% if progress_bar_setting == 'shipping' %}
    {% assign freeShipping = false %}
    {% assign progress_percent = 0 %}

    {% capture free_shipping_order_total_raw %}{% render 'evamats-free-shipping-threshold' %}{% endcapture %}
    {% assign free_shipping_order_total_raw = free_shipping_order_total_raw | strip %}
    {% assign threshold = free_shipping_order_total_raw | times: 100.0 %}

    {% if threshold > 0 and cart != empty %}
      {% assign progress_percent = cart.total_price | times: 100 | divided_by: threshold | at_most: 100 %}

      {% if cart.total_price >= threshold %}
        {% assign freeShipping = true %}
        {% assign progress_percent = 100 %}
      {% endif %}

      <div id="drawer__progress" class="drawer__progress evamats-cart-gift-banner-wrap">
        <div class="evamats-cart-gift-banner">
          <div class="evamats-cart-gift-banner__text-row">
            <p class="evamats-cart-gift-banner__text">
              {% if freeShipping %}
                {{ 'sections.cart.progress_free_shipping' | t }}
              {% else %}
                {% assign value = threshold | minus: cart.total_price | money %}
                {{ 'sections.cart.progress_text_order_value' | t: value: value }}
              {% endif %}
            </p>
            <span class="evamats-cart-gift-banner__info" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/>
                <path d="M8 7.2V11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <circle cx="8" cy="5.1" r="0.9" fill="currentColor"/>
              </svg>
            </span>
          </div>
          <div class="evamats-cart-gift-banner__bar" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{ progress_percent | round }}">
            <div class="evamats-cart-gift-banner__bar-fill{% if progress_percent > 0 and progress_percent < 100 %} evamats-cart-gift-banner__bar-fill--tip{% endif %}" style="width: {{ progress_percent }}%;"></div>
          </div>
          {% render 'evamats-cart-gift-banner-icon' %}
        </div>
      </div>
    {% endif %}
  {% elsif progress_bar_setting == 'discount' %}
    {% assign discount5 = 50000 %}
    {% assign discount15 = 120000 %}
    {% assign discount20 = 240000 %}
    {% assign discount25 = 360000 %}

    {% assign total = cart.total_price %}

    {% assign nextDiscount = '' %}
    {% assign value = 0 %}
    {% assign progressThreshold = 0 %}

    {% if total < discount5 %}
      {% assign nextDiscount = '5%' %}
      {% assign value = discount5 | minus: total %}
      {% assign progressThreshold = total | times: 100.0 | divided_by: discount5 %}
    {% elsif total < discount15 %}
      {% assign nextDiscount = '15%' %}
      {% assign value = discount15 | minus: total %}
      {% assign progressThreshold = total | times: 100.0 | divided_by: discount15 %}
    {% elsif total < discount20 %}
      {% assign nextDiscount = '20%' %}
      {% assign progressThreshold = total | times: 100.0 | divided_by: discount20 %}
      {% assign value = discount20 | minus: total %}
    {% elsif total < discount25 %}
      {% assign nextDiscount = '25%' %}
      {% assign value = discount25 | minus: total %}
      {% assign progressThreshold = total | times: 100.0 | divided_by: discount25 %}
    {% else %}
      {% assign nextDiscount = 'full discount' %}
      {% assign progressThreshold = 100.0 %}
    {% endif %}

    {% if total != 0 and nextDiscount != 'full discount' %}
      {% assign progress_percent = progressThreshold | at_most: 100 | round: 1 %}
      <div id="drawer__progress" class="drawer__progress evamats-cart-gift-banner-wrap">
        <div class="evamats-cart-gift-banner">
          <div class="evamats-cart-gift-banner__text-row">
            <p class="evamats-cart-gift-banner__text">
              {% assign value_money = value | money %}
              {{ 'sections.cart.progress_text_discount' | t: value: value_money, nextDiscount: nextDiscount }}
            </p>
            <span class="evamats-cart-gift-banner__info" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/>
                <path d="M8 7.2V11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <circle cx="8" cy="5.1" r="0.9" fill="currentColor"/>
              </svg>
            </span>
          </div>
          <div class="evamats-cart-gift-banner__bar" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{ progress_percent | round }}">
            <div class="evamats-cart-gift-banner__bar-fill{% if progress_percent > 0 and progress_percent < 100 %} evamats-cart-gift-banner__bar-fill--tip{% endif %}" style="width: {{ progress_percent }}%;"></div>
          </div>
          {% render 'evamats-cart-gift-banner-icon' %}
        </div>
      </div>
    {% elsif total != 0 %}
      <div class="drawer__progress_text">
        {{ 'sections.cart.progress_max_discount' | t }}
      </div>
    {% endif %}
  {% endif %}
{% endif %}

{% unless progress_part == 'gift' %}
<script>
  (function () {
    if (window.__cartUpsellDelegated) return;
    window.__cartUpsellDelegated = true;

    document.addEventListener('click', function (e) {
      var variant = e.target.closest('.drawer__progress_products .product__upsell_item_variant');
      if (variant && !variant.classList.contains('disabled')) {
        var group = variant.closest('.product__upsell_item_variants');
        if (!group) return;
        group.querySelectorAll('.product__upsell_item_variant').forEach(function (v) {
          v.classList.remove('active');
        });
        variant.classList.add('active');
        return;
      }

      var button = e.target.closest('.drawer__progress_products .product-form__submit');
      if (!button || button.disabled) return;
      e.preventDefault();

      var productWrapper = button.closest('.product__upsell_item');
      if (!productWrapper) return;

      var variantId = null;
      var activeVariant = productWrapper.querySelector('.product__upsell_item_variant.active');
      if (activeVariant) {
        variantId = activeVariant.dataset.id;
      } else {
        variantId = productWrapper.dataset.id;
      }

      if (!variantId) {
        alert({{ 'sections.cart.cart_upsell_variant_error' | t | json }});
        return;
      }

      fetch(window.routes.cart_add_url + '.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
        },
        body: JSON.stringify({
          id: variantId,
          quantity: 1,
        }),
      })
        .then(function (response) {
          if (!response.ok) throw new Error('Cart add error');
          return response.json();
        })
        .then(function () {
          location.reload();
        })
        .catch(function (err) {
          console.error(err);
        });
    });
  })();
</script>
{% endunless %}
