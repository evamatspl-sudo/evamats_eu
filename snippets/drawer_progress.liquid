{% assign progress_bar_setting = settings.progress_bar_type | default: settings.progrss_bar_type %}
{% comment %} Sync inline styles: progress + upsell strip on first paint {% endcomment %}
<style id="cart-upsell-critical-css">
  #drawer__progress.drawer__progress { margin: 20px auto 10px; padding-bottom: 22px; }
  .drawer__progress_bar { position: relative; width: 100%; height: 6px; border-radius: 30px; background: #f0f0f0; }
  .drawer__progress_bar .line {
    position: absolute; top: 0; left: 0; height: 6px; border-radius: 30px;
    background: var(--color-1, #ef022d); max-width: 100%; display: block !important;
  }
  .drawer__progress_text { margin-bottom: 8px; text-align: center; }
  .drawer__progress_products.swiper {
    position: relative; overflow: hidden; margin-bottom: 20px; background: #fff;
    padding: 12px ; border-radius: 10px; box-sizing: border-box;
  }
  .drawer__progress_products .swiper-wrapper {
    display: flex; align-items: stretch !important; box-sizing: border-box;
  }
  .drawer__progress_products .swiper-slide {
    flex-shrink: 0; box-sizing: border-box; width: 280px;
    max-width: min(280px, calc(100vw - 7rem)); padding: 0 8px; align-self: stretch !important;
  }
  .drawer__progress_products .drawer__progress_products_item {
    width: 100%; min-height: 100%; height: 100%; padding: 12px 14px;
    box-sizing: border-box; border-radius: 8px; overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.12);
  }
  .drawer__progress_products .product__upsell_item {
    display: flex; flex-direction: column; align-items: stretch; gap: 0;
    width: 100%; min-height: 100%; min-width: 0;
  }
  .drawer__progress_products .product__upsell_item_top {
    display: flex; flex-direction: row; align-items: flex-start; gap: 14px;
    width: 100%; min-width: 0;
  }
  .drawer__progress_products .img_wr { flex-shrink: 0; width: 42%; max-width: 42%; aspect-ratio: 1 / 1; overflow: hidden; align-self: flex-start; border-radius: 0.4rem; }
  .drawer__progress_products .img_wr img { width: 100%; height: 100%; max-width: none; object-fit: cover; object-position: center; display: block; }
  .drawer__progress_products .product__upsell_item_heading {
    display: flex; flex-direction: column; flex: 1; min-width: 0; min-height: 0;
  }
  .drawer__progress_products .product-form__buttons {
    margin-top: auto; padding-top: 10px; width: 100%; max-width: 100%; box-sizing: border-box;
  }
  .drawer__progress_products .product-form__submit {
    width: 100%; box-sizing: border-box; font-size: 12px; padding: 6px 10px; position: relative;
    background: var(--color-1, #ef022d); color: #fff; border: 1px solid transparent;
    border-radius: var(--buttons-radius, 4px); cursor: pointer; text-transform: uppercase;
  }
  .drawer__progress_products .product__upsell_item_title {
    font-size: 12px; line-height: 16px; text-align: center; word-break: break-word;
    display: block; margin-bottom: 8px; color: #000;
  }
  .drawer__progress_products .product__upsell_item_title:visited,
  .drawer__progress_products .product__upsell_item_title:hover,
  .drawer__progress_products .product__upsell_item_title:focus {
    color: #000;
  }
  .drawer__progress_products .product__upsell_item_heading .product__upsell_price {
    text-align: center; margin-top: 0.35rem; margin-bottom: 0; display: block;
    font-size: 1.15rem; line-height: 1.3; font-weight: 600;
  }
  .drawer__progress_products .product__upsell_item_variants {
    display: flex; flex-wrap: nowrap; gap: 6px; margin-top: 8px; width: 100%; min-width: 0;
    overflow-x: auto; overflow-y: hidden; justify-content: flex-start; padding-bottom: 4px;
    -webkit-overflow-scrolling: touch; scrollbar-width: thin;
  }
  .drawer__progress_products .product__upsell_item_variant {
    flex-shrink: 0; white-space: nowrap; padding: 0.3rem 0.5rem; font-size: 10px; box-sizing: border-box;
  }
  @media (max-width: 1023px) {
    .drawer__progress_products .product__upsell_item_top {
      flex-direction: column;
      align-items: center;
    }
    .drawer__progress_products .product__upsell_item_top .img_wr {
      width: min(9.5rem, 40vw);
      max-width: min(9.5rem, 40vw);
      margin-left: auto;
      margin-right: auto;
    }
  .drawer__progress_products .product__upsell_item_top .img_wr img {
    width: 100%;
    height: 100%;
    aspect-ratio: auto;
    object-fit: cover;
    object-position: center;
    max-width: none;
  }
    .drawer__progress_products .product__upsell_item_top .product__upsell_item_heading {
      flex: none;
      width: 100%;
      min-width: 0;
    }
  }
  @media (max-width: 767px) {
    .drawer__progress_products .swiper-slide { height: auto !important; }
    .drawer__progress_products .drawer__progress_products_item { min-height: 0; height: auto; }
    .drawer__progress_products .product__upsell_item { min-height: 0; height: auto; }
  }
</style>
{% capture drawer_products %}
  {% assign drawer_pool_collection = settings.order_related_collection %}
  {% assign drawer_random_limit = settings.order_related_collection_limit | default: 5 %}
  {% assign drawer_collection_eligible = 0 %}

  {% if drawer_pool_collection != blank %}
    {% for p in drawer_pool_collection.products %}
      {% if p.available %}
        {% assign _tl = p.title | downcase %}
        {% assign _skip_h = false %}
        {% if _tl contains 'heel pad' or _tl contains 'heelpad' or _tl contains 'podpiętka' or _tl contains 'podpietka' or _tl contains 'fersenpolster' %}
          {% assign _skip_h = true %}
        {% endif %}
        {% if p.tags contains 'heel-pad' or p.tags contains 'heel_pad' or p.tags contains 'heelpad' %}
          {% assign _skip_h = true %}
        {% endif %}
        {% unless _skip_h %}
          {% assign drawer_collection_eligible = drawer_collection_eligible | plus: 1 %}
        {% endunless %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% assign drawer_use_collection_random = false %}
  {% if drawer_pool_collection != blank and drawer_collection_eligible > 0 %}
    {% assign drawer_use_collection_random = true %}
  {% endif %}

  {% if drawer_use_collection_random or settings.order_related_products != blank %}
    <div class="drawer__progress_products swiper">
      <div
        class="swiper-wrapper"
        {% if drawer_use_collection_random %}
          id="drawer-upsell-random-wrapper"
          data-random-pool
          data-random-limit="{{ drawer_random_limit }}"
        {% endif %}
      >
        {% if drawer_use_collection_random %}
          {% for item in drawer_pool_collection.products %}
            {% if item.available %}
              {% render 'drawer-progress-upsell-if-not-heeled', item: item, section_id: section_id, random_pick: true %}
            {% endif %}
          {% endfor %}
        {% else %}
          {% for item in settings.order_related_products %}
            {% if item.available %}
              {% render 'drawer-progress-upsell-if-not-heeled', item: item, section_id: section_id %}
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>

      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>
    {% if drawer_use_collection_random %}
      <script>
        (function () {
          var wrap = document.getElementById('drawer-upsell-random-wrapper');
          if (!wrap || !wrap.hasAttribute('data-random-pool')) return;
          var limit = parseInt(wrap.getAttribute('data-random-limit'), 10) || 5;
          var slides = wrap.querySelectorAll('.swiper-slide[data-upsell-random]');
          if (!slides.length) return;
          var arr = Array.prototype.slice.call(slides);
          arr.sort(function () {
            return 0.5 - Math.random();
          });
          var selected = arr.slice(0, Math.min(limit, arr.length));
          wrap.innerHTML = '';
          selected.forEach(function (el) {
            wrap.appendChild(el);
          });
        })();
      </script>
    {% endif %}
  {% endif %}
{% endcapture %}

{% comment %} {% if progress_bar_setting == 'shipping' %}
  {% assign progressThreshold = 0 %}
  {% assign freeShipping = false %}

  {% assign threshold = settings.order_total | times: 100.0 %}
  {% assign progressThreshold = cart.total_price | divided_by: threshold %}

  {% if progressThreshold > 1 %}
    {% assign freeShipping = true %}
  {% endif %}

  {% if threshold != '' %}
    <div id="drawer__progress" class="drawer__progress">
      <div class="drawer__progress_text">
        {% if freeShipping %}
          {{ 'sections.cart.progress_free_shipping' | t }}
        {% else %}
          {% assign value = threshold | minus: cart.total_price | money %}
          {{ 'sections.cart.progress_text_order_value' | t: value: value }}
        {% endif %}
      </div>
      <div class="drawer__progress_bar ">
        <div class="line" style="width: {{ progressThreshold | times: 100 | at_most: 100 }}%;"></div>
      </div>
    </div>

    {{ drawer_products }}
  {% endif %}
{% elsif progress_bar_setting == 'discount' %}
  {% assign discount5 = 50000 %}
  {% assign discount15 = 120000 %}
  {% assign discount20 = 240000 %}
  {% assign discount25 = 360000 %}

  {% assign total = cart.total_price %}

  {% assign nextDiscount = '' %}
  {% assign value = 0 %}
  {% assign progressThreshold = 0 %}

  {% if total < discount5 %}
    {% assign nextDiscount = '5%' %}
    {% assign value = discount5 | minus: total %}
    {% assign progressThreshold = total | times: 100.0 | divided_by: discount5 %}
  {% elsif total < discount15 %}
    {% assign nextDiscount = '15%' %}
    {% assign value = discount15 | minus: total %}
    {% assign progressThreshold = total | times: 100.0 | divided_by: discount15 %}
  {% elsif total < discount20 %}
    {% assign nextDiscount = '20%' %}
    {% assign progressThreshold = total | times: 100.0 | divided_by: discount20 %}
    {% assign value = discount20 | minus: total %}
  {% elsif total < discount25 %}
    {% assign nextDiscount = '25%' %}
    {% assign value = discount25 | minus: total %}
    {% assign progressThreshold = total | times: 100.0 | divided_by: discount25 %}
  {% else %}
    {% assign nextDiscount = 'full discount' %}
    {% assign progressThreshold = 100.0 %}
  {% endif %}

  {% if total != 0 and nextDiscount != 'full discount' %}
    <div id="drawer__progress" class="drawer__progress">
      <div class="drawer__progress_text">
        {% assign value_money = value | money %}
        {{ 'sections.cart.progress_text_discount' | t: value: value_money, nextDiscount: nextDiscount }}
      </div>
      <div class="drawer__progress_bar">
        <div class="line" style="width: {{ progressThreshold }}%;"></div>
      </div>
    </div>
  {% else %}
    <div class="drawer__progress_text">
      {{ 'sections.cart.progress_max_discount' | t }}
    </div>
  {% endif %}

{% endif %} {% endcomment %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.drawer__progress_products .product-form__submit').forEach(function (button) {
      button.addEventListener('click', function (e) {
        e.preventDefault();

        const productWrapper = button.closest('.product__upsell_item');
        if (!productWrapper) return;

        let variantId = null;

        const activeVariant = productWrapper.querySelector('.product__upsell_item_variant.active');
        if (activeVariant) {
          variantId = activeVariant.dataset.id;
        } else {
          variantId = productWrapper.dataset.id;
        }

        if (!variantId) {
          alert({{ 'sections.cart.cart_upsell_variant_error' | t | json }});
          return;
        }

        fetch(window.routes.cart_add_url + '.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify({
            id: variantId,
            quantity: 1,
          }),
        })
          .then(function (response) {
            if (!response.ok) throw new Error('Cart add error');
            return response.json();
          })
          .then(function () {
            location.reload();
          })
          .catch(function (err) {
            console.error(err);
          });
      });
    });

    document.querySelectorAll('.drawer__progress_products .product__upsell_item_variant').forEach(function (variant) {
      variant.addEventListener('click', function () {
        const group = variant.closest('.product__upsell_item_variants');
        if (!group) return;

        group.querySelectorAll('.product__upsell_item_variant').forEach(function (v) {
          v.classList.remove('active');
        });
        variant.classList.add('active');
      });
    });
  });
</script>
