{% comment %}
  Mats set option label — value-based image mapping (works when meta body_type is blank or any known type).
  Accepts: product, option, section, value, index, value_norm, needle, body_types, meta_body_type, trunk_word, trunk_tooltip_content
{% endcomment %}
{%- liquid
  if meta_body_type != blank
    capture meta_body_type_normalized
      render 'evamats-body-type-slug', body_type: meta_body_type
    endcapture
    assign meta_body_type = meta_body_type_normalized | strip
  else
    capture meta_body_type_normalized
      render 'evamats-body-type-slug', product: product
    endcapture
    assign meta_body_type = meta_body_type_normalized | strip
  endif
  assign value_lowercase = value | downcase

  assign z_al_dywanik = '|||dywanik kierowcy|||mata kierowcy|||only driver mat|||driver mat|||front driver mat|||pouze koberec řidiče|||'
  assign z_al_przod = '|||przód|||przed|||front|||vorne|||přední|||'
  assign z_al_tyl = '|||tył|||tyl|||rear|||hinten|||back row|||zadní|||'
  assign z_al_przod_tyl = '|||przód + tył|||przod + tyl|||front + rear|||front+rear|||vorne + hinten|||přední + zadní|||přední a zadní|||'
  assign z_al_mata_bag = '|||mata do bagażnika|||mata do bagaznika|||trunk mat|||boot mat|||trunk|||kufr|||'
  assign z_al_przod_bag = '|||przód + tył + bagażnik|||przod + tyl + bagaznik|||front + rear + trunk|||přední + zadní + kufr|||'
  assign z_al_3rzad = '|||przód + tył + 3 rząd|||przod + tyl + 3 rzad|||front + rear + 3rd row|||front + rear + third row|||'
  assign z_al_3rz_maly = '|||przód + tył + 3 rząd + mały bagażnik|||przod + tyl + 3 rzad + maly bagaznik|||front + rear + third row + small trunk|||'
  assign z_al_3rz_duzy = '|||przód + tył + 3 rząd + duży bagażnik|||przod + tyl + 3 rzad + duzy bagaznik|||front + rear + third row + huge trunk|||front + rear + third row + large trunk|||'
  assign z_al_3r2b = '|||3 rzędy + 2 bagażniki (duży | mały)|||3 rzedu + 2 bagazniki|||3 rows 2 trunks|||'
  assign z_al_przod_duzy_bag = '|||przód + tył + duży bagażnik|||przod + tyl + duzy bagaznik|||front + rear + large trunk|||'

  assign zestaw_img_5os = ''
  assign zestaw_img_7os = ''
  assign zestaw_badge = ''

  if value_norm == '3 rzędy + 2 bagażniki (duży | mały)' or z_al_3r2b contains needle
    assign zestaw_img_7os = '7os-mat-set-trunk-2.svg'
    assign zestaw_badge = '-15%'
  elsif value_norm == 'przód + tył + 3 rząd + duży bagażnik' or z_al_3rz_duzy contains needle
    assign zestaw_img_7os = '7os-mat-set-row-trunk-l.svg'
    assign zestaw_badge = '-15%'
  elsif value_norm == 'przód + tył + 3 rząd + mały bagażnik' or z_al_3rz_maly contains needle
    assign zestaw_img_7os = '7os-mat-set-row-trunk-sm.svg'
    assign zestaw_badge = '-15%'
  elsif value_norm == 'przód + tył + 3 rząd' or z_al_3rzad contains needle
    assign zestaw_img_7os = '7os-mat-set-row.svg'
    assign zestaw_badge = '-15%'
  elsif value_norm == 'przód + tył + duży bagażnik' or z_al_przod_duzy_bag contains needle
    assign zestaw_img_7os = '7os-mat-set-trunk-l.svg'
    assign zestaw_badge = '-15%'
  elsif value_norm == 'przód + tył + bagażnik' or z_al_przod_bag contains needle
    assign zestaw_img_5os = '5os-mat-set.svg'
    assign zestaw_img_7os = '7os-mat-front-back-trunk.svg'
    assign zestaw_badge = '-15%'
  elsif value_norm == 'mata do bagażnika' or z_al_mata_bag contains needle
    assign zestaw_img_5os = '5os-mat-trunk.svg'
    assign zestaw_img_7os = '7os-mat-trunk.svg'
  elsif value_norm == 'przód + tył' or z_al_przod_tyl contains needle
    assign zestaw_img_5os = '5os-mat-front-back.svg'
    assign zestaw_img_7os = '7os-mat-front-back.svg'
  elsif value_norm == 'tył' or z_al_tyl contains needle
    assign zestaw_img_5os = '5os-mat-back-2.svg'
    assign zestaw_img_7os = '7os-mat-back-2.svg'
  elsif value_norm == 'przód' or z_al_przod contains needle
    assign zestaw_img_5os = '5os-mat-front-2.svg'
    assign zestaw_img_7os = '7os-mat-front-2.svg'
  elsif value_norm == 'dywanik kierowcy' or z_al_dywanik contains needle
    assign zestaw_img_5os = '5os-mat-front-1.svg'
    assign zestaw_img_7os = '7os-mat-front-1.svg'
  endif

  case meta_body_type
    when '5os'
      assign default_images = '5os-mat-front-1.svg|5os-mat-front-2.svg|5os-mat-back-2.svg|5os-mat-front-back.svg|5os-mat-trunk.svg|5os-mat-set.svg' | split: '|'
      assign badges = '||-5%||-10%||-15%' | split: '|'
    when '2os'
      assign default_images = '2os-mat-front-1.svg|2os-mat-front-2.svg|5os-mat-trunk.svg|5os-mat-front-trunk.svg|2os-mat-front-trunk-front.svg' | split: '|'
      assign badges = '||-5%||-10%' | split: '|'
    when 'electro'
      assign default_images = '5os-mat-front-1.svg|5os-mat-front-2.svg|5os-mat-back-2.svg|5os-mat-front-back.svg|5os-mat-trunk.svg|5os-mat-set.svg|5os-mat-set-front-back.svg' | split: '|'
      assign badges = '||-5%|-5%|-10%||-15%|-15%' | split: '|'
    when 'electro_7os'
      assign default_images = '7os-mat-front-1.svg|7os-mat-front-2.svg|7os-mat-back-2.svg|7os-mat-front-back.svg|7os-mat-trunk.svg|7os-mat-set-row.svg|7os-mat-set-row-trunk-sm.svg|7os-mat-set-row-trunk-l.svg|7os-mat-set-trunk-l.svg|7os-mat-set-trunk-sm-front.svg|7os-mat-set-trunk-l-front.svg|7os-mat-set-front-back-trunk-sm-front.svg' | split: '|'
      assign badges = '|-5%||-10%||-15%|-15%|-15%|-15%|-15%|-15%|-15%' | split: '|'
    when 'minivan'
      assign default_images = 'minivan-1.svg|minivan-2.svg|minivan-3.svg|minivan-4.svg|minivan-5.svg|minivan-6.svg|minivan-7.svg|minivan-8.svg|minivan-8.svg' | split: '|'
      assign badges = '|-5%|-15%|-15%|||-15%|-15%|-15%' | split: '|'
    when 'minivan_mini'
      assign default_images = 'minivan-1.svg|minivan-2.svg|minivan-3.svg|minivan-4.svg|minivan-5.svg|minivan-7.svg' | split: '|'
      assign badges = '|-5%|-15%|-15%||-15%' | split: '|'
    when 'bus'
      assign default_images = 'bus-1.svg|bus-2.svg|bus-3.svg|bus-4.svg|bus-6.svg|bus-5.svg' | split: '|'
      assign badges = '|-10%|-15%|-15%|-15%|' | split: '|' 
    when 'bus_solid'
      assign default_images = 'bus_solid_1.svg|van-duzy-12.svg|bus_solid_3.svg|bus_solid_4.svg|bus_solid_5.svg' | split: '|'
      assign badges = '|-10%|-15%|-15%|-15%' | split: '|'
    when 'camper'
      assign default_images = 'bus-2.svg' | split: '|'
      assign badges = '' | split: '|'
    when 'pickup2kabina'
      assign default_images = 'pickup-1.svg|pickup-2.svg|pickup-3.svg|pickup-4.svg|pickup-5.svg|pickup-6.svg' | split: '|'
      assign badges = '||-5%|-10%|-15%||-15%' | split: '|'
    when 'tir'
      assign default_images = 'tir-1.svg|tir-2.svg|tir-3.svg' | split: '|'
      assign badges = '||-10%|-15%' | split: '|'
    when 'van_duzy'
      assign default_images = 'van-duzy-4.svg|van-duzy-1.svg|van-duzy-2.svg|van-duzy-3.svg' | split: '|'
      assign badges = '||-10%|-15%|' | split: '|'
    when 'van_duzy_separate'
      assign default_images = 'van-duzy-4.svg|van_duzy_separate_2.svg|van_duzy_separate_3.svg|van-duzy-3.svg' | split: '|'
      assign badges = '||-10%|-15%|' | split: '|'
    when 'van_duzy_separate_2_row'
      assign default_images = 'van-duzy-4.svg|van-duzy-6.svg|van-duzy-5.svg|van-duzy-8.svg|van-duzy-7.svg|van-duzy-3.svg' | split: '|'
      assign badges = '||-15%|||' | split: '|'
    when 'van_duzy_solid'
      assign default_images = 'van-duzy-1.svg|van-duzy-2.svg|van-duzy-3.svg' | split: '|'
      assign badges = '||-10%|-15%' | split: '|'

    when '7os'
      assign default_images = '7os-mat-front-1.svg|7os-mat-front-2.svg|7os-mat-back-2.svg|7os-mat-front-back.svg|7os-mat-trunk.svg|7os-mat-set-row.svg|7os-mat-set-row-trunk-sm.svg|7os-mat-set-row-trunk-l.svg|7os-mat-set-trunk-2.svg|7os-mat-set-trunk-l.svg' | split: '|'
      assign badges = '|||-10%||-15%|-15%|-15%|-15%|-15%|-15%' | split: '|'

    when 'van_duzy_solid_2_row'
      assign default_images = 'van-duzy-10.svg|van-duzy-9.svg|van-duzy-12.svg|van-duzy-11.svg|van-duzy-3.svg' | split: '|'
      assign badges = '||-10%|-15%||' | split: '|'
    when 'tractor'
      assign default_images = 'tractor.svg' | split: '|'
      assign badges = '' | split: '|'
    when 'van_maly'
      assign default_images = 'van-duzy-4.svg|van_duzy_separate_2.svg|van-duzy-3.svg|van_duzy_separate_3.svg' | split: '|'
      assign badges = '||-5%||-10%' | split: '|'
    when 'custom'
      assign default_images = '5os-mat-front-2.svg|5os-mat-back-2.svg|5os-mat-front-back.svg|5os-mat-trunk.svg|5os-mat-set.svg' | split: '|'
      assign badges = '' | split: '|'
    when 'pickup'
      assign default_images = 'pickup-1.svg|pickup-2.svg|pickup-7.svg|pickup-5.svg' | split: '|'
      assign badges = '||-5%|-10%|' | split: '|'
    else
      assign default_images = '' | split: '|'
      assign badges = '' | split: '|'
  endcase

  assign custom_images = product.metafields.custom.custom_mats_set_images.value
  assign custom_image = custom_images[index]
  assign fallback_image = default_images[index]
  assign badge = badges[index]

  if body_types != '' and zestaw_badge != ''
    assign badge = zestaw_badge
  endif

  assign use_zestaw_mapping = false
  if body_types != ''
    if zestaw_img_5os != '' or zestaw_img_7os != ''
      assign meta_norm = meta_body_type | downcase
      unless meta_norm contains 'van' or meta_norm contains 'minivan' or meta_norm contains 'tractor' or meta_norm contains 'pickup' or meta_norm contains 'bus' or meta_norm contains 'camper' or meta_norm contains 'tir' or meta_norm == '2os'
        assign use_zestaw_mapping = true
      endunless
    endif
  endif

  assign initial_src = ''
  if use_zestaw_mapping
    if custom_image and custom_image != '-'
      assign initial_src = custom_image
    elsif meta_body_type contains '7os' and zestaw_img_7os != ''
      assign initial_src = zestaw_img_7os | file_url
    elsif zestaw_img_5os != ''
      assign initial_src = zestaw_img_5os | file_url
    elsif zestaw_img_7os != ''
      assign initial_src = zestaw_img_7os | file_url
    endif
  elsif custom_image and custom_image != '-'
    assign initial_src = custom_image
  elsif fallback_image != blank
    assign initial_src = fallback_image | file_url
  elsif zestaw_img_5os != ''
    assign initial_src = zestaw_img_5os | file_url
  elsif zestaw_img_7os != ''
    assign initial_src = zestaw_img_7os | file_url
  endif
-%}

<label
  for="{{ section.id }}-{{ option.position }}-{{ index }}"
  {% if value contains '#MWS' or value contains 'Default Title' %} style="display: none"{% endif %}
  class="default_option"
>
  {%- if initial_src != blank -%}
    <img
      src="{{ initial_src }}"
      {% if use_zestaw_mapping and zestaw_img_5os != '' %}data-image-5os="{{ zestaw_img_5os | file_url }}"{% endif %}
      {% if use_zestaw_mapping and zestaw_img_7os != '' %}data-image-7os="{{ zestaw_img_7os | file_url }}"{% endif %}
      alt=""
      loading="lazy"
      width="72"
      height="72"
    >
  {%- endif -%}

  <div class="label__tooltip">{{ value }}</div>

  {%- if badge != blank -%}
    <div class="label_badge">{{ badge }}</div>
  {%- endif -%}

  {%- if trunk_word != blank and value_lowercase contains trunk_word -%}
  <span
    class="trunk_message"
    tabindex="0"
    role="button"
    aria-label="{{ 'general.config.label_trunk' | t | escape }}"
    aria-describedby="trunk-tooltip-{{ section.id }}-{{ index }}"
  >
    <span class="trunk_message__icon trunk_message__icon--default" aria-hidden="true">
      {%- render 'evamats-trunk-attention-icon', state: 'default' -%}
    </span>
    <span class="trunk_message__icon trunk_message__icon--active" aria-hidden="true">
      {%- render 'evamats-trunk-attention-icon', state: 'active' -%}
    </span>
    <span
      class="trunk_message__tooltip rte"
      id="trunk-tooltip-{{ section.id }}-{{ index }}"
      role="tooltip"
    >
      {%- if trunk_tooltip_content != blank -%}
        {{- trunk_tooltip_content -}}
      {%- else -%}
        {{- 'general.config.label_trunk' | t -}}
      {%- endif -%}
    </span>
  </span>
  {%- endif -%}
</label>
