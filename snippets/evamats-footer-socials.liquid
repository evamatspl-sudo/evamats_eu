{%- comment -%}
  Social row — same markup/classes as video_reviews.liquid (square icons in footer).
  @param section {section} — facebook_url, instagram_url, tiktok_url, youtube_url, facebook_label
{%- endcomment -%}

{%- liquid
  assign facebook_url = section.settings.facebook_url | default: settings.social_facebook_link
  assign instagram_url = section.settings.instagram_url | default: settings.social_instagram_link
  assign tiktok_url = section.settings.tiktok_url | default: settings.social_tiktok_link
  assign youtube_url = section.settings.youtube_url | default: settings.social_youtube_link
  assign threads_url = section.settings.threads_url | default: settings.social_threads_link

  assign show_socials = false
  if facebook_url != blank or instagram_url != blank or tiktok_url != blank or youtube_url != blank or threads_url != blank
    assign show_socials = true
  endif
-%}

{%- if show_socials -%}
  <div class="video_reviews__socials" role="navigation" aria-label="Social media">
    {%- if facebook_url != blank -%}
      <a
        class="video_reviews__social-link video_reviews__social-link--facebook"
        href="{{ facebook_url }}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Facebook"
      >
        <span class="video_reviews__social-fb-icon" aria-hidden="true">
          <svg width="12" height="22" viewBox="0 0 12 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M11.4021 7.5834H7.58333V5.41673C7.58333 4.29873 7.67433 3.59457 9.27658 3.59457H11.3002V0.149568C10.3155 0.0477344 9.32533 -0.00209896 8.33408 6.77083e-05C5.395 6.77083e-05 3.25 1.79515 3.25 5.09065V7.5834H0V11.9167L3.25 11.9157V21.6667H7.58333V11.9135L10.9048 11.9124L11.4021 7.5834Z"
              fill="currentColor"
            />
          </svg>
        </span>
        {%- if section.settings.facebook_label != blank -%}
          <span class="video_reviews__social-fb-label">{{ section.settings.facebook_label | escape }}</span>
        {%- endif -%}
        <span class="video_reviews__social-fb-icon video_reviews__social-fb-icon--external" aria-hidden="true">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M0.338778 0L8.5206 0C9.02267 0 9.42969 0.407014 9.42969 0.909091V9.09091H7.61151V3.10383L1.28882 9.42651L0.00317419 8.14087L6.32586 1.81818L0.338778 1.81818L0.338778 0Z"
              fill="currentColor"
            />
          </svg>
        </span>
      </a>
    {%- endif -%}

    {%- if instagram_url != blank -%}
      <a class="video_reviews__social-link" href="{{ instagram_url }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path
            d="M8.9401 2.70801C5.5094 2.70801 2.71094 5.50647 2.71094 8.93717V17.0622C2.71094 20.4924 5.5093 23.2913 8.9401 23.2913H17.0651C20.4954 23.2913 23.2943 20.4925 23.2943 17.0622V8.93717C23.2943 5.50637 20.4953 2.70801 17.0651 2.70801H8.9401ZM8.9401 4.33301H17.0651C19.617 4.33301 21.6693 6.38473 21.6693 8.93717V17.0622C21.6693 19.614 19.6169 21.6663 17.0651 21.6663H8.9401C6.38766 21.6663 4.33594 19.6141 4.33594 17.0622V8.93717C4.33594 6.38463 6.38756 4.33301 8.9401 4.33301ZM18.4193 6.49967C17.8207 6.49967 17.3359 6.98447 17.3359 7.58301C17.3359 8.18155 17.8207 8.66634 18.4193 8.66634C19.0178 8.66634 19.5026 8.18155 19.5026 7.58301C19.5026 6.98447 19.0178 6.49967 18.4193 6.49967ZM13.0026 7.58301C10.0208 7.58301 7.58594 10.0179 7.58594 12.9997C7.58594 15.9815 10.0208 18.4163 13.0026 18.4163C15.9844 18.4163 18.4193 15.9815 18.4193 12.9997C18.4193 10.0179 15.9844 7.58301 13.0026 7.58301ZM13.0026 9.20801C15.106 9.20801 16.7943 10.8963 16.7943 12.9997C16.7943 15.1031 15.106 16.7913 13.0026 16.7913C10.8992 16.7913 9.21094 15.1031 9.21094 12.9997C9.21094 10.8963 10.8992 9.20801 13.0026 9.20801Z"
            fill="currentColor"
          />
        </svg>
      </a>
    {%- endif -%}

    {%- if tiktok_url != blank -%}
      <a class="video_reviews__social-link" href="{{ tiktok_url }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
        <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
