 {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}
 {% render 'product-media-gallery_without_edges',
   images: withoutEdgesImages,
   gallery_product: product,
   variant_images: variant_images,
   images_only: single_gallery
 %}
 {% unless single_gallery %}
   {% render 'product-media-gallery_with_edges', images: withEdgesImages, gallery_product: product, variant_images: variant_images %}
 {% endunless %}
{% endif %}
</div>
