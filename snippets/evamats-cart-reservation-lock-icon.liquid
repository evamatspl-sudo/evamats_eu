{%- assign lock_clip_id = 'cart-lock-clip-' | append: section.id -%}
{%- assign lock_mask_id = 'cart-lock-mask-' | append: section.id -%}
<svg class="evamats-cart-reservation-lock-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
  <g clip-path="url(#{{ lock_clip_id }})">
    <mask id="{{ lock_mask_id }}" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24">
      <path d="M24 0H0V24H24V0Z" fill="white"/>
    </mask>
    <g mask="url(#{{ lock_mask_id }})">
      <path d="M6 10V8C6 4.69 7 2 12 2C17 2 18 4.69 18 8V10" stroke="#1B1D22" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M17 22H7C3 22 2 21 2 17V15C2 11 3 10 7 10H17C21 10 22 11 22 15V17C22 21 21 22 17 22Z" fill="#FEC622"/>
    </g>
  </g>
  <defs>
    <clipPath id="{{ lock_clip_id }}">
      <rect width="24" height="24" fill="white"/>
    </clipPath>
  </defs>
</svg>
