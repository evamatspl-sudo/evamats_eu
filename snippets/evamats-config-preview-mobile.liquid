{%- comment -%}
  Mobile mat preview popup — Figma 1710:26297 (Selector-popup)
{%- endcomment -%}
{%- liquid
  assign has_mats_type = false
  if show_mats_type_chip
    assign has_mats_type = true
  elsif product
    assign option_mats_type = 'general.config.mats_type' | t
    for product_option in product.options_with_values
      if product_option.name == option_mats_type or product_option.name == 'Mats type' or product_option.name contains option_mats_type
        assign has_mats_type = true
      endif
    endfor
  endif
-%}
<div class="product__config_image product__config_image--main product__config_image--mobile evamats-config-preview">
  <button
    type="button"
    class="evamats-config-preview__reopen"
    data-preview-reopen
    aria-label="{{ 'general.config.preview_badge' | t }}"
  >
    {{ 'general.config.preview_badge' | t }}
    {% render 'icon-eye' %}
  </button>

  <div class="evamats-config-preview__panel">
    <button
      type="button"
      class="evamats-config-preview__close"
      data-preview-close
      aria-label="{{ 'accessibility.close' | t }}"
    >
      {% render 'icon-close' %}
    </button>

    {%- if product_title != blank -%}
      <p class="evamats-config-preview__title">{{ product_title }}</p>
    {%- endif -%}

    <div class="evamats-config-preview__chips">
      {%- unless show_mats_set_chip == false -%}
        <div class="evamats-config-preview__chip" data-name="mats_set" hidden></div>
      {%- endunless -%}
      {%- if has_mats_type -%}
        <div class="evamats-config-preview__chip" data-name="mats_type" hidden></div>
      {%- endif -%}
      <div class="evamats-config-preview__chip" data-type="matPattern" hidden></div>
      <div class="evamats-config-preview__chip" data-type="matColor" hidden></div>
      <div class="evamats-config-preview__chip" data-type="trimColor" data-chip-label="{{ 'general.config.trim_color' | t }}" hidden></div>
    </div>

    <div class="evamats-config-preview__stage">
      <div class="evamats-config-preview__swatches">
        <div class="evamats-config-preview__swatch" data-type="matPattern" hidden></div>
        <div class="evamats-config-preview__swatch" data-type="trimColor" hidden></div>
      </div>

      <div class="evamats-config-preview__media-col">
        <div class="evamats-config-preview__media-row">
          <button
            type="button"
            class="evamats-config-preview__toggle"
            data-preview-mat-toggle
            aria-label="{{ 'general.config.preview_hide' | t }}"
            aria-pressed="false"
            data-label-hide="{{ 'general.config.preview_hide' | t | escape }}"
            data-label-show="{{ 'general.config.preview_badge' | t | escape }}"
          >
            <span class="evamats-config-preview__hide-label">{{ 'general.config.preview_hide' | t }}</span>
            <span class="evamats-config-preview__show-label">{{ 'general.config.preview_badge' | t }}</span>
          </button>

          <div class="evamats-config-preview__media">
            <img
              src="{{ '1x1_000000.webp' | file_url }}"
              alt=""
              class="product__config_image--mobile_image evamats-config-preview__image"
              width="600"
              height="600"
              loading="lazy"
            >
            <button
              type="button"
              class="evamats-config-preview__zoom"
              data-preview-zoom
              aria-label="{{ 'general.config.preview_zoom' | t }}"
            >
              {% render 'icon-zoom' %}
            </button>
          </div>
        </div>

        <button
          type="button"
          class="evamats-config-preview__enlarge"
          data-preview-enlarge
          aria-expanded="false"
          data-label-enlarge="{{ 'general.config.preview_enlarge' | t | escape }}"
          data-label-shrink="{{ 'general.config.preview_shrink' | t | escape }}"
        >
          <span data-preview-enlarge-label>{{ 'general.config.preview_enlarge' | t }}</span>
          {% render 'icon-caret' %}
        </button>
      </div>
    </div>

    <p class="evamats-config-preview__note">*{{ 'general.config.comment' | t }}</p>
  </div>
</div>
