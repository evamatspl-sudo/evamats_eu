        <span class="evamats-config-option-label">{{ value | remove: 'EVAMATS' }}</span>

      </label>
    {% elsif is_simple_product %}
      {%- liquid
        assign value_variant = nil
        assign gift_amount_variant = nil

        if option_is_gift_amount
          if option.position == 2
            assign selected_card_type = product.selected_or_first_available_variant.option1
            for variant in product.variants
              if variant.option1 == selected_card_type and variant.option2 == value
                assign gift_amount_variant = variant
                assign value_variant = variant
                break
              endif
            endfor
          elsif option.position == 1
            assign selected_card_type = product.selected_or_first_available_variant.option2
            for variant in product.variants
              if variant.option2 == selected_card_type and variant.option1 == value
                assign gift_amount_variant = variant
                assign value_variant = variant
                break
              endif
            endfor
          endif
        else
          for variant in product.variants
            case option.position
              when 1
                if variant.option1 == value
                  assign value_variant = variant
                endif
              when 2
                if variant.option2 == value
                  assign value_variant = variant
                endif
              when 3
                if variant.option3 == value
                  assign value_variant = variant
                endif
            endcase
          endfor
        endif
      -%}
      {% if option_is_gift_amount %}
        <label
          for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
          {% if value contains '#MWS' or value contains 'Default Title' %} style="display: none"{% endif %}
          class="evamats-product-option__swatch evamats-product-option__amount-swatch"
        >
          <span class="evamats-product-option__amount-media">
            {%- if value_variant.featured_media -%}
              {{
                value_variant.featured_media
                | image_url: width: 220
                | image_tag: loading: 'lazy', widths: '110, 220', sizes: '110px', alt: value, class: 'evamats-product-option__amount-image'
              }}
            {%- elsif product.featured_media -%}
              {{
                product.featured_media
                | image_url: width: 220
                | image_tag: loading: 'lazy', widths: '110, 220', sizes: '110px', alt: value, class: 'evamats-product-option__amount-image'
              }}
            {%- endif -%}
          </span>
          <span class="evamats-product-option__amount-label" data-gift-amount-value="{{ value | escape }}">
            {%- if gift_amount_variant -%}
              {{ gift_amount_variant.price | money }}
            {%- else -%}
              {{ value }}
            {%- endif -%}
          </span>
          <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
        </label>
      {% elsif option_has_swatch and value_variant.featured_media %}
        <label
          for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
          {% if value contains '#MWS' or value contains 'Default Title' %} style="display: none"{% endif %}
          class="evamats-product-option__swatch"
        >
          {{
            value_variant.featured_media
