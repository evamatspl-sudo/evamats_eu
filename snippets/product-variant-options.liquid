{% comment %}
  Renders product variant options

  Accepts:
  - product: {Object} product object.
  - option: {Object} current product_option object.
  - block: {Object} block object.


  Usage:
  {% render 'product-variant-options',
    product: product,
    option: option,
    block: block
  %}
{% endcomment %}
{%- liquid
  assign variants_available_arr = product.variants | map: 'available'
  assign variants_option1_arr = product.variants | map: 'option1'
  assign variants_option2_arr = product.variants | map: 'option2'
  assign variants_option3_arr = product.variants | map: 'option3'

  assign product_form_id = 'product-form-' | append: section.id

  assign meta_body_type = product.metafields.custom.body_type
  assign trunk_tooltip_content = section.settings.trunk_message
  if meta_body_type == '5os' or meta_body_type == '7os'
    assign trunk_tooltip_content = section.settings.trunk_message_5_7_os
  endif
  capture body_type_slug
    render 'evamats-body-type-slug', body_type: meta_body_type, product: product
  endcapture
  assign body_type_slug = body_type_slug | strip
  assign z_al_dywanik = '|||dywanik kierowcy|||mata kierowcy|||only driver mat|||driver mat|||front driver mat|||pouze koberec řidiče|||'
  assign z_al_przod = '|||przód|||przed|||front|||vorne|||přední|||'
  assign z_al_tyl = '|||tył|||tyl|||rear|||hinten|||back row|||zadní|||'
  assign z_al_przod_tyl = '|||przód + tył|||przod + tyl|||front + rear|||front+rear|||vorne + hinten|||přední + zadní|||přední a zadní|||'
  assign z_al_mata_bag = '|||mata do bagażnika|||mata do bagaznika|||trunk mat|||boot mat|||trunk|||kufr|||'
  assign z_al_przod_bag = '|||przód + tył + bagażnik|||przod + tyl + bagaznik|||front + rear + trunk|||přední + zadní + kufr|||'
  assign z_al_3rzad = '|||przód + tył + 3 rząd|||przod + tyl + 3 rzad|||front + rear + 3rd row|||front + rear + third row|||'
  assign z_al_3rz_maly = '|||przód + tył + 3 rząd + mały bagażnik|||przod + tyl + 3 rzad + maly bagaznik|||front + rear + third row + small trunk|||'
  assign z_al_3rz_duzy = '|||przód + tył + 3 rząd + duży bagażnik|||przod + tyl + 3 rzad + duzy bagaznik|||front + rear + third row + huge trunk|||front + rear + third row + large trunk|||'
  assign z_al_3r2b = '|||3 rzędy + 2 bagażniki (duży | mały)|||3 rzedu + 2 bagazniki|||3 rows 2 trunks|||'
  assign z_al_przod_duzy_bag = '|||przód + tył + duży bagażnik|||przod + tyl + duzy bagaznik|||front + rear + large trunk|||'
  assign zestaw_body_both_str = z_al_dywanik | append: z_al_przod | append: z_al_tyl | append: z_al_przod_tyl | append: z_al_mata_bag
  assign zestaw_body_5os_str = z_al_przod_bag
  assign zestaw_body_7os_str = z_al_3rzad | append: z_al_3rz_maly | append: z_al_3rz_duzy | append: z_al_3r2b | append: z_al_przod_duzy_bag

  assign has_body_type_choice = false
  if product.metafields.custom.custom_list_body_type_in_config.value != blank
    assign has_body_type_choice = true
  endif
-%}

{%- for value in option.values -%}
  {%- liquid
    assign option_disabled = true

    for option1_name in variants_option1_arr
      case option.position
        when 1
          if variants_option1_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 2
          if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 3
          if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == product.selected_or_first_available_variant.option2 and variants_option3_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
      endcase
    endfor
  -%}

  {%- if block.settings.picker_type == 'button' -%}
    
    {% assign optionName = value %}
    {% assign optionMatsType = 'general.config.mats_type' | t %}
    {% assign optionMatsSet = 'general.config.mats_set' | t %}
    {% assign optionMatsSize = 'general.config.mats_size' | t %}
    {% assign isConfigTemplate = false %}
    {% if product.template_suffix contains 'config' %}
      {% assign isConfigTemplate = true %}
    {% endif %}
    {% assign isMatsTypeOption = false %}
    {% assign isMatsSetOption = false %}
    {% if isConfigTemplate %}
      {% if option.name == optionMatsType or option.name == 'Mats type' %}
        {% assign isMatsTypeOption = true %}
      {% endif %}
      {% if option.name == optionMatsSet or option.name == 'Mats set' or option.name contains optionMatsSet %}
        {% assign isMatsSetOption = true %}
      {% endif %}
    {% endif %}
    {% assign metaBodyType = body_type_slug %}
    
    {% comment %} Translated word for "Trunk" — used for icon + input_trunk class on all body types {% endcomment %}
    {% assign trunkWord = 'general.config.trunk' | t | downcase %}
    {% assign valueLowercase = value | downcase %}

    {% if forloop.index == 1 and isMatsTypeOption %}
      {% assign optionName = 'classic' %}
    {% endif %}
    {% if forloop.index == 2 and isMatsTypeOption %}
      {% assign optionName = '3d' %}
    {% endif %}
    {% assign body_types = '' %}
    {% if isMatsSetOption %}
      {% assign value_norm = value | downcase | strip %}
      {% assign value_norm = value_norm | replace: '  ', ' ' %}
      {% assign value_norm = value_norm | replace: '  ', ' ' %}
      {% assign value_norm = value_norm | replace: '  ', ' ' %}
      {% assign needle = '|||' | append: value_norm | append: '|||' %}
      {% if zestaw_body_both_str contains needle %}
        {% assign body_types = '5os 7os' %}
      {% elsif zestaw_body_5os_str contains needle %}
        {% assign body_types = '5os' %}
      {% elsif zestaw_body_7os_str contains needle %}
        {% assign body_types = '7os' %}
      {% endif %}
    {% endif %}
    {% comment %} data-body-types only needs both 5os/7os when the product offers a body-type choice; otherwise collapse to the product's own body type {% endcomment %}
    {% assign body_types_attr = body_types %}
    {% unless has_body_type_choice %}
      {% if body_types_attr == '5os 7os' %}
        {% if metaBodyType == '5os' or metaBodyType == '7os' %}
          {% assign body_types_attr = metaBodyType %}
        {% else %}
          {% assign body_types_attr = '' %}
        {% endif %}
      {% endif %}
    {% endunless %}
    <input
      type="radio"
      id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
      data-name="{{ optionName | escape }}"
      name="{{ option.name }}"
      data-title="{{ value }}"
      value="{{ value | escape }}"
      form="{{ product_form_id }}"
      data-index="{{ forloop.index }}"
      class="{% if valueLowercase contains trunkWord %}input_trunk{% endif %}{% if option_disabled %} disabled{% endif %}"
      {% if body_types_attr != '' %}data-body-types="{{ body_types_attr }}"{% endif %}
      {% if option.selected_value == value %}
        checked
      {% endif %}
    >
    {% if isMatsSetOption %}
      {% render 'evamats-mats-set-option-label',
        product: product,
        option: option,
        section: section,
        value: value,
        index: forloop.index0,
        value_norm: value_norm,
        needle: needle,
        body_types: body_types,
        meta_body_type: metaBodyType,
        trunk_word: trunkWord,
        trunk_tooltip_content: trunk_tooltip_content
      %}
    {% elsif isMatsTypeOption %}
      <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" {% if  value contains "#MWS" or value contains "Default Title" %} style="display: none"{% endif %} class="default_option">
        {% assign optionValue = value | downcase %}
        {% case forloop.index %}
          {% when 1 %}
            <img src="{{ '5os-classic-diamonds-black-red.webp' | file_url}}" alt="" loading="lazy">
            <div class="label__tooltip">{% render 'evamats-strip-brand-label', text: value %}</div>
          {% when 2 %}
            <img src="{{ '5os-3d-diamonds-black-red.webp' | file_url}}" alt="" loading="lazy">
            <div class="label__tooltip">{% render 'evamats-strip-brand-label', text: value %}</div>
        {% endcase %}
        <span class="evamats-config-option-label">{% render 'evamats-strip-brand-label', text: value %}</span>

      </label>
    {% elsif is_simple_product %}
      {%- liquid
        assign value_variant = nil
        assign gift_amount_variant = nil

        if option_is_gift_amount
          if option.position == 2
            assign selected_card_type = product.selected_or_first_available_variant.option1
            for variant in product.variants
              if variant.option1 == selected_card_type and variant.option2 == value
                assign gift_amount_variant = variant
                assign value_variant = variant
                break
              endif
            endfor
          elsif option.position == 1
            assign selected_card_type = product.selected_or_first_available_variant.option2
            for variant in product.variants
              if variant.option2 == selected_card_type and variant.option1 == value
                assign gift_amount_variant = variant
                assign value_variant = variant
                break
              endif
            endfor
          endif
        else
          for variant in product.variants
            case option.position
              when 1
                if variant.option1 == value
                  assign value_variant = variant
                endif
              when 2
                if variant.option2 == value
                  assign value_variant = variant
                endif
              when 3
                if variant.option3 == value
                  assign value_variant = variant
                endif
            endcase
          endfor
        endif
      -%}
      {% if option_is_gift_amount %}
        <label
          for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
          {% if value contains '#MWS' or value contains 'Default Title' %} style="display: none"{% endif %}
          class="evamats-product-option__swatch evamats-product-option__amount-swatch"
        >
          <span class="evamats-product-option__amount-media">
            {%- if value_variant.featured_media -%}
              {{
                value_variant.featured_media
                | image_url: width: 220
                | image_tag: loading: 'lazy', widths: '110, 220', sizes: '110px', alt: value, class: 'evamats-product-option__amount-image'
              }}
            {%- elsif product.featured_media -%}
              {{
                product.featured_media
                | image_url: width: 220
                | image_tag: loading: 'lazy', widths: '110, 220', sizes: '110px', alt: value, class: 'evamats-product-option__amount-image'
              }}
            {%- endif -%}
          </span>
          <span class="evamats-product-option__amount-label" data-gift-amount-value="{{ value | escape }}">
            {%- if gift_amount_variant -%}
              {{ gift_amount_variant.price | money }}
            {%- else -%}
              {{ value }}
            {%- endif -%}
          </span>
          <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
        </label>
      {% elsif option_has_swatch and value_variant.featured_media %}
        <label
          for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
          {% if value contains '#MWS' or value contains 'Default Title' %} style="display: none"{% endif %}
          class="evamats-product-option__swatch"
        >
          {{
            value_variant.featured_media
            | image_url: width: 128
            | image_tag: loading: 'lazy', widths: '64,128', sizes: '64px', alt: value
          }}
          <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
        </label>
      {% else %}
        <label
          for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
          {% if value contains '#MWS' or value contains 'Default Title' %} style="display: none"{% endif %}
          class="evamats-product-option__pill"
        >
          {{- value -}}
          <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
        </label>
      {% endif %}
    {% else %}
      <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" {% if  value contains "#MWS" or value contains "Default Title" %} style="display: none"{% endif %}>
        {{ value -}}
        <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
      </label>
    {% endif %}
    
    
  {%- elsif block.settings.picker_type == 'dropdown' -%}
    <option
      value="{{ value | escape }}"
      {% if option.selected_value == value %}
        selected="selected"
      {% endif %}
    >
      {% if option_disabled -%}
        {{- 'products.product.value_unavailable' | t: option_value: value -}}
      {%- else -%}
        {{- value -}}
      {%- endif %}
    </option>
  {%- endif -%}
{%- endfor -%}
