{% comment %}
  Renders product variant options

  Accepts:
  - product: {Object} product object.
  - option: {Object} current product_option object.
  - block: {Object} block object.


  Usage:
  {% render 'product-variant-options',
    product: product,
    option: option,
    block: block
  %}
{% endcomment %}
{%- liquid
  assign variants_available_arr = product.variants | map: 'available'
  assign variants_option1_arr = product.variants | map: 'option1'
  assign variants_option2_arr = product.variants | map: 'option2'
  assign variants_option3_arr = product.variants | map: 'option3'

  assign product_form_id = 'product-form-' | append: section.id
-%}

{%- for value in option.values -%}
  {%- liquid
    assign option_disabled = true

    for option1_name in variants_option1_arr
      case option.position
        when 1
          if variants_option1_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 2
          if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 3
          if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == product.selected_or_first_available_variant.option2 and variants_option3_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
      endcase
    endfor
  -%}

  {%- if block.settings.picker_type == 'button' -%}
    
    {% assign optionName = value %}
    {% assign optionMatsType = 'general.config.mats_type' | t %}
    {% assign optionMatsSet = 'general.config.mats_set' | t %}
    {% assign optionMatsSize = 'general.config.mats_size' | t %}
    {% assign isMatsTypeOption = false %}
    {% if option.name == optionMatsType or option.name == 'Mats type' %}
      {% assign isMatsTypeOption = true %}
    {% endif %}
    {% assign isMatsSetOption = false %}
    {% if option.name == optionMatsSet or option.name == 'Mats set' %}
      {% assign isMatsSetOption = true %}
    {% endif %}
    {% assign metaBodyType = product.metafields.custom.body_type %}
    
    {% comment %} Translated word for "Trunk" — used for icon + input_trunk class on all body types {% endcomment %}
    {% assign trunkWord = 'general.config.trunk' | t | downcase %}
    {% assign valueLowercase = value | downcase %}

    {% if forloop.index == 1 and isMatsTypeOption %}
      {% assign optionName = 'classic' %}
    {% endif %}
    {% if forloop.index == 2 and isMatsTypeOption %}
      {% assign optionName = '3d' %}
    {% endif %}
    <input
      type="radio"
      id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
      data-name="{{ optionName | escape }}"
      name="{{ option.name }}"
      data-title="{{ value }}"
      value="{{ value | escape }}"
      form="{{ product_form_id }}"
      data-index="{{ forloop.index }}"
      class="{% if valueLowercase contains trunkWord %}input_trunk{% endif %}{% if option_disabled %} disabled{% endif %}"
      {% if option.selected_value == value %}
        checked
      {% endif %}
    >
    {% if isMatsSetOption %}
      {% if metaBodyType == '5os' %}
        <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" {% if  value contains "#MWS" or value contains "Default Title" %} style="display: none"{% endif %} class="default_option">
          {% assign optionValue = value | downcase %}
          {% case forloop.index %}
            {% when 1 %}
              <img src="{{ '5os-mat-front-1.webp' | file_url}}" alt="" loading="lazy">
              <div class="label__tooltip">{{ value }}</div>
            {% when 2 %}
              <img src="{{ '5os-mat-front-2.webp' | file_url}}" alt="" loading="lazy">
              <div class="label__tooltip">{{ value }}</div>
              <div class="label_badge">-5%</div>
            {% when 3 %}
