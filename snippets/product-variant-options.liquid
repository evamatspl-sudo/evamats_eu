              <div class="label__tooltip">{{ value }}</div>
            {% when 6 %}
              <img src="{{ '5os-mat-set.svg' | file_url}}" alt="" loading="lazy">
              <div class="label__tooltip">{{ value }}</div>
              <div class="label_badge">-15%</div>
          {% endcase %}
          {% if valueLowercase contains trunkWord %}
            {% render 'evamats-trunk-option-notice', trunk_content: trunk_tooltip_content %}
          {% endif %}
        </label>
