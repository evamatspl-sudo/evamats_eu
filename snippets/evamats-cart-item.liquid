{% comment %}
  Cart line item — Figma 1710:11106 desktop / 1710:10701 mobile
  Params: item, line_index, section_id
{% endcomment %}
{%- liquid
  assign line_index = line_index | default: item.index | plus: 1
  assign has_discount = false
  assign discount_percent = 0
  assign compare_line = item.variant.compare_at_price | times: item.quantity
  if compare_line > item.final_line_price and compare_line > 0
    assign has_discount = true
    assign discount_amount = compare_line | minus: item.final_line_price
    assign discount_percent = discount_amount | times: 100.0 | divided_by: compare_line | round
  elsif item.original_line_price > item.final_line_price and item.original_line_price > 0
    assign has_discount = true
    assign discount_amount = item.original_line_price | minus: item.final_line_price
    assign discount_percent = discount_amount | times: 100.0 | divided_by: item.original_line_price | round
  endif

  assign has_options = false
  if item.product.has_only_default_variant == false
    assign has_options = true
  endif
  if item.properties.size > 0
    assign has_options = true
  endif
  if item.selling_plan_allocation != null
    assign has_options = true
  endif
-%}

<article class="evamats-cart-item cart-item" id="CartItem-{{ line_index }}" data-line-key="{{ item.key }}" role="listitem">
  <div class="evamats-cart-item__media cart-item__media">
    {% if item.image %}
      <a href="{{ item.url }}" class="cart-item__link" aria-hidden="true" tabindex="-1"></a>
      <div class="evamats-cart-item__image-wrap cart-item__image-container">
        <img
          src="{{ item.image | image_url: width: 300 }}"
          class="evamats-cart-item__image cart-item__image"
          alt="{{ item.image.alt | escape }}"
          loading="lazy"
          width="150"
          height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
        >
        <button type="button" class="evamats-cart-item__restore" data-cart-restore>
          {{ 'sections.cart.restore_item' | t }}
        </button>
      </div>
    {% endif %}
  </div>

  <div class="evamats-cart-item__body cart-item__details">
    <div class="evamats-cart-item__top">
      <a href="{{ item.url }}" class="evamats-cart-item__title cart-item__name break">
        {{- item.product.title | escape -}}
        <span class="ga_cart_upsell" data-productid="{{ item.product_id }}"></span>
      </a>

      <div class="evamats-cart-item__price-mobile large-up-hide">
        {% render 'evamats-cart-item-price', item: item, has_discount: has_discount, discount_percent: discount_percent, mobile: true %}
      </div>

      <cart-remove-button class="evamats-cart-item__remove-wrap large-up-hide" id="Remove-mobile-{{ line_index }}" data-index="{{ line_index }}" data-key="{{ item.key }}">
        <a
          href="{{ item.url_to_remove }}"
          class="evamats-cart-item__remove"
          aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M11.6616 1.74198C11.5077 1.74562 11.3615 1.80991 11.2549 1.92086L7.00064 6.17509L2.74641 1.92086C2.69205 1.86498 2.62704 1.82056 2.55522 1.79023C2.4834 1.7599 2.40624 1.74427 2.32828 1.74426C2.21223 1.74429 2.09883 1.77893 2.00258 1.84375C1.90632 1.90856 1.83158 2.00061 1.78792 2.10813C1.74425 2.21564 1.73364 2.33374 1.75744 2.44732C1.78124 2.56089 1.83838 2.66479 1.92154 2.74573L6.17577 6.99996L1.92154 11.2542C1.86555 11.3079 1.82086 11.3723 1.79007 11.4436C1.75927 11.5148 1.74301 11.5915 1.74222 11.6691C1.74143 11.7467 1.75613 11.8237 1.78547 11.8955C1.8148 11.9674 1.85818 12.0327 1.91306 12.0875C1.96794 12.1424 2.03322 12.1858 2.10507 12.2151C2.17692 12.2445 2.25391 12.2592 2.33151 12.2584C2.40912 12.2576 2.48579 12.2413 2.55703 12.2105C2.62827 12.1797 2.69266 12.135 2.74641 12.0791L7.00064 7.82483L11.2549 12.0791C11.3086 12.135 11.373 12.1797 11.4442 12.2105C11.5155 12.2413 11.5922 12.2576 11.6698 12.2584C11.7474 12.2592 11.8244 12.2445 11.8962 12.2151C11.9681 12.1858 12.0333 12.1424 12.0882 12.0875C12.1431 12.0327 12.1865 11.9674 12.2158 11.8955C12.2451 11.8237 12.2599 11.7467 12.2591 11.6691C12.2583 11.5915 12.242 11.5148 12.2112 11.4436C12.1804 11.3723 12.1357 11.3079 12.0797 11.2542L7.82551 6.99996L12.0797 2.74573C12.1645 2.66426 12.2226 2.55911 12.2465 2.44405C12.2705 2.32898 12.2591 2.20937 12.2139 2.10087C12.1687 1.99238 12.0918 1.90007 11.9933 1.83603C11.8947 1.77199 11.7791 1.73921 11.6616 1.74198Z" fill="#8090A4"/>
          </svg>
        </a>
      </cart-remove-button>
    </div>

    {%- if has_options -%}
      <div class="evamats-cart-item__chips">
        {%- if item.product.has_only_default_variant == false -%}
          {%- for option in item.options_with_values -%}
            {%- if option.name == 'Title' -%}{%- continue -%}{%- endif -%}
            {%- unless option.value contains 'Default Title' -%}
              {% render 'evamats-cart-option-chip', product: item.product, option_name: option.name, option_value: option.value %}
            {%- endunless -%}
          {%- endfor -%}
        {%- endif -%}

        {%- for property in item.properties -%}
          {%- if property.first == '_bundle' or property.first == '__is_bundle_product' or property.first == '_upsell_bundle' -%}
            {%- continue -%}
          {%- endif -%}
          {%- assign property_first_char = property.first | slice: 0 -%}
          {%- if property.last != blank and property_first_char != '_' -%}
            {%- assign prop_cell_shape = 'general.config.cell_shape' | t -%}
            {%- assign prop_material_color = 'general.config.material_color' | t -%}
            {%- assign prop_trim_color = 'general.config.trim_color' | t -%}
            {%- if property.first == prop_cell_shape or property.first == prop_material_color or property.first == prop_trim_color -%}
              {% render 'evamats-cart-property-chip', property_name: property.first, property_value: property.last %}
            {%- elsif property.last contains '/uploads/' -%}
              {%- assign file_type = property.last | split: '.' | last | downcase -%}
              {%- assign file_types = 'jpg,jpeg,webp,gif,png,apng,avif,svg,bmp,ico,tiff' | split: ',' -%}
              {%- unless file_types contains file_type -%}
                {%- continue -%}
              {%- endunless -%}
              {% render 'evamats-cart-chip', chip_label: property.first, chip_image: property.last %}
            {%- else -%}
              {% render 'evamats-cart-chip', chip_label: property.last, chip_image: blank %}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if item.selling_plan_allocation != null -%}
          {% render 'evamats-cart-chip', chip_label: item.selling_plan_allocation.selling_plan.name, chip_image: blank %}
        {%- endif -%}
      </div>
    {%- endif -%}

    <ul class="discounts list-unstyled evamats-cart-item__discounts" role="list" aria-label="{{ 'customer.order.discount' | t }}">
      {%- for discount in item.discounts -%}
        <li class="discounts__discount">
          {%- render 'icon-discount' -%}
          {{ discount.title }}
        </li>
      {%- endfor -%}
    </ul>

    <div class="evamats-cart-item__actions cart-item__quantity">
      <div class="evamats-cart-item__qty-row">
        <div class="cart-item__quantity-wrapper">
          <label class="visually-hidden" for="Quantity-{{ line_index }}">
            {{ 'products.product.quantity.label' | t }}
          </label>
          <quantity-input class="quantity cart-quantity evamats-cart-item__quantity">
            <button class="quantity__button no-js-hidden" name="minus" type="button">
              <span class="visually-hidden">
                {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
              </span>
              {% render 'icon-minus' %}
            </button>
            <input
              class="quantity__input"
              data-quantity-variant-id="{{ item.variant.id }}"
              type="number"
              name="updates[]"
              value="{{ item.quantity }}"
              {% # theme-check-disable %}
              data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
              min="{{ item.variant.quantity_rule.min }}"
              {% if item.variant.quantity_rule.max != null %}
                max="{{ item.variant.quantity_rule.max }}"
              {% endif %}
              step="{{ item.variant.quantity_rule.increment }}"
              {% # theme-check-enable %}
              aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
              id="Quantity-{{ line_index }}"
              data-index="{{ line_index }}"
            >
            <button class="quantity__button no-js-hidden" name="plus" type="button">
              <span class="visually-hidden">
                {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
              </span>
              {% render 'icon-plus' %}
            </button>
          </quantity-input>
        </div>

        <p class="evamats-cart-item__unit-price small-hide">
          {%- liquid
            if item.original_price != item.final_price
              assign unit_price_money = item.final_price | money
            else
              assign unit_price_money = item.original_price | money
            endif
          -%}
          {{ 'sections.cart.unit_price_each_html' | t: price: unit_price_money }}
        </p>
      </div>

      <div class="cart-item__error" id="Line-item-error-{{ line_index }}" role="alert">
        <small class="cart-item__error-text"></small>
        <svg aria-hidden="true" focusable="false" class="icon icon-error" viewBox="0 0 13 13">
          <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
          <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
          <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
          <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
        </svg>
      </div>
    </div>
  </div>

  <div class="evamats-cart-item__aside cart-item__totals right small-hide">
    <div class="loading-overlay hidden">
      <div class="loading-overlay__spinner">
        <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
          <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
        </svg>
      </div>
    </div>

    <cart-remove-button id="Remove-{{ line_index }}" data-index="{{ line_index }}" data-key="{{ item.key }}">
      <a
        href="{{ item.url_to_remove }}"
        class="evamats-cart-item__remove"
        aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <path d="M11.6616 1.74198C11.5077 1.74562 11.3615 1.80991 11.2549 1.92086L7.00064 6.17509L2.74641 1.92086C2.69205 1.86498 2.62704 1.82056 2.55522 1.79023C2.4834 1.7599 2.40624 1.74427 2.32828 1.74426C2.21223 1.74429 2.09883 1.77893 2.00258 1.84375C1.90632 1.90856 1.83158 2.00061 1.78792 2.10813C1.74425 2.21564 1.73364 2.33374 1.75744 2.44732C1.78124 2.56089 1.83838 2.66479 1.92154 2.74573L6.17577 6.99996L1.92154 11.2542C1.86555 11.3079 1.82086 11.3723 1.79007 11.4436C1.75927 11.5148 1.74301 11.5915 1.74222 11.6691C1.74143 11.7467 1.75613 11.8237 1.78547 11.8955C1.8148 11.9674 1.85818 12.0327 1.91306 12.0875C1.96794 12.1424 2.03322 12.1858 2.10507 12.2151C2.17692 12.2445 2.25391 12.2592 2.33151 12.2584C2.40912 12.2576 2.48579 12.2413 2.55703 12.2105C2.62827 12.1797 2.69266 12.135 2.74641 12.0791L7.00064 7.82483L11.2549 12.0791C11.3086 12.135 11.373 12.1797 11.4442 12.2105C11.5155 12.2413 11.5922 12.2576 11.6698 12.2584C11.7474 12.2592 11.8244 12.2445 11.8962 12.2151C11.9681 12.1858 12.0333 12.1424 12.0882 12.0875C12.1431 12.0327 12.1865 11.9674 12.2158 11.8955C12.2451 11.8237 12.2599 11.7467 12.2591 11.6691C12.2583 11.5915 12.242 11.5148 12.2112 11.4436C12.1804 11.3723 12.1357 11.3079 12.0797 11.2542L7.82551 6.99996L12.0797 2.74573C12.1645 2.66426 12.2226 2.55911 12.2465 2.44405C12.2705 2.32898 12.2591 2.20937 12.2139 2.10087C12.1687 1.99238 12.0918 1.90007 11.9933 1.83603C11.8947 1.77199 11.7791 1.73921 11.6616 1.74198Z" fill="#8090A4"/>
        </svg>
      </a>
    </cart-remove-button>

    <div class="cart-item__price-wrapper evamats-cart-item__price-desktop">
      {% render 'evamats-cart-item-price', item: item, has_discount: has_discount, discount_percent: discount_percent, mobile: false %}
    </div>
  </div>

</article>
