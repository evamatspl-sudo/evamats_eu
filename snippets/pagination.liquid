{% comment %}
  Renders paginated page links. Must be used within paginate tags.

  Usage:
  {% paginate results by 16 %}
    {% render 'pagination', paginate: paginate, anchor: '#ProductGridContainer' %}
  {% endpaginate %}

  Accepts:
  - paginate: {Object}
  - anchor: {String} (optional)
{% endcomment %}

<link rel="stylesheet" href="{{ 'component-pagination.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-pagination.css' | asset_url | stylesheet_tag }}</noscript>

{%- if paginate.parts.size > 1 -%}
  <div class="evamats-pagination">
    <nav class="evamats-pagination__nav" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
      <ul class="evamats-pagination__list list-unstyled" role="list">
        <li class="evamats-pagination__item">
          {%- if paginate.previous -%}
            <a
              href="{{ paginate.previous.url }}{{ anchor }}"
              class="evamats-pagination__arrow evamats-pagination__arrow--prev"
              aria-label="{{ 'general.pagination.previous' | t }}"
            >
              {% render 'evamats-pagination-arrow', direction: 'prev' %}
            </a>
          {%- else -%}
            <span class="evamats-pagination__arrow evamats-pagination__arrow--prev evamats-pagination__arrow--disabled" aria-hidden="true">
              {% render 'evamats-pagination-arrow', direction: 'prev' %}
            </span>
          {%- endif -%}
        </li>

        {%- for part in paginate.parts -%}
          <li class="evamats-pagination__item">
            {%- if part.is_link -%}
              <a
                href="{{ part.url }}{{ anchor }}"
                class="evamats-pagination__page"
                aria-label="{{ 'general.pagination.page' | t: number: part.title }}"
              >
                {{- part.title -}}
              </a>
            {%- elsif part.title == paginate.current_page -%}
              <span
                class="evamats-pagination__page evamats-pagination__page--current"
                aria-current="page"
                aria-label="{{ 'general.pagination.page' | t: number: part.title }}"
              >
                {{- part.title -}}
              </span>
            {%- else -%}
              <span class="evamats-pagination__page evamats-pagination__page--ellipsis" aria-hidden="true">
                {{- part.title -}}
              </span>
            {%- endif -%}
          </li>
        {%- endfor -%}

        <li class="evamats-pagination__item">
          {%- if paginate.next -%}
            <a
              href="{{ paginate.next.url }}{{ anchor }}"
              class="evamats-pagination__arrow evamats-pagination__arrow--next"
              aria-label="{{ 'general.pagination.next' | t }}"
            >
              {% render 'evamats-pagination-arrow', direction: 'next' %}
            </a>
          {%- else -%}
            <span class="evamats-pagination__arrow evamats-pagination__arrow--next evamats-pagination__arrow--disabled" aria-hidden="true">
              {% render 'evamats-pagination-arrow', direction: 'next' %}
            </span>
          {%- endif -%}
        </li>
      </ul>
    </nav>
  </div>
{%- endif -%}
