{% comment %}
  Cart variant option chip with icon
  Params: product, option_name, option_value
{% endcomment %}
{%- liquid
  assign chip_product = all_products[product.handle] | default: product
  assign chip_label = option_value | split: '#MWS' | first | strip
  assign chip_image = blank
  assign option_mats_type = 'general.config.mats_type' | t
  assign option_mats_set = 'general.config.mats_set' | t
  assign meta_body_type = chip_product.metafields.custom.body_type
  assign value_index = -1
  assign value_norm = chip_label | downcase | strip
  assign value_norm = value_norm | replace: '  ', ' '

  for product_option in chip_product.options_with_values
    if product_option.name == option_name
      for val in product_option.values
        assign val_clean = val | split: '#MWS' | first | strip
        if val_clean == chip_label
          assign value_index = forloop.index0
        endif
      endfor
    endif
  endfor

  assign is_mats_type_option = false
  if option_name == option_mats_type or option_name == 'Mats type'
    assign is_mats_type_option = true
  endif

  assign is_mats_set_option = false
  if option_name == option_mats_set or option_name == 'Mats set'
    assign is_mats_set_option = true
  endif
-%}

{%- if is_mats_type_option -%}
  {%- liquid
    assign mats_type_needle = '|||' | append: value_norm | append: '|||'
    assign without_edges_label = 'general.config.without_edges' | t | downcase
    assign with_edges_label = 'general.config.with_edges' | t | downcase
    assign mats_type_classic_aliases = '|||3d bez rantów|||3d bez rantow|||without edges|||without edge|||classic|||klasyczne|||' | append: without_edges_label | append: '|||'
    assign mats_type_rims_aliases = '|||3d z rantami|||with edges|||with rim|||3d|||premium|||' | append: with_edges_label | append: '|||'
    assign mats_type_image = '5os-3d-diamonds-black-red.webp'
    if mats_type_classic_aliases contains mats_type_needle
      assign mats_type_image = '5os-classic-diamonds-black-red.webp'
    elsif mats_type_rims_aliases contains mats_type_needle
      assign mats_type_image = '5os-3d-diamonds-black-red.webp'
    elsif value_index == 0
      assign mats_type_image = '5os-classic-diamonds-black-red.webp'
    elsif value_index == 1
      assign mats_type_image = '5os-3d-diamonds-black-red.webp'
    endif
    assign chip_image = mats_type_image | file_url
    assign chip_label = chip_label | replace: 'EVAMATS', '' | replace: '  ', ' ' | strip
  -%}
{%- elsif is_mats_set_option -%}
  {%- liquid
    assign custom_images = chip_product.metafields.custom.custom_mats_set_images.value
    if custom_images != blank and value_index >= 0 and custom_images[value_index] != blank
      assign chip_image = custom_images[value_index]
    endif

    assign needle = '|||' | append: value_norm | append: '|||'

    assign en_only_driver = 'general.config.only_driver_mat' | t | downcase
    assign en_front = 'general.config.front' | t | downcase
    assign en_rear = 'general.config.rear' | t | downcase
    assign en_trunk = 'general.config.trunk' | t | downcase
    assign en_front_rear = 'general.config.front_rear' | t | downcase
    assign en_front_rear_trunk = 'general.config.front_rear_trunk' | t | downcase

    assign zestaw_image_file = blank

    if value_norm == en_only_driver or value_norm == 'dywanik kierowcy'
      if meta_body_type contains '7os' or meta_body_type == 'electro_7os'
        assign zestaw_image_file = '7os-mat-front-1.webp'
      else
        assign zestaw_image_file = '5os-mat-front-1.svg'
      endif
    elsif value_norm == en_front or value_norm == 'przód'
      if meta_body_type contains '7os' or meta_body_type == 'electro_7os'
        assign zestaw_image_file = '7os-mat-front-2.webp'
      else
        assign zestaw_image_file = '5os-mat-front-2.svg'
      endif
    elsif value_norm == en_rear or value_norm == 'tył'
      if meta_body_type contains '7os' or meta_body_type == 'electro_7os'
        assign zestaw_image_file = '7os-mat-back-2.webp'
      else
        assign zestaw_image_file = '5os-mat-back-2.svg'
      endif
    elsif value_norm == en_front_rear or value_norm == 'przód + tył'
      if meta_body_type contains '7os' or meta_body_type == 'electro_7os'
        assign zestaw_image_file = '7os-mat-front-back.webp'
      else
        assign zestaw_image_file = '5os-mat-front-back.svg'
      endif
    elsif value_norm == en_trunk or value_norm == 'mata do bagażnika'
      if meta_body_type contains '7os' or meta_body_type == 'electro_7os'
        assign zestaw_image_file = '7os-mat-trunk.webp'
      else
        assign zestaw_image_file = '5os-mat-trunk.svg'
      endif
    elsif value_norm == en_front_rear_trunk or value_norm == 'przód + tył + bagażnik'
      if meta_body_type contains '7os' or meta_body_type == 'electro_7os'
        assign zestaw_image_file = '7os-mat-set-row.webp'
      else
        assign zestaw_image_file = '5os-mat-set.svg'
      endif
    elsif value_norm == '3 rzędy + 2 bagażniki (duży | mały)'
      assign zestaw_image_file = '7os-mat-set-trunk-2.webp'
    elsif value_norm == 'przód + tył + 3 rząd + duży bagażnik'
      assign zestaw_image_file = '7os-mat-set-row-trunk-l.webp'
    elsif value_norm == 'przód + tył + 3 rząd + mały bagażnik'
      assign zestaw_image_file = '7os-mat-set-row-trunk-sm.webp'
    elsif value_norm == 'przód + tył + 3 rząd'
      assign zestaw_image_file = '7os-mat-set-row.webp'
    elsif value_norm == 'przód + tył + duży bagażnik'
      assign zestaw_image_file = '7os-mat-set-trunk-l.webp'
    endif

    if chip_image == blank and zestaw_image_file != blank
      assign chip_image = zestaw_image_file | file_url
    endif

    if chip_image == blank and value_index >= 0 and meta_body_type != blank
      assign default_images = blank | split: '|'
      case meta_body_type
        when '5os'
          assign default_images = '5os-mat-front-1.svg|5os-mat-front-2.svg|5os-mat-back-2.svg|5os-mat-front-back.svg|5os-mat-trunk.svg|5os-mat-set.svg' | split: '|'
        when '2os'
          assign default_images = '5os-mat-front-1.svg|5os-mat-front-2.svg|5os-mat-trunk.svg|5os-mat-front-trunk.webp' | split: '|'
        when 'electro'
          assign default_images = '5os-mat-front-1.svg|5os-mat-front-2.svg|5os-mat-back-2.svg|5os-mat-front-back.svg|5os-mat-trunk.svg|5os-mat-set.svg|5os-mat-set-front.webp' | split: '|'
        when 'electro_7os'
          assign default_images = '7os-mat-front-1.webp|7os-mat-front-2.webp|7os-mat-back-2.webp|7os-mat-front-back.webp|7os-mat-trunk.webp|7os-mat-set-row.webp|7os-mat-set-row-trunk-sm.webp|7os-mat-set-row-trunk-l.webp|7os-mat-set-trunk-l.webp|7os-mat-set-trunk-sm-front.webp|7os-mat-set-trunk-l-front.webp|7os-mat-set-front-back-trunk-sm-front.webp' | split: '|'
        when '7os'
          assign default_images = '7os-mat-front-1.webp|7os-mat-front-2.webp|7os-mat-back-2.webp|7os-mat-front-back.webp|7os-mat-trunk.webp|7os-mat-set-row.webp|7os-mat-set-row-trunk-sm.webp|7os-mat-set-row-trunk-l.webp|7os-mat-set-trunk-2.webp|7os-mat-set-trunk-l.webp' | split: '|'
        when 'minivan'
          assign default_images = 'minivan-1.webp|minivan-2.webp|minivan-3.webp|minivan-4.webp|minivan-5.webp|minivan-6.webp|minivan-7.webp|minivan-8.webp|minivan-9.webp' | split: '|'
        when 'bus'
          assign default_images = 'bus-1.webp|bus-2.webp|bus-3.webp|bus-4.webp|bus-6.webp|bus-5.webp' | split: '|'
        when 'bus_solid'
          assign default_images = 'bus_solid_1.webp|bus_solid_2.webp|bus_solid_3.webp|bus_solid_4.webp|bus_solid_5.webp' | split: '|'
        when 'camper'
          assign default_images = 'bus-2.webp' | split: '|'
        when 'pickup'
          assign default_images = 'pickup-1.webp|pickup-2.webp|pickup-7.webp|pickup-5.webp' | split: '|'
        when 'pickup2kabina'
          assign default_images = 'pickup-1.webp|pickup-2.webp|pickup-3.webp|pickup-4.webp|pickup-5.webp|pickup-6.webp' | split: '|'
        when 'tir'
          assign default_images = 'tir-1.webp|tir-2.webp|tir-3.webp' | split: '|'
        when 'van_duzy'
          assign default_images = 'van-duzy-4.webp|van-duzy-1.webp|van-duzy-2.webp|van-duzy-3.webp' | split: '|'
        when 'van_duzy_separate'
          assign default_images = 'van-duzy-4.webp|van-duzy-1.webp|van-duzy-2.webp|van-duzy-3.webp' | split: '|'
        when 'van_duzy_separate_2_row'
          assign default_images = 'van-duzy-4.webp|van-duzy-6.webp|van-duzy-5.webp|van-duzy-8.webp|van-duzy-7.webp|van-duzy-3.webp' | split: '|'
        when 'van_duzy_solid'
          assign default_images = 'van-duzy-1.webp|van-duzy-2.webp|van-duzy-3.webp' | split: '|'
        when 'van_duzy_solid_2_row'
          assign default_images = 'van-duzy-10.webp|van-duzy-9.webp|van-duzy-12.webp|van-duzy-11.webp|van-duzy-3.webp' | split: '|'
        when 'van_maly'
          assign default_images = 'van-sm-1.webp|van-sm-2.webp|van-sm-3.webp|van-sm-4.webp' | split: '|'
        when 'tractor'
          assign default_images = 'tractor.webp' | split: '|'
        when 'custom'
          assign default_images = '5os-mat-front-2.svg|5os-mat-back-2.svg|5os-mat-front-back.svg|5os-mat-trunk.svg|5os-mat-set.svg' | split: '|'
      endcase

      assign fallback_image_file = default_images[value_index]
      if fallback_image_file != blank
        assign chip_image = fallback_image_file | file_url
      endif
    endif
  -%}
{%- endif -%}

{% render 'evamats-cart-chip', chip_label: chip_label, chip_image: chip_image %}
