{%- comment -%}
  Pair of round slider arrows — Figma RoundButton 2209:14169

  @param size {string} large | medium | small
  @param color {string} red | white
  @param absolute {boolean}
  @param class {string} extra class on wrapper
  @param prev_label {string}
  @param next_label {string}
{%- endcomment -%}

<div class="eva-slider-controls__arrows{% if class != blank %} {{ class }}{% endif %}">
  {% render 'eva-slider-nav-button',
    direction: 'prev',
    size: size,
    color: color,
    absolute: absolute,
    label: prev_label
  %}
  {% render 'eva-slider-nav-button',
    direction: 'next',
    size: size,
    color: color,
    absolute: absolute,
    label: next_label
  %}
</div>
